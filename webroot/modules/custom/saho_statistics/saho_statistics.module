<?php

/**
 * @file
 * Contains hooks and functions for the SAHO Statistics module.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\node\NodeInterface;
use Drupal\taxonomy\TermInterface;

/**
 * Implements hook_help().
 */
function saho_statistics_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.saho_statistics':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Provides statistics tracking and most popular content functionality.') . '</p>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function saho_statistics_theme($existing, $type, $theme, $path) {
  return [
    'saho_top_read_content_block' => [
      'variables' => [
        'items' => [],
        'block_title' => '',
        'display_mode' => 'list',
        'show_view_count' => TRUE,
        'show_thumbnail' => FALSE,
        'full_width' => TRUE,
      ],
      'template' => 'saho-top-read-content-block',
    ],
    'saho_history_through_pictures' => [
      'variables' => [
        'items' => [],
        'block_title' => '',
        'display_mode' => 'grid',
        'show_title' => TRUE,
        'show_caption' => FALSE,
        'total_count' => 0,
      ],
      'template' => 'saho-history-through-pictures',
    ],
    'history_through_pictures_gallery' => [
      'variables' => [
        'items' => [],
        'total_count' => 0,
        'sort_links' => [],
        'current_sort' => 'newest',
        'pager' => NULL,
      ],
      'template' => 'history-through-pictures-gallery',
    ],
  ];
}

/**
 * Implements hook_theme_suggestions_HOOK_alter() for views-view.
 */
function saho_statistics_theme_suggestions_views_view_alter(array &$suggestions, array $variables) {
  // We want to ensure our preprocess function runs for the classroom view template.
  $view = $variables['view'];
  if (isset($view) && $view->id() == 'classroom') {
    $suggestions[] = 'views_view__classroom';
  }
}

/**
 * Implements hook_preprocess_views_view().
 */
function saho_statistics_preprocess_views_view(&$variables) {
  $view = $variables['view'];

  // Only act on the classroom view.
  if (isset($view) && $view->id() == 'classroom') {
    // Get popular terms from our service - getting terms from all vocabularies.
    $popular_terms = \Drupal::service('saho_statistics.term_tracker')->getPopularTerms(10);

    // Add them to template variables.
    $variables['popular_terms'] = $popular_terms;
  }
}

/**
 * Implements hook_entity_view().
 */
function saho_statistics_entity_view(array &$build, EntityInterface $entity, $display, $view_mode) {
  // Track page views for content entities.
  if ($entity->getEntityTypeId() == 'node' && $view_mode == 'full') {
    // Track the pageview using Drupal's core statistics module functionality.
    if (\Drupal::moduleHandler()->moduleExists('statistics')) {
      // We could track page views here, but we'll rely on Drupal's built-in
      // statistics tracking instead of calling a specific function.
      // @see statistics.module
    }

    // Track entity references for this node if applicable.
    if ($entity instanceof NodeInterface && $entity->hasField('field_tags') && !$entity->get('field_tags')->isEmpty()) {
      // We could add custom tracking logic here if needed.
    }
  }
}

/**
 * Implements hook_entity_update().
 */
function saho_statistics_entity_update(EntityInterface $entity) {
  // If a taxonomy term is updated, we may want to rebuild caches for related entities.
  if ($entity instanceof TermInterface) {
    // Clear cached statistics for this term.
    \Drupal::service('saho_statistics.term_tracker')->clearCache();
  }
}

/**
 * Implements hook_page_attachments().
 *
 * Passes real popular search queries (from saho_search_queries table) to
 * drupalSettings so the search modal can render live data instead of
 * hardcoded chips. Falls back gracefully to an empty array so the Twig
 * fallback chips remain visible if no data exists yet.
 */
function saho_statistics_page_attachments(array &$attachments) {
  $cid = 'saho_statistics:popular_searches';
  $cache = \Drupal::cache()->get($cid);

  if ($cache) {
    $popular = $cache->data;
  }
  else {
    $popular = _saho_statistics_get_popular_searches(8);
    // Cache for 15 minutes so trending topics stay reasonably fresh.
    \Drupal::cache()->set($cid, $popular, \Drupal::time()->getRequestTime() + 900);
  }

  $attachments['#attached']['drupalSettings']['sahoSearch']['popularSearches'] = $popular;
}

/**
 * Returns the top N most-searched queries over the last 90 days.
 *
 * Performs a case-insensitive GROUP BY so "Mandela" and "mandela" merge.
 * Only includes queries that returned at least one result.
 *
 * @param int $limit
 *   Maximum number of results to return.
 *
 * @return array
 *   Array of associative arrays with 'label' (original-case representative)
 *   and 'url' keys, ordered by descending search count.
 */
function _saho_statistics_get_popular_searches(int $limit = 8): array {
  $config = \Drupal::config('saho_statistics.settings');
  if (!$config->get('track_searches')) {
    return [];
  }

  try {
    $cutoff = \Drupal::time()->getRequestTime() - (90 * 86400);

    // Group by lowercase query text and pick one representative label.
    $db = \Drupal::database();
    $query = $db->select('saho_search_queries', 'q');
    $query->addField('q', 'query_text', 'query_label');
    $query->addExpression('COUNT(*)', 'search_count');
    $query->condition('q.timestamp', $cutoff, '>');
    // Only queries that returned meaningful results (≥5) are useful suggestions.
    $query->condition('q.result_count', 5, '>=');
    // utf8mb4 collation is case-insensitive — duplicates (Mandela/mandela) merge.
    $query->groupBy('q.query_text');
    // Require at least 2 searches to filter out one-off typos/junk.
    $query->having('COUNT(*) >= 2');
    $query->orderBy('search_count', 'DESC');
    $query->range(0, $limit);

    $rows = $query->execute()->fetchAll();

    $popular = [];
    foreach ($rows as $row) {
      $raw = trim($row->query_label);
      if ($raw === '') {
        continue;
      }

      // query_text is stored as a JSON-serialised Search API condition array,
      // e.g. {"#conjunction":"AND","0":"Nelson","1":"Mandela"}.
      // Decode it and join the numeric-keyed values into a readable label.
      $decoded = json_decode($raw, TRUE);
      if (is_array($decoded)) {
        $words = array_filter(
          $decoded,
          static fn($k) => is_numeric($k),
          ARRAY_FILTER_USE_KEY
        );
        $label = implode(' ', $words);
      }
      else {
        // Fallback: treat as plain text (legacy rows).
        $label = $raw;
      }

      // Normalise to title-case so "mandela" and "Mandela" render identically.
      $label = mb_convert_case(trim($label), MB_CASE_TITLE, 'UTF-8');
      if ($label === '') {
        continue;
      }

      $popular[] = [
        'label' => $label,
        'url'   => '/search?search_api_fulltext=' . rawurlencode($label),
      ];
    }

    return $popular;
  }
  catch (\Exception $e) {
    \Drupal::logger('saho_statistics')->error(
      'Failed to retrieve popular searches: @msg',
      ['@msg' => $e->getMessage()]
    );
    return [];
  }
}

/**
 * Implements hook_cron().
 */
function saho_statistics_cron() {
  $config = \Drupal::config('saho_statistics.settings');

  // Only run cleanup if search tracking is enabled.
  if (!$config->get('track_searches')) {
    return;
  }

  // Get retention period in days (default 90).
  $retention_days = $config->get('search_query_retention') ?? 90;
  $cutoff = \Drupal::time()->getRequestTime() - ($retention_days * 86400);

  // Delete old search queries.
  $deleted = \Drupal::database()->delete('saho_search_queries')
    ->condition('timestamp', $cutoff, '<')
    ->execute();

  if ($deleted > 0) {
    \Drupal::logger('saho_statistics')->info('Deleted @count old search queries older than @days days.', [
      '@count' => $deleted,
      '@days' => $retention_days,
    ]);
  }
}
