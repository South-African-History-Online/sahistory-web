{#
/**
 * @file
 * History Through Pictures gallery page (Open Record register, #453).
 *
 * Picture-archive head (mono kicker, Caslon title, serif standfirst, mono
 * count), one quiet mono auto-submitting sort row, then the same duotone
 * picture-index figures as the front strip. Featured items carry a mono
 * FEATURED tag in the caption band instead of an on-image badge.
 *
 * Available variables:
 * - items, total_count, sort_links (label/url/active), current_sort, pager.
 */
#}
<div class="history-pictures-gallery saho-page">

  <header class="gallery-head">
    <p class="gallery-head__kicker">{{ 'Picture archive'|t }}</p>
    <h1 class="gallery-head__title">{{ 'History Through Pictures'|t }}</h1>
    <p class="gallery-head__standfirst">{{ 'Images from the archive that tell the story of South Africa\'s past. Featured pictures open their story; the rest open in place.'|t }}</p>
    <p class="gallery-head__count">{{ total_count|number_format(0, '.', ',') }} {{ 'images'|t }}</p>
  </header>

  <form class="gallery-sort" method="get" data-saho-autosubmit>
    <label class="gallery-sort__label" for="gallery-sort-select">{{ 'Sort'|t }}</label>
    <select class="gallery-sort__select" id="gallery-sort-select" name="sort">
      {% for link in sort_links %}
        <option value="{{ link.key }}" {{ link.active ? 'selected' }}>{{ link.label }}</option>
      {% endfor %}
    </select>
    <noscript><button type="submit" class="gallery-sort__apply">{{ 'Apply'|t }}</button></noscript>
  </form>

  <div class="history-pictures-grid history-pictures-grid--gallery">
    {% for item in items %}
      <div class="history-picture-item">
        <a
          {% if item.has_feature_link %}
            href="{{ item.url }}" class="history-picture-link"
          {% else %}
            href="{{ item.image_large|default(item.image) }}" class="history-picture-link history-picture-lightbox" data-gallery="history-gallery" data-title="{{ item.title }}"{% if item.caption %} data-description="{{ item.caption }}"{% endif %}
          {% endif %}
        >
          <span class="history-picture-frame">
            <img class="saho-duotone" src="{{ item.image }}" alt="{{ item.title }}" loading="lazy" decoding="async" />
          </span>
          <span class="history-picture-label">
            <span class="history-picture-label__title">{{ item.title }}</span>
            {% if item.has_feature_link %}
              <span class="history-picture-label__tag">{{ 'Featured'|t }}</span>
            {% endif %}
            {% if item.caption %}
              <span class="history-picture-label__source">{{ item.caption }}</span>
            {% endif %}
          </span>
        </a>
      </div>
    {% endfor %}
  </div>

  {% if pager %}
    <div class="gallery-pager">
      {{ pager }}
    </div>
  {% endif %}
</div>
