{#
/**
 * @file
 * History Through Pictures strip (Open Record register, #453).
 *
 * An archival picture index: duotone figures in a still grid with visible
 * mono caption bands (museum labels, not hover overlays). The whole figure
 * is one link - to the featured story when one exists, otherwise it opens
 * the large derivative in the lightbox. Carousel and masonry are retired.
 *
 * Available variables:
 * - items: nid, title, url, image (650 derivative), image_large (1300
 *   derivative), caption, has_feature_link.
 * - block_title, show_title (caption band toggle), show_caption
 *   (field_source line), total_count, attributes.
 */
#}
{% macro picture_figure(item, show_title, show_caption) %}
  <div class="history-picture-item">
    <a
      {% if item.has_feature_link %}
        href="{{ item.url }}" class="history-picture-link"
      {% else %}
        href="{{ item.image_large|default(item.image) }}" class="history-picture-link history-picture-lightbox" data-gallery="history-gallery" data-title="{{ item.title }}"{% if item.caption %} data-description="{{ item.caption }}"{% endif %}
      {% endif %}
    >
      <span class="history-picture-frame">
        <img class="saho-duotone" src="{{ item.image }}" alt="{{ item.title }}" loading="lazy" decoding="async" />
      </span>
      {% if show_title %}
        <span class="history-picture-label">
          <span class="history-picture-label__title">{{ item.title }}</span>
          {% if show_caption and item.caption %}
            <span class="history-picture-label__source">{{ item.caption }}</span>
          {% endif %}
        </span>
      {% endif %}
    </a>
  </div>
{% endmacro %}

{% import _self as pictures %}

<div{{ attributes.addClass(['saho-history-pictures']) }}>
  {% if block_title %}
    {{ include('saho:saho-section-heading', {
      title: block_title,
      level: 'h2',
      href: '/history-through-pictures',
      link_label: 'View more'|t,
    }, with_context = false) }}
  {% endif %}

  <div class="history-pictures-grid">
    {% for item in items %}
      {{ pictures.picture_figure(item, show_title, show_caption) }}
    {% endfor %}
  </div>
</div>
