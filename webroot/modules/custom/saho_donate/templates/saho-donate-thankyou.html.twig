{#
/**
 * @file
 * Thank-you page after successful PayFast donation.
 */
#}

<div class="saho-donate-thankyou container py-5 text-center">
  <div class="saho-donate-thankyou__icon mb-3" aria-hidden="true">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--saho-color-primary, #990000)" stroke-width="1.5">
      <circle cx="12" cy="12" r="10"/>
      <polyline points="9 12 11 14 15 10"/>
    </svg>
  </div>
  <h1 class="saho-donate-thankyou__title">{{ 'Thank You!'|t }}</h1>
  <p class="saho-donate-thankyou__message lead">
    {{ 'Your donation helps keep South African history free and accessible for everyone.'|t }}
  </p>
  <p class="text-muted">
    {{ 'A confirmation email will be sent to you by PayFast.'|t }}
  </p>
  <a href="/" class="btn btn-primary mt-3">{{ 'Return to SAHO'|t }}</a>
</div>
