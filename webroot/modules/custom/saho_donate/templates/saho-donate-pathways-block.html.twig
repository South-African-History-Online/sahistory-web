{#
/**
 * @file
 * Block template: 3 donation pathways (Marion Institute, Champion, Snapscan).
 *
 * Available variables:
 * - champion_url: URL to the SAHO Champion page on the shop.
 * - snapscan_url: Snapscan deep-link/QR URL.
 * - snapscan_qr_image: Path to the Snapscan QR code image.
 */
#}
<div class="donate-pathways-block">
  <div class="row g-4">

    {# --- Card 1: Once-off via Marion Institute --- #}
    <div class="col-md-4">
      <div class="donate-pathway-card donate-pathway-card--primary">
        <div class="donate-pathway-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
          </svg>
        </div>
        <h3 class="donate-pathway-card__title">{{ 'Once-off Donation'|t }}</h3>
        <p class="donate-pathway-card__text">{{ 'Make a direct contribution via our Marion Institute fiscal sponsorship. Tax certificates available for qualifying gifts.'|t }}</p>
        <div class="donate-pathway-card__cta">
          <a href="https://www.marioninstitute.org/south-african-history-online-donation-page/"
             class="donate-btn donate-btn--primary donate-btn--full"
             target="_blank" rel="noopener noreferrer">
            {{ 'Donate via Marion Institute'|t }}
          </a>
        </div>
      </div>
    </div>

    {# --- Card 2: SAHO Champion (recurring) --- #}
    <div class="col-md-4">
      <div class="donate-pathway-card donate-pathway-card--champion">
        <div class="donate-pathway-card__badge">{{ 'Most popular'|t }}</div>
        <div class="donate-pathway-card__icon donate-pathway-card__icon--gold" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h3 class="donate-pathway-card__title">{{ 'SAHO Champion'|t }}</h3>
        <p class="donate-pathway-card__text">{{ 'Subscribe monthly or annually and receive exclusive benefits including book gifts and recognition on the Wall of Champions.'|t }}</p>
        <div class="donate-pathway-card__cta">
          <a href="{{ champion_url }}"
             class="donate-btn donate-btn--gold donate-btn--full">
            {{ 'Become a Champion'|t }}
          </a>
        </div>
      </div>
    </div>

    {# --- Card 3: Snapscan QR --- #}
    <div class="col-md-4">
      <div class="donate-pathway-card donate-pathway-card--snapscan">
        <div class="donate-pathway-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3 11h8V3H3v8zm2-6h4v4H5V5zM3 21h8v-8H3v8zm2-6h4v4H5v-4zM13 3v8h8V3h-8zm6 6h-4V5h4v4zM13 13h2v2h-2v-2zm2 2h2v2h-2v-2zm2-2h2v2h-2v-2zm-2 4h2v2h-2v-2zm2 2h2v2h-2v-2zm-4-4h2v2h-2v-2zm0 4h2v2h-2v-2z"/>
          </svg>
        </div>
        <h3 class="donate-pathway-card__title">{{ 'Donate via Snapscan'|t }}</h3>
        <p class="donate-pathway-card__text">{{ 'Scan the QR code with the Snapscan app on your phone to donate instantly.'|t }}</p>

        {# QR code with copy overlay #}
        <div class="donate-snapscan-qr">
          <a href="{{ snapscan_url }}"
             class="donate-snapscan-qr__link"
             target="_blank" rel="noopener noreferrer"
             aria-label="{{ 'Open Snapscan donation page'|t }}">
            <img
              src="{{ snapscan_qr_image }}"
              alt="{{ 'Snapscan QR code - scan to donate to SAHO'|t }}"
              class="donate-snapscan-qr__image"
              width="160"
              height="160"
            />
            <div class="donate-snapscan-qr__overlay" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
              <span>{{ 'Open Snapscan'|t }}</span>
            </div>
          </a>
        </div>

        <div class="donate-pathway-card__cta">
          <a href="{{ snapscan_url }}"
             class="donate-btn donate-btn--outline-snapscan donate-btn--full"
             target="_blank" rel="noopener noreferrer">
            {{ 'Open Snapscan'|t }}
          </a>
        </div>
      </div>
    </div>

  </div>
</div>
