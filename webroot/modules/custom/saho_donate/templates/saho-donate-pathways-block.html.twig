{#
/**
 * @file
 * Block template: 3 donation pathways (for Layout Builder).
 */
#}
<div class="donate-pathways-block">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="donate-pathway-card donate-pathway-card--primary">
        <div class="donate-pathway-card__icon" aria-hidden="true">♥</div>
        <h3 class="donate-pathway-card__title">{{ 'Once-off Donation'|t }}</h3>
        <p class="donate-pathway-card__text">{{ 'Make a direct contribution via our Marion Institute fiscal sponsorship.'|t }}</p>
        <a href="https://www.marioninstitute.org/south-african-history-online-donation-page/"
           class="donate-btn donate-btn--primary donate-btn--full"
           target="_blank" rel="noopener noreferrer">
          {{ 'Donate via Marion Institute'|t }}
        </a>
      </div>
    </div>
    <div class="col-md-4">
      <div class="donate-pathway-card donate-pathway-card--champion">
        <div class="donate-pathway-card__badge">{{ 'Most popular'|t }}</div>
        <div class="donate-pathway-card__icon" aria-hidden="true">★</div>
        <h3 class="donate-pathway-card__title">{{ 'SAHO Champion'|t }}</h3>
        <p class="donate-pathway-card__text">{{ 'Subscribe monthly or annually and receive exclusive benefits including book gifts.'|t }}</p>
        <a href="https://shop.sahistory.org.za/champion"
           class="donate-btn donate-btn--gold donate-btn--full">
          {{ 'Become a Champion'|t }}
        </a>
      </div>
    </div>
    <div class="col-md-4">
      <div class="donate-pathway-card">
        <div class="donate-pathway-card__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5z"/><path d="M8 14a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/></svg>
        </div>
        <h3 class="donate-pathway-card__title">{{ 'Snapscan / EFT'|t }}</h3>
        <p class="donate-pathway-card__text">{{ 'Pay by Snapscan QR or direct bank transfer.'|t }}</p>
        <div class="donate-eft-details">
          <p><strong>{{ 'Bank:'|t }}</strong> FNB</p>
          <p><strong>{{ 'Ref:'|t }}</strong> DONATE</p>
          <p><a href="mailto:mediateam@sahistory.org.za">{{ 'Request details →'|t }}</a></p>
        </div>
      </div>
    </div>
  </div>
</div>
