{#
/**
 * @file
 * Auto-submitting hidden form that POSTs to PayFast.
 *
 * Variables:
 * - payfast_url: The PayFast process URL.
 * - fields: Associative array of POST fields.
 */
#}

<div class="saho-donate-redirect container py-5 text-center">
  <p class="text-muted">{{ 'Redirecting you to PayFast to complete your donation…'|t }}</p>
  <div class="spinner-border text-primary mt-3" role="status">
    <span class="visually-hidden">{{ 'Loading...'|t }}</span>
  </div>

  <form id="saho-payfast-form" method="POST" action="{{ payfast_url }}" aria-hidden="true">
    {% for name, value in fields %}
      <input type="hidden" name="{{ name }}" value="{{ value }}">
    {% endfor %}
  </form>
</div>
