{#
/**
 * @file
 * Block template: Champion tier comparison (for Layout Builder).
 */
#}
<div class="donate-tiers-block">
  <div class="row g-4 justify-content-center">

    <div class="col-md-4">
      <div class="donate-tier">
        <div class="donate-tier__stars">★</div>
        <div class="donate-tier__header">
          <h3 class="donate-tier__name">{{ 'Monthly Champion'|t }}</h3>
          <div class="donate-tier__price">
            <span class="donate-tier__currency">ZAR</span>
            <span class="donate-tier__amount">200</span>
            <span class="donate-tier__period">/{{ 'month'|t }}</span>
          </div>
        </div>
        <ul class="donate-benefits-list">
          <li>{{ 'Wall of Champions listing'|t }}</li>
          <li>{{ '10% book discount'|t }}</li>
          <li>{{ 'Champion newsletter'|t }}</li>
          <li>{{ 'Exclusive content access'|t }}</li>
        </ul>
        <a href="https://shop.sahistory.org.za/product/saho-champion-monthly-support-0"
           class="donate-btn donate-btn--outline-violet donate-btn--full">
          {{ 'Join Monthly'|t }}
        </a>
      </div>
    </div>

    <div class="col-md-4">
      <div class="donate-tier donate-tier--featured">
        <div class="donate-tier__badge">{{ 'Best Value'|t }}</div>
        <div class="donate-tier__stars donate-tier__stars--gold">★★</div>
        <div class="donate-tier__header">
          <h3 class="donate-tier__name">{{ 'Annual Champion'|t }}</h3>
          <div class="donate-tier__price">
            <span class="donate-tier__currency">ZAR</span>
            <span class="donate-tier__amount">2,000</span>
            <span class="donate-tier__period">/{{ 'year'|t }}</span>
          </div>
        </div>
        <ul class="donate-benefits-list">
          <li><strong>{{ 'Everything Monthly, plus:'|t }}</strong></li>
          <li>{{ '20% book discount'|t }}</li>
          <li>{{ '1 publication gift per quarter'|t }}</li>
          <li>{{ 'Annual certificate'|t }}</li>
        </ul>
        <a href="https://shop.sahistory.org.za/product/saho-champion-annual-support-0"
           class="donate-btn donate-btn--gold donate-btn--full">
          {{ 'Join Annual'|t }}
        </a>
      </div>
    </div>

    <div class="col-md-4">
      <div class="donate-tier donate-tier--patron">
        <div class="donate-tier__stars donate-tier__stars--patron">★★★</div>
        <div class="donate-tier__header">
          <h3 class="donate-tier__name">{{ 'Patron Champion'|t }}</h3>
          <div class="donate-tier__price">
            <span class="donate-tier__currency">ZAR</span>
            <span class="donate-tier__amount">5,000</span>
            <span class="donate-tier__period">/{{ 'year'|t }}</span>
          </div>
        </div>
        <ul class="donate-benefits-list">
          <li><strong>{{ 'Everything Annual, plus:'|t }}</strong></li>
          <li>{{ 'Heritage photo book annually'|t }}</li>
          <li>{{ 'Framed certificate'|t }}</li>
          <li>{{ 'Permanent Wall listing'|t }}</li>
        </ul>
        <a href="https://shop.sahistory.org.za/champion#patron"
           class="donate-btn donate-btn--patron donate-btn--full">
          {{ 'Join as Patron'|t }}
        </a>
      </div>
    </div>

  </div>
</div>
