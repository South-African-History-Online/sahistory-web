{#
/**
 * @file
 * SAHO donation page template.
 *
 * Variables:
 * - form: The rendered DonateForm (PayFast one-off donation).
 * - pathways_block: Rendered alternative donation pathways block.
 */
#}

<div class="saho-donate-page container pt-5 pb-4">

  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <div class="saho-donate-intro mb-4">
        <h1 class="saho-donate-intro__title">{{ 'Support Free History Education'|t }}</h1>
        <p class="saho-donate-intro__lead">
          {{ 'SAHO is a free, non-commercial resource. Your donation keeps South African history accessible to everyone.'|t }}
        </p>
      </div>

      <div class="saho-donate-card card shadow-sm">
        <div class="card-body p-4">
          {{ form }}
        </div>
      </div>

      <p class="saho-donate-security mt-3 text-center text-muted small">
        <span class="me-1" aria-hidden="true">🔒</span>
        {{ 'Secure payment via PayFast. SAHO never stores your card details.'|t }}
      </p>

    </div>
  </div>

  {% if pathways_block %}
  <div class="saho-donate-alternatives mt-5 pt-4 border-top">
    <h2 class="saho-donate-alternatives__title text-center mb-4">
      {{ 'Other ways to support SAHO'|t }}
    </h2>
    {{ pathways_block }}
  </div>
  {% endif %}

</div>
