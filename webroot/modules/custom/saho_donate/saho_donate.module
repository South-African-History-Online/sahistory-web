/**
 * @file
 * SAHO Donate module hooks.
 */

/**
 * Implements hook_theme().
 */
function saho_donate_theme(): array {
  return [
    'saho_donate_page' => [
      'variables' => [
        'form' => NULL,
        'pathways_block' => [],
      ],
    ],
    'saho_donate_redirect' => [
      'variables' => [
        'payfast_url' => '',
        'fields' => [],
      ],
    ],
    'saho_donate_thankyou' => [
      'variables' => [],
    ],
    'saho_donate_cancelled' => [
      'variables' => [],
    ],
    'saho_donate_pathways_block' => [
      'variables' => [
        'champion_url' => 'https://shop.sahistory.org.za/champion',
        'snapscan_url' => 'https://pos.snapscan.io/qr/SAHO',
        'snapscan_qr_image' => '/sites/default/files/saho_snapscan.gif',
      ],
    ],
    'saho_champion_tiers_block' => [
      'variables' => [
        'monthly_url' => 'https://shop.sahistory.org.za/product/saho-champion-monthly-support',
        'annual_url' => 'https://shop.sahistory.org.za/product/saho-champion-annual-support',
        'patron_url' => 'https://shop.sahistory.org.za/champion#patron',
      ],
    ],
