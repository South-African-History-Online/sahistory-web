<?php

/**
 * @file
 * Install hooks for SAHO Shop Shipping.
 *
 * Shipping methods are ContentEntities (not config-exportable), so the
 * five we ship to production are created here via the entity API
 * rather than as YAML in config/shop/. Each method has an explicit
 * UUID so the free-shipping promotion can reference them
 * deterministically across sites.
 */

use Drupal\commerce_promotion\Entity\Promotion;
use Drupal\commerce_shipping\Entity\Shipment;

