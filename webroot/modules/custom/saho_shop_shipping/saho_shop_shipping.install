/**
 * Resolves the commerce_store IDs the shipping methods should attach to.
 *
 * In SAHO's multisite layout there's exactly one store ("SAHO Shop")
 * but lookups go by integer entity ID, not by a machine name. We
 * prefer to match by name to stay environment-agnostic and fall back
 * to "all stores" if the named one isn't found.
 *
 * @return int[]
 *   Store entity IDs.
 */
function _saho_shop_shipping_resolve_store_ids(): array {
  $store_storage = \Drupal::entityTypeManager()->getStorage('commerce_store');
  $by_name = $store_storage->loadByProperties(['name' => 'SAHO Shop']);
  if (!empty($by_name)) {
    return array_map(static fn($s) => (int) $s->id(), array_values($by_name));
  }
  return array_map(static fn($s) => (int) $s->id(), array_values($store_storage->loadMultiple()));
}

/**
 * Implements hook_install().
 *
 * Provisions five Phase 0 shipping methods, a free-shipping-over-R750
 * promotion that covers only the two cheapest options, and backfills
 * weight = 0.5 kg on every existing publication variation. Every
 * routine is idempotent - re-running this hook leaves existing
 * entities alone.
 */
function saho_shop_shipping_install(): void {
  _saho_shop_shipping_install_shipments_field();
  _saho_shop_shipping_install_shipping_methods();
  _saho_shop_shipping_install_free_shipping_promotion();
  _saho_shop_shipping_backfill_publication_weights();
}

/**
 * Provisions the `shipments` field on the default commerce_order bundle.
 *
 * The SAHO shop manages `shipments` through config sync - both
 * field.storage.commerce_order.shipments.yml AND
 * field.field.commerce_order.default.shipments.yml exist in
 * config/shop/. After cim runs, the FieldStorageConfig + FieldConfig
 * pair is in place and this routine is a no-op.
 *
 * The safety net below handles the edge case where the field doesn't
 * exist yet at hook_install time - e.g. someone manually disabled and
 * re-enabled the module after deleting one of the config rows. In
 * that case we fall back to commerce_shipping's BaseFieldDefinition
 * via installFieldStorageDefinition().
 */
function _saho_shop_shipping_install_shipments_field(): void {
  $update_manager = \Drupal::entityDefinitionUpdateManager();
  if ($update_manager->getFieldStorageDefinition('shipments', 'commerce_order')) {
    return;
  }
  $definition = Shipment::buildShipmentsFieldDefinition('default');
  $update_manager->installFieldStorageDefinition('shipments', 'commerce_order', 'commerce_shipping', $definition);
}

/**
 * Creates the five shipping methods if they don't already exist.
 */
function _saho_shop_shipping_install_shipping_methods(): void {
  $storage = \Drupal::entityTypeManager()->getStorage('commerce_shipping_method');
  $store_ids = _saho_shop_shipping_resolve_store_ids();
  if (empty($store_ids)) {
    \Drupal::logger('saho_shop_shipping')->warning('No commerce_store entities found - skipped installing shipping methods.');
    return;
  }

  foreach (_saho_shop_shipping_method_specs() as $uuid => $spec) {
    $existing = $storage->loadByProperties(['uuid' => $uuid]);
    if (!empty($existing)) {
      continue;
    }
    $method = $storage->create([
      'uuid' => $uuid,
      'stores' => $store_ids,
      'name' => $spec['name'],
      'status' => TRUE,
      'weight' => $spec['weight'],
      'plugin' => [
        'target_plugin_id' => 'flat_rate',
        'target_plugin_configuration' => [
          'display_label' => $spec['name'],
          'rate_label' => $spec['rate_label'],
          'rate_description' => $spec['description'],
          'rate_amount' => [
            'number' => $spec['rate'],
            'currency_code' => 'ZAR',
          ],
          'services' => [
            'default' => [
              'label' => $spec['service_label'],
              'amount' => [
                'number' => $spec['rate'],
                'currency_code' => 'ZAR',
              ],
              'description' => $spec['service_description'],
            ],
          ],
          'workflow' => 'shipment_default',
        ],
      ],
      'conditions' => $spec['conditions'],
      'condition_operator' => 'AND',
    ]);
    $method->save();
  }
}

/**
 * Creates the free-shipping-over-R750 promotion if it doesn't exist.
 *
 * The promotion is restricted to the two cheapest options (local
 * pickup and Paxi) so a R750 order doesn't get free door-to-door
 * courier delivery at SAHO's expense - the goal is to nudge multi-
 * book carts, not subsidise premium delivery.
 */
function _saho_shop_shipping_install_free_shipping_promotion(): void {
  $storage = \Drupal::entityTypeManager()->getStorage('commerce_promotion');
  $existing = $storage->loadByProperties(['name' => 'Free shipping over R750']);
  if (!empty($existing)) {
    return;
  }

  $eligible_uuids = [
    '13a5c927-e273-4115-ad0e-11e7669bdf0b',
    '2b11648f-cb74-40f3-8d04-121aa9929171',
  ];
  $method_storage = \Drupal::entityTypeManager()->getStorage('commerce_shipping_method');
  $eligible_loaded = $method_storage->loadByProperties(['uuid' => $eligible_uuids]);
  if (empty($eligible_loaded)) {
    \Drupal::logger('saho_shop_shipping')->warning('Skipped installing free shipping promotion - eligible shipping methods are missing. Re-run drush updb after the shipping methods are in place.');
    return;
  }

  $promotion = Promotion::create([
    'name' => 'Free shipping over R750',
    'display_name' => 'Free shipping when you spend R750 or more',
    'description' => 'Spend R750 or more and the cheapest shipping options (free Cape Town pickup, Paxi to PEP) are on us. SAHO is a non-profit and we keep door-to-door courier rates as they are so larger orders subsidise smaller ones rather than premium delivery.',
    'order_types' => ['default'],
    'stores' => _saho_shop_shipping_resolve_store_ids(),
    'offer' => [
      'target_plugin_id' => 'shipment_percentage_off',
      'target_plugin_configuration' => [
        'display_inclusive' => TRUE,
        'percentage' => '1',
        'filter' => 'include',
        'shipping_methods' => $eligible_uuids,
      ],
    ],
    'conditions' => [
      [
        'target_plugin_id' => 'order_total_price',
        'target_plugin_configuration' => [
          'operator' => '>=',
          'amount' => ['number' => '750.00', 'currency_code' => 'ZAR'],
        ],
      ],
    ],
    'condition_operator' => 'AND',
    'compatibility' => 'any',
    'status' => TRUE,
  ]);
  $promotion->save();
}

/**
 * Backfills weight = 0.5 kg on existing publication variations.
 *
 * The default value on the field config only applies to entities
 * saved AFTER the field was added. We touch existing variations so
 * the weight conditions on shipping methods (<= 5 kg / <= 10 kg)
 * don't filter them out entirely.
 */
function _saho_shop_shipping_backfill_publication_weights(): void {
  $storage = \Drupal::entityTypeManager()->getStorage('commerce_product_variation');
  $ids = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('type', 'publication')
    ->execute();
  foreach ($storage->loadMultiple($ids) as $variation) {
    /** @var \Drupal\commerce_product\Entity\ProductVariationInterface $variation */
    if ($variation->hasField('weight') && $variation->get('weight')->isEmpty()) {
      $variation->set('weight', ['number' => '0.500', 'unit' => 'kg']);
      $variation->save();
    }
  }
}
