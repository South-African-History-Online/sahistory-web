{#
/**
 * @file
 * Featured biography block template.
 *
 * Open Record 2027 idiom: archive index cards on paper with the biography
 * accent edge, duotone portraits, mono dates line and a display-font title.
 * When a portrait is missing we show a plain sunk surface with a mono
 * initial - never a gradient placeholder.
 *
 * JS hooks preserved (featured-biography.js): .featured-biography-block,
 * .enable-carousel, .saho-cards-grid, .saho-card, .saho-card--demo,
 * .featured-biography-carousel-controls, .featured-bio-prev-btn,
 * .featured-bio-next-btn, .featured-bio-indicators, .featured-bio-indicator.
 */
#}
<div class="featured-biography-block saho-fbio{% if enable_carousel %} enable-carousel{% endif %}">
  {% if display_title %}
    <div class="saho-fbio__heading">
      <h2 class="saho-fbio__title">{{ display_title }}</h2>
    </div>
  {% endif %}

  {% if block_description is not empty %}
    <p class="saho-fbio__description">{{ block_description }}</p>
  {% endif %}

  {% if biography_data is defined and biography_data is not empty and biography_data.items is defined and biography_data.items is not empty %}
    {# Multiple biographies display #}
    <div class="saho-cards-grid">
      {% for item in biography_data.items %}
        <div class="saho-card saho-fbio__card{% if item.is_demo %} saho-card--demo{% endif %}">
          <a href="{{ item.url }}" class="saho-fbio__link">
            {% if item.image %}
              <div class="saho-fbio__media saho-duotone">
                <img src="{{ item.image }}" alt="{{ item.title|striptags }}" loading="lazy" decoding="async" />
              </div>
            {% else %}
              <div class="saho-fbio__media saho-fbio__media--empty" aria-hidden="true">
                <span class="saho-fbio__initial">{{ item.title|striptags|trim|slice(0, 1)|upper }}</span>
              </div>
            {% endif %}
            <div class="saho-fbio__body">
              {% if item.categories is defined and item.categories is not empty %}
                {% for category in item.categories|slice(0, 1) %}
                  <p class="saho-fbio__eyebrow">{{ category.name }}</p>
                {% endfor %}
              {% else %}
                <p class="saho-fbio__eyebrow">{{ 'Biography'|t }}</p>
              {% endif %}
              <h3 class="saho-fbio__card-title">{{ item.title }}</h3>
              {% if item.dates %}
                <p class="saho-fbio__dates">{{ item.dates }}</p>
              {% endif %}
              {% if item.body %}
                <p class="saho-fbio__excerpt">{{ item.body|striptags|truncate(150, true, '...') }}</p>
              {% endif %}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>

    {% if enable_carousel and biography_data.items|length > 1 %}
      <div class="featured-biography-carousel-controls">
        <button class="featured-bio-prev-btn carousel-button" type="button"
          aria-label="{{ 'Previous biography'|t }}">
          <span aria-hidden="true">&larr;</span>
        </button>
        <div class="featured-bio-indicators">
          {% for i in 0..((biography_data.items|length / 3)|round(0, 'ceil') - 1) %}
            <button
              class="featured-bio-indicator{% if loop.first %} active{% endif %}"
              type="button"
              data-slide-to="{{ i }}"
              aria-label="{{ 'Biography'|t }} {{ i + 1 }}"
            ></button>
          {% endfor %}
        </div>
        <button class="featured-bio-next-btn carousel-button" type="button"
          aria-label="{{ 'Next biography'|t }}">
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    {% endif %}

  {% elseif biography_item is defined and biography_item is not empty %}
    {# Single biography display #}
    <div class="featured-biography-content">
      <div class="featured-biography-item">
        <div class="featured-biography-image">
          <a href="{{ biography_item.url }}">
            {% if biography_item.image %}
              <span class="saho-duotone">
                <img src="{{ biography_item.image }}" alt="{{ biography_item.title|striptags }}" loading="lazy" decoding="async" />
              </span>
            {% else %}
              <span class="saho-fbio__media saho-fbio__media--empty saho-fbio__media--single" aria-hidden="true">
                <span class="saho-fbio__initial">{{ biography_item.title|striptags|trim|slice(0, 1)|upper }}</span>
              </span>
            {% endif %}
          </a>
        </div>
        <div class="featured-biography-details">
          {% if biography_item.category %}
            <div class="featured-biography-categories">
              <a href="{{ biography_item.category_url }}" class="featured-biography-category">{{ biography_item.category }}</a>
            </div>
          {% endif %}
          <h3 class="featured-biography-title">
            <a href="{{ biography_item.url }}">{{ biography_item.title }}</a>
          </h3>
          {% if biography_item.dates %}
            <div class="featured-biography-dates">{{ biography_item.dates }}</div>
          {% endif %}
          {% if biography_item.position %}
            <div class="featured-biography-position">{{ biography_item.position }}</div>
          {% endif %}
          {% if biography_item.body_summary %}
            <div class="featured-biography-summary">
              {{ biography_item.body_summary|striptags|truncate(300, true, '...') }}
            </div>
          {% elseif biography_item.body %}
            <div class="featured-biography-summary">
              {{ biography_item.body|striptags|truncate(300, true, '...') }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% else %}
    {# Empty state #}
    <div class="featured-biography-empty">
      <p>{{ 'No featured biography available at this time.'|t }}</p>
    </div>
  {% endif %}

  {% if show_admin_info %}
    <div class="featured-biography-admin-info">
      <h4>{{ 'Admin Information'|t }}</h4>
      <dl>
        <dt>{{ 'Selection Method'|t }}</dt>
        <dd>{{ selection_method }}</dd>
        {% if entity_count %}
          <dt>{{ 'Entity Count'|t }}</dt>
          <dd>{{ entity_count }}</dd>
        {% endif %}
        {% if highlight_category %}
          <dt>{{ 'Highlight Category'|t }}</dt>
          <dd>{{ highlight_category }}</dd>
        {% endif %}
        <dt>{{ 'Display Mode'|t }}</dt>
        <dd>{{ display_mode }}</dd>
        <dt>{{ 'Carousel Enabled'|t }}</dt>
        <dd>{{ enable_carousel ? 'Yes'|t : 'No'|t }}</dd>
      </dl>
    </div>
  {% endif %}
</div>
