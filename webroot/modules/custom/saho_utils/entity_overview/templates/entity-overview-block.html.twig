{#
/**
 * @file
 * Default theme implementation for an entity overview block.
 *
 * Canonical single source for this block's markup, using the unified SAHO
 * card system. Do not re-add a theme override - a diverged copy shadowed
 * this template for months.
 *
 * Available variables:
 * - items: An array of entity items, each with:
 *   - id: The entity ID.
 *   - title: The entity title.
 *   - url: The entity URL.
 *   - image: The entity image URL.
 *   - teaser: The entity teaser text.
 *   - created: The entity creation timestamp.
 *   - changed: The entity changed timestamp.
 * - block_title: The title of the block.
 * - intro_text: Introductory text for the block.
 * - block_id: A unique ID for the block wrapper.
 * - display_mode: default | compact | full-width.
 * - show_display_toggle: Whether readers may switch display modes.
 * - attributes: HTML attributes for the containing element.
 *
 * @ingroup themeable
 */
#}
<div{{ attributes.addClass('entity-overview-block', 'entity-overview--' ~ display_mode|default('default')) }} data-block-id="{{ block_id }}" data-display-mode="{{ display_mode|default('default') }}">
  {% if block_title %}
    {{ include('saho:saho-section-heading', {
      title: block_title,
      level: 'h2',
    }, with_context = false) }}
  {% endif %}

  {% if intro_text %}
    <div class="block-intro mb-4">
      {{ intro_text|replace({'%title': block_title}) }}
    </div>
  {% endif %}

  {% if show_display_toggle %}
    <div class="entity-overview-toggle" role="group" aria-label="{{ 'Display mode'|t }}">
      {% for mode, label in { 'default': 'Grid'|t, 'compact': 'Compact'|t, 'full-width': 'List'|t } %}
        <button type="button" class="entity-overview-toggle__btn" data-mode="{{ mode }}"
          aria-pressed="{{ display_mode|default('default') == mode ? 'true' : 'false' }}">{{ label }}</button>
      {% endfor %}
    </div>
  {% endif %}

  {# Content using SAHO Card System #}
  {% if items %}
    <div class="entity-overview-items saho-card-grid">
      {% for item in items %}
        <div class="saho-card entity-overview-item" data-item-id="{{ item.id }}">
          {% if item.image %}
            <div class="saho-card-image">
              <a href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                <img src="{{ item.image }}" alt="" loading="lazy" decoding="async" onerror="this.closest('.saho-card-image').classList.add('is-broken')">
              </a>
            </div>
          {% endif %}

          <div class="saho-card-content">
            <h3 class="saho-card-title">
              <a href="{{ item.url }}">{{ item.title }}</a>
            </h3>

            {% if item.teaser %}
              <div class="saho-card-teaser">
                <p>{{ item.teaser }}</p>
              </div>
            {% endif %}

            <div class="saho-card-meta">
              <time datetime="{{ item.changed|date('c') }}">
                {{ 'Updated'|t }}: {{ item.changed|date('j M Y') }}
              </time>
              {# Only a Created date on a DIFFERENT day says anything; two
                 timestamps minutes apart rendered as twin dates. #}
              {% if item.created|date('Y-m-d') != item.changed|date('Y-m-d') %}
                <span class="separator">&middot;</span>
                <time datetime="{{ item.created|date('c') }}">
                  {{ 'Created'|t }}: {{ item.created|date('j M Y') }}
                </time>
              {% endif %}
            </div>

            <div class="saho-card-actions">
              {% include 'saho:saho-button' with {
                text: 'Read more'|t,
                url: item.url,
                variant: 'text',
                size: 'small',
                icon: 'arrow-right',
                icon_position: 'after'
              } %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  {% else %}
    <div class="alert alert-info text-center">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="16" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
      {{ 'No items found.'|t }}
    </div>
  {% endif %}
</div>
