{#
/**
 * @file
 * Default theme implementation for an entity overview block.
 *
 * Canonical single source for this block's markup, using the unified SAHO
 * card system. The saho theme previously carried a diverged block override
 * (webroot/themes/custom/saho/templates/block/entity-overview-block.html.twig);
 * that copy should be removed by the theme pass so this template renders.
 *
 * Available variables:
 * - items: An array of entity items, each with:
 *   - id: The entity ID.
 *   - title: The entity title.
 *   - url: The entity URL.
 *   - image: The entity image URL.
 *   - teaser: The entity teaser text.
 *   - created: The entity creation date.
 *   - changed: The entity changed date.
 * - block_title: The title of the block.
 * - intro_text: Introductory text for the block.
 * - block_id: A unique ID for the block wrapper.
 * - attributes: HTML attributes for the containing element.
 *
 * @ingroup themeable
 */
#}
<div{{ attributes.addClass('entity-overview-block') }} data-block-id="{{ block_id }}">
  {% if block_title %}
    {{ include('saho:saho-section-heading', {
      title: block_title,
      level: 'h2',
    }, with_context = false) }}
  {% endif %}

  {% if intro_text %}
    <div class="block-intro mb-4">
      {{ intro_text|replace({'%title': block_title}) }}
    </div>
  {% endif %}

  {# Content using SAHO Card System #}
  {% if items %}
    <div class="entity-overview-items saho-card-grid">
      {% for item in items %}
        <div class="saho-card entity-overview-item" data-item-id="{{ item.id }}">
          {% if item.image %}
            <div class="saho-card-image">
              <a href="{{ item.url }}">
                <img src="{{ item.image }}" alt="{{ item.title|striptags }}" loading="lazy" decoding="async" onerror="this.closest('.saho-card-image').classList.add('is-broken')">
              </a>
            </div>
          {% endif %}

          <div class="saho-card-content">
            <h3 class="saho-card-title">
              <a href="{{ item.url }}">{{ item.title }}</a>
            </h3>

            {% if item.teaser %}
              <div class="saho-card-teaser">
                <p>{{ item.teaser }}</p>
              </div>
            {% endif %}

            <div class="saho-card-meta">
              <time datetime="{{ item.changed|date('c') }}">
                {{ 'Updated'|t }}: {{ item.changed|date('j M Y') }}
              </time>
              {% if item.created != item.changed %}
                <span class="separator">•</span>
                <time datetime="{{ item.created|date('c') }}">
                  {{ 'Created'|t }}: {{ item.created|date('j M Y') }}
                </time>
              {% endif %}
            </div>

            <div class="saho-card-actions">
              {% include 'saho:saho-button' with {
                text: 'Read more'|t,
                url: item.url,
                variant: 'text',
                size: 'small',
                icon: 'arrow-right',
                icon_position: 'after'
              } %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  {% else %}
    <div class="alert alert-info text-center">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="16" x2="12" y2="12"/>
        <line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
      {{ 'No items found.'|t }}
    </div>
  {% endif %}
</div>
