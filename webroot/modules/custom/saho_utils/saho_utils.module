<?php

/**
 * @file
 * Contains saho_utils.module.
 */

use Drupal\Component\Utility\Html;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_form_alter().
 */
function saho_utils_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Alter the exposed form for the SAHO global search view.
  if ($form_id == 'views_exposed_form' && isset($form['#id']) && $form['#id'] == 'views-exposed-form-saho-global-search-page-1') {
    // Customize the fulltext search field options to rename body/title labels.
    if (isset($form['search_api_fulltext_searched_fields']) && isset($form['search_api_fulltext_searched_fields']['#options'])) {
      $options = &$form['search_api_fulltext_searched_fields']['#options'];

      // Replace the field labels with custom names.
      if (isset($options['body'])) {
        $options['body'] = t('Flexible Search');
      }
      if (isset($options['title'])) {
        $options['title'] = t('Strict Search');
      }
    }
  }

  // Archive browse (/archives) refine rail.
  if ($form_id == 'views_exposed_form' && isset($form['#id']) && $form['#id'] == 'views-exposed-form-archive-pages-page-1') {
    _saho_utils_archive_refine_alter($form);
  }

  // Extend the year range for event date field to support historical dates.
  // SAHO covers African history from earliest times to present.
  if ($form_id === 'node_event_form' || $form_id === 'node_event_edit_form') {
    if (isset($form['field_event_date']['widget'][0]['value'])) {
      // Allow dates from year 1000 to 2100 for historical events.
      // Note: Year must be 4 digits for Drupal's date range parser.
      $form['field_event_date']['widget'][0]['value']['#date_year_range'] = '1000:2100';
    }
  }
}

/**
 * Shapes the /archives refine rail: collection select + facet-group order.
 *
 * The view's "collection" filter is a numeric filter on
 * field_feature_parent_target_id (collection pages link in with
 * ?collection=NID); a raw nid textfield is useless to a person, so it
 * becomes a select of every collection head with its record count.
 * Group order is set by weight so the strongest facets lead the rail:
 * coverage across the 30k records is collection 91%, resource type 45%,
 * language 12%, SALDRU topic 5%, African country under 1%.
 */
function _saho_utils_archive_refine_alter(array &$form): void {
  if (isset($form['collection'])) {
    $form['collection'] = [
      '#type' => 'select',
      '#options' => ['' => t('- All collections -')] + _saho_utils_archive_collection_options(),
      '#default_value' => $form['collection']['#default_value'] ?? '',
    ] + array_intersect_key($form['collection'], array_flip(['#name', '#id']));
  }
  // Keys are the filters' exposed identifiers, not their plugin ids.
  $weights = [
    'tid' => -10,
    'collection' => -9,
    'language' => -8,
    'saldru' => -7,
    'field_african_country_target_id' => -6,
  ];
  foreach ($weights as $key => $weight) {
    if (isset($form[$key])) {
      $form[$key]['#weight'] = $weight;
    }
  }

  // Facets are apparatus: each value carries its record count, values with
  // records lead (count descending), values with none disappear - a person
  // should never click into an empty result set.
  foreach (_saho_utils_archive_facet_counts() as $key => $counts) {
    if (!isset($form[$key]['#options'])) {
      continue;
    }
    $selected = array_filter((array) ($form[$key]['#default_value'] ?? []));
    $kept = [];
    foreach ($form[$key]['#options'] as $value => $label) {
      $records = $counts[$value] ?? 0;
      // A selected zero value must stay visible so it can be unchecked.
      if ($records === 0 && !in_array((string) $value, array_map('strval', $selected), TRUE)) {
        continue;
      }
      $kept[$value] = ['label' => (string) $label, 'records' => $records];
    }
    uasort($kept, fn(array $a, array $b) => [$b['records'], $a['label']] <=> [$a['records'], $b['label']]);
    $form[$key]['#options'] = array_map(
      fn(array $option) => Markup::create(
        Html::escape($option['label'])
        . ' <span class="saho-facet-count">' . number_format($option['records']) . '</span>'
      ),
      $kept
    );
  }
}

/**
 * Returns per-value record counts for the /archives checkbox facets.
 *
 * One aggregated query per facet field over published archive nodes,
 * keyed by the filters' exposed identifiers. Counts are corpus-wide
 * (not narrowed by the current selection - that is Solr facet
 * territory). Cached until archive content changes.
 *
 * @return array
 *   Exposed identifier => [term id => record count].
 */
function _saho_utils_archive_facet_counts(): array {
  $cid = 'saho_utils:archive_facet_counts';
  $cache = \Drupal::cache()->get($cid);
  if ($cache) {
    return $cache->data;
  }
  $fields = [
    'tid' => 'field_media_library_type',
    'language' => 'field_language',
    'saldru' => 'field_saldru_category',
    'field_african_country_target_id' => 'field_african_country',
  ];
  $counts = [];
  $database = \Drupal::database();
  foreach ($fields as $key => $field) {
    $counts[$key] = array_map('intval', $database->query("
      SELECT f.{$field}_target_id AS tid, COUNT(*) AS records
      FROM {node__{$field}} f
      INNER JOIN {node_field_data} n
        ON n.nid = f.entity_id AND n.status = 1 AND n.type = 'archive'
      WHERE f.deleted = 0
      GROUP BY f.{$field}_target_id")->fetchAllKeyed());
  }
  \Drupal::cache()->set($cid, $counts, \Drupal::time()->getRequestTime() + 3600, ['node_list:archive']);
  return $counts;
}

/**
 * Returns collection options for the archive refine rail, with counts.
 *
 * Keyed by collection nid, labelled "Title (1,234)", ordered by record
 * count. Cached until archive content changes.
 *
 * @return array
 *   Options array of collection nid => label.
 */
function _saho_utils_archive_collection_options(): array {
  $cid = 'saho_utils:archive_collection_options';
  $cache = \Drupal::cache()->get($cid);
  if ($cache) {
    return $cache->data;
  }
  $options = [];
  $rows = \Drupal::database()->query("
    SELECT p.field_feature_parent_target_id AS nid, parent.title AS title, COUNT(*) AS records
    FROM {node__field_feature_parent} p
    INNER JOIN {node_field_data} parent
      ON parent.nid = p.field_feature_parent_target_id AND parent.status = 1
    INNER JOIN {node_field_data} child
      ON child.nid = p.entity_id AND child.status = 1
    WHERE p.bundle = 'archive' AND p.deleted = 0
    GROUP BY p.field_feature_parent_target_id, parent.title
    ORDER BY records DESC, parent.title ASC")->fetchAll();
  foreach ($rows as $row) {
    $options[(int) $row->nid] = $row->title . ' (' . number_format((int) $row->records) . ')';
  }
  \Drupal::cache()->set($cid, $options, \Drupal::time()->getRequestTime() + 3600, ['node_list:archive']);
  return $options;
}
