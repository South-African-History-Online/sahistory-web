<?php

/**
 * @file
 * Champion Access module.
 *
 * Grants the 'champion' Drupal role from paid champion product orders
 * and gates nodes that have field_champion_access set to TRUE.
 */

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Drupal\user\UserInterface;

/**
 * Implements hook_node_access().
 *
 * Restricts view access to nodes with field_champion_access = 1
 * to users with the 'champion' role (or node administration permission).
 */
function champion_access_node_access(NodeInterface $node, $op, AccountInterface $account) {
  if ($op !== 'view') {
    return AccessResult::neutral();
  }

  if (!$node->hasField('field_champion_access')) {
    return AccessResult::neutral();
  }

  if (!$node->get('field_champion_access')->value) {
    return AccessResult::neutral();
  }

  if ($account->hasPermission('administer nodes') || in_array('champion', $account->getRoles())) {
    return AccessResult::allowed()
      ->cachePerUser()
      ->addCacheableDependency($node);
  }

  return AccessResult::forbidden()
    ->cachePerUser()
    ->addCacheableDependency($node);
}

/**
 * Implements hook_user_login().
 *
 * Backfill / safety net: grants the champion role on login if the user
 * has a paid champion order but the order-paid event was missed (or
 * predates this code). Additive only - never removes the role, and
 * no-ops for users who already have it. The ChampionOrderSubscriber is
 * the primary grant path.
 */
function champion_access_user_login(UserInterface $account) {
  /** @var \Drupal\champion_access\Service\ChampionRoleService $service */
  $service = \Drupal::service('champion_access.role_service');
  $service->ensureChampionRole($account);
}
