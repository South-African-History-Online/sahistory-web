{#
/**
 * @file
 * SAHO Publications block - front-page discovery section (Open Record 2027).
 *
 * Square paper cards on the catalogue grid: hairline frames, an archive
 * (ochre) accent edge, Caslon titles and mono apparatus for prices/labels.
 * Book covers stay full colour - they are products, not archive imagery.
 *
 * Available variables:
 * - eyebrow: small mono kicker line above the title.
 * - title: section heading.
 * - subtitle: section lead paragraph.
 * - items: array of publication rows. Each item supports:
 *   - title (required), subtitle, author, year, price, url, cover.
 * - shop_url: target for the "View all publications" CTA.
 * - all_label: label for the "View all" CTA.
 */
#}
<section class="saho-publications" aria-labelledby="saho-publications-heading">
  <div class="container">

    <header class="saho-publications__header">
      {% if eyebrow %}
        <p class="saho-publications__kicker">{{ eyebrow|t }}</p>
      {% endif %}
      <div class="saho-publications__header-row">
        <h2 id="saho-publications-heading" class="saho-publications__title">{{ title|t }}</h2>
      </div>
      {% if subtitle %}
        <p class="saho-publications__subtitle">{{ subtitle|t }}</p>
      {% endif %}
    </header>

    {% if items %}
      <div class="saho-publications__grid">
        {% for item in items %}
          <article class="saho-publications__card">
            <a href="{{ item.url }}" class="saho-publications__cover-link" aria-label="{{ 'View'|t }} {{ item.title }} {{ 'on the SAHO Shop'|t }}">
              <div class="saho-publications__cover">
                {% if item.cover %}
                  <img
                    src="{{ item.cover }}"
                    alt="{{ item.title }} {{ 'cover'|t }}"
                    class="saho-publications__cover-img"
                    loading="lazy"
                    decoding="async"
                  />
                {% else %}
                  <div class="saho-publications__cover-fallback" aria-hidden="true">
                    <span class="saho-publications__fallback-mark">SAHO</span>
                    <span class="saho-publications__fallback-sub">{{ 'Press'|t }}</span>
                  </div>
                {% endif %}
              </div>
            </a>

            <div class="saho-publications__card-body">
              <h3 class="saho-publications__card-title">
                <a href="{{ item.url }}"><span class="saho-publications__card-title-text">{{ item.title }}</span></a>
              </h3>
              {% if item.subtitle %}
                <p class="saho-publications__card-subtitle">{{ item.subtitle }}</p>
              {% endif %}
              {% if item.author or item.year %}
                <p class="saho-publications__card-meta">
                  {% if item.author %}<span class="saho-publications__card-author">{{ item.author }}</span>{% endif %}
                  {% if item.author and item.year %} <span aria-hidden="true">&middot;</span> {% endif %}
                  {% if item.year %}<span class="saho-publications__card-year">{{ item.year }}</span>{% endif %}
                </p>
              {% endif %}
              <div class="saho-publications__card-footer">
                {% if item.price %}
                  <span class="saho-publications__price">{{ item.price }}</span>
                {% endif %}
                <a href="{{ item.url }}" class="saho-publications__cta">
                  {{ 'View in shop'|t }} <span aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    <div class="saho-publications__footer">
      <a href="{{ shop_url }}" class="saho-publications__view-all">
        <span class="saho-publications__view-all-label">{{ all_label|t }} <span aria-hidden="true">&rarr;</span></span>
      </a>
    </div>

  </div>
</section>
