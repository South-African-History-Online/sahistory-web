{#
/**
 * @file
 * Theme implementation for the Africa Regions block (Open Record, #462).
 *
 * Regions render as place-typed archive-cards: slate accent, mono article
 * count, Caslon region name, featured country as a plain line. Whole card
 * is the link - no icons, decorative maps or carousels. Region descriptions
 * are not rendered (the voice states facts or says nothing).
 *
 * Available variables:
 * - regions: Array of region data (id, label, description, count,
 *   featured_country, url, color).
 * - block_title: Block title.
 * - intro_text: Editor-supplied standfirst (empty by default).
 * - display_mode: grid | list (legacy carousel renders as grid).
 * - show_content_count: Whether to show content counts.
 * - show_featured_country: Whether to show featured countries.
 *
 * @ingroup themeable
 */
#}
<div class="africa-regions-block">
  {% if block_title %}
    {{ include('saho:saho-section-heading', {
      title: block_title,
      level: 'h2',
    }, with_context = false) }}
  {% endif %}

  {% if intro_text %}
    <p class="block-intro">{{ intro_text }}</p>
  {% endif %}

  {% if regions %}
    <div class="saho-cards-grid regions-grid{{ display_mode == 'list' ? ' regions-grid--list' : '' }}">
      {% for region in regions %}
        {{ include('saho:saho-archive-card', {
          type: 'place',
          title: region.label,
          dates: show_content_count and region.count ? region.count ~ (region.count == 1 ? ' ARTICLE' : ' ARTICLES') : '',
          excerpt: (show_featured_country and region.featured_country) ? region.featured_country : '',
          href: region.url,
        }, with_context = false) }}
      {% endfor %}
    </div>
  {% else %}
    <p class="saho-view-empty">{{ 'No region data available.'|t }}</p>
  {% endif %}
</div>
