{#
/**
 * @file
 * Theme implementation for the History Classroom block (Open Record, #462).
 *
 * Grade doors rendered as archive-cards: type marker GRADE N, mono phase
 * kicker, Caslon featured-topic title, mono resource count. Whole card is
 * the link - no medallions, numerals, icons or carousels.
 *
 * Available variables:
 * - grades: Array of grade data (number, tid, name, label, count,
 *   featured_topic, url).
 * - block_title: Block title.
 * - intro_text: Editor-supplied standfirst (empty by default).
 * - display_mode: grid | list (legacy carousel renders as grid).
 * - show_content_count: Whether to show content counts.
 * - show_featured_topic: Whether to show featured topics.
 *
 * @ingroup themeable
 */
#}
<div class="history-classroom-block">
  {% if block_title %}
    {{ include('saho:saho-section-heading', {
      title: block_title,
      level: 'h2',
    }, with_context = false) }}
  {% endif %}

  {% if intro_text %}
    <p class="block-intro">{{ intro_text }}</p>
  {% endif %}

  {% if grades %}
    <div class="saho-cards-grid classroom-grades-grid{{ display_mode == 'list' ? ' classroom-grades-grid--list' : '' }}">
      {% for grade in grades %}
        {% set phase = grade.number <= 6 ? 'Intermediate Phase' : (grade.number <= 9 ? 'Senior Phase' : 'FET Phase') %}
        {{ include('saho:saho-archive-card', {
          type: 'archive',
          badge_label: grade.label,
          dates: phase|upper,
          title: (show_featured_topic and grade.featured_topic) ? grade.featured_topic : grade.label ~ ' resources',
          meta: show_content_count ? grade.count ~ (grade.count == 1 ? ' RESOURCE' : ' RESOURCES') : '',
          href: grade.url,
        }, with_context = false) }}
      {% endfor %}
    </div>
  {% else %}
    <p class="saho-view-empty">{{ 'No classroom content available.'|t }}</p>
  {% endif %}
</div>
