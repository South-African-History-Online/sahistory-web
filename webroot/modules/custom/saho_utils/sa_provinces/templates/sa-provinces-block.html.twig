{#
/**
 * @file
 * Theme implementation for the South African Provinces block (Open Record, #462).
 *
 * Provinces render as place-typed archive-cards: slate accent, mono place
 * count, Caslon province name, featured place as a plain line. Whole card
 * is the link - no monograms, pins, italics or carousels. Province
 * descriptions are editorial copy under review and are not rendered.
 *
 * Available variables:
 * - provinces: Array of province data (id, name, description, icon_letter,
 *   count, featured_place, url, tid, image).
 * - block_title: Block title.
 * - intro_text: Editor-supplied standfirst (empty by default).
 * - display_mode: grid | list (legacy carousel renders as grid).
 * - show_place_count: Whether to show place counts.
 * - show_featured_place: Whether to show featured places.
 *
 * @ingroup themeable
 */
#}
<div class="sa-provinces-block">
  {% if block_title %}
    {{ include('saho:saho-section-heading', {
      title: block_title,
      level: 'h2',
    }, with_context = false) }}
  {% endif %}

  {% if intro_text %}
    <p class="block-intro">{{ intro_text }}</p>
  {% endif %}

  {% if provinces %}
    <div class="saho-cards-grid provinces-grid{{ display_mode == 'list' ? ' provinces-grid--list' : '' }}">
      {% for province in provinces %}
        {{ include('saho:saho-archive-card', {
          type: 'place',
          title: province.name,
          dates: show_place_count ? province.count ~ (province.count == 1 ? ' PLACE' : ' PLACES') : '',
          excerpt: (show_featured_place and province.featured_place) ? province.featured_place : '',
          href: province.url,
          image: province.image|default(''),
          image_alt: province.image ? province.name : '',
        }, with_context = false) }}
      {% endfor %}
    </div>
  {% else %}
    <p class="saho-view-empty">{{ 'No province data available.'|t }}</p>
  {% endif %}
</div>
