{#
/**
 * @file
 * Theme implementation for the Educational Resources block (Open Record 2027).
 *
 * Resource types read as filed catalogue cards: square paper sheets with a
 * hairline frame, the article (oxblood) accent edge, Caslon titles, serif
 * descriptions and mono counts/labels. No icons, no gradients, no shadows.
 *
 * Available variables:
 * - resources: Array of resource data:
 *   - id: Resource type ID
 *   - label: Display label (e.g., "CAPS Documents")
 *   - description: Resource type description
 *   - icon: FontAwesome icon class (unused in the Open Record idiom)
 *   - color: Hex color for resource type (unused in the Open Record idiom)
 *   - count: Number of articles
 *   - featured_item: Featured/recent article title
 *   - url: Link to resource search/listing
 * - block_title: Block title
 * - intro_text: Introduction text
 * - display_mode: Display mode (grid, carousel, list)
 * - show_content_count: Whether to show content counts
 * - show_featured_item: Whether to show featured items
 *
 * @ingroup themeable
 */
#}
<div class="educational-resources-block">
  {% if block_title %}
    <header class="edu-resources__header">
      <p class="edu-resources__kicker">{{ 'For the classroom'|t }}</p>
      <div class="edu-resources__header-row">
        <h2 class="edu-resources__title">{{ block_title }}</h2>
      </div>
      {% if intro_text %}
        <p class="edu-resources__intro">{{ intro_text }}</p>
      {% endif %}
    </header>
  {% elseif intro_text %}
    <p class="edu-resources__intro">{{ intro_text }}</p>
  {% endif %}

  {% if resources %}
    <div class="resources-wrapper display-mode-{{ display_mode }}">
      {% if display_mode == 'carousel' %}
        {# Carousel mode for mobile-friendly browsing (Bootstrap JS hooks preserved) #}
        <div id="resourcesCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-indicators">
            {% for resource in resources %}
              <button type="button" data-bs-target="#resourcesCarousel" data-bs-slide-to="{{ loop.index0 }}"
                      class="{{ loop.first ? 'active' : '' }}" aria-label="{{ resource.label }}"></button>
            {% endfor %}
          </div>

          <div class="carousel-inner">
            {% for resource in resources %}
              <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                {{ _self.resource_card(resource, show_content_count, show_featured_item) }}
              </div>
            {% endfor %}
          </div>

          <button class="carousel-control-prev" type="button" data-bs-target="#resourcesCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">{{ 'Previous'|t }}</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#resourcesCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">{{ 'Next'|t }}</span>
          </button>
        </div>

      {% elseif display_mode == 'list' %}
        {# Stacked list mode #}
        <div class="resources-list">
          {% for resource in resources %}
            {{ _self.resource_card(resource, show_content_count, show_featured_item) }}
          {% endfor %}
        </div>

      {% else %}
        {# Grid mode (default) #}
        <div class="resources-grid">
          {% for resource in resources %}
            {{ _self.resource_card(resource, show_content_count, show_featured_item) }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% else %}
    <p class="edu-resources__empty">{{ 'No educational resources available.'|t }}</p>
  {% endif %}
</div>

{#
/**
 * Resource card macro for reusable card rendering.
 */
#}
{% macro resource_card(resource, show_count, show_featured) %}
  <article class="edu-resources__card resource-{{ resource.id }}">
    <a href="{{ resource.url }}" class="edu-resources__card-link">
      <p class="edu-resources__card-apparatus">
        <span class="edu-resources__card-label">{{ 'Educational resource'|t }}</span>
        {% if show_count %}
          <span class="edu-resources__card-count">{{ resource.count }} {{ resource.count == 1 ? 'resource'|t : 'resources'|t }}</span>
        {% endif %}
      </p>

      <h3 class="edu-resources__card-title"><span class="edu-resources__card-title-text">{{ resource.label }}</span></h3>

      <p class="edu-resources__card-desc">{{ resource.description }}</p>

      {% if show_featured and resource.featured_item %}
        <p class="edu-resources__featured">
          <span class="edu-resources__featured-label">{{ 'Featured'|t }}</span>
          <span class="edu-resources__featured-text">{{ resource.featured_item|truncate(60, true) }}</span>
        </p>
      {% endif %}

      <p class="edu-resources__card-cta">
        <span class="edu-resources__card-cta-text">{{ 'View resources'|t }} <span aria-hidden="true">&rarr;</span></span>
      </p>
    </a>
  </article>
{% endmacro %}
