<?php

/**
 * @file
 * Contains hero_banner.module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function hero_banner_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.hero_banner':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Provides a customizable hero banner block with background image and call to action button.') . '</p>';
      return $output;

    default:
  }
}

// The block renders through the saho:saho-hero-banner SDC (#461); the legacy
// hero_banner_block theme hook, template and CSS libraries are removed.
