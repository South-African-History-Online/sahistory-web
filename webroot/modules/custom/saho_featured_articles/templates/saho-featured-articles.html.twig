{#
/**
 * @file
 * The /featured Editorial Register (Open Record).
 *
 * Anatomy: register head (mono kicker, Caslon H1, mono counts as the
 * status strip) -> the current feature as a wf07 hero -> staff-picks
 * card grid -> most-read ledger -> the paged full register with section
 * chips and a quiet mono sort row.
 *
 * Available variables:
 * - hero: saho-hero-banner props, or {fallback: true, ...} home-feature
 *   props when the feature has no usable image, or null.
 * - stats: [{label, value}] for the status strip.
 * - staff_picks / register_items: saho-archive-card props arrays.
 * - most_read: [{rank, title, href, ref, views}] ledger rows.
 * - register_sections: [{key, label, href, active}] chips.
 * - current_section, current_sort, pager.
 */
#}
<div class="saho-page featured-register">

  <header class="featured-register__head">
    <p class="featured-register__kicker">{{ 'Editorial register'|t }}</p>
    <h1 class="featured-register__title">{{ 'Featured'|t }}</h1>
    <p class="featured-register__standfirst">{{ 'The stories the archive is holding up to the light: the current feature, the staff picks, and the record of what readers return to.'|t }}</p>
  </header>

  {% if stats %}
    {{ include('saho:saho-archive-status-bar', { stats: stats }, with_context = false) }}
  {% endif %}

  {% if hero %}
    <section class="featured-register__hero" aria-label="{{ 'Current feature'|t }}">
      {% if hero.fallback %}
        {{ include('saho:saho-home-feature', {
          kicker: 'Current feature'|t,
          title: hero.title,
          standfirst: hero.standfirst,
          href: hero.href,
          cta_label: 'Open the feature'|t,
          secondary_href: '/timelines',
          secondary_label: 'View chronology'|t,
          meta: hero.meta,
          heading_level: 'h2',
        }, with_context = false) }}
      {% else %}
        {{ include('saho:saho-hero-banner', hero, with_context = false) }}
      {% endif %}
    </section>
  {% endif %}

  {% if staff_picks %}
    <section class="featured-register__section">
      {{ include('saho:saho-section-heading', {
        title: 'Staff picks'|t,
        level: 'h2',
        href: '/featured?section=staff-picks',
        link_label: 'All picks'|t,
      }, with_context = false) }}
      <div class="saho-cards-grid">
        {% for card in staff_picks %}
          {{ include('saho:saho-archive-card', card, with_context = false) }}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if most_read %}
    <section class="featured-register__section">
      {{ include('saho:saho-section-heading', {
        title: 'Most read'|t,
        level: 'h2',
        href: '/featured?section=most-read',
        link_label: 'Full list'|t,
      }, with_context = false) }}
      <ol class="featured-ledger">
        {% for row in most_read %}
          <li class="featured-ledger__row">
            <a class="featured-ledger__link" href="{{ row.href }}">
              <span class="featured-ledger__rank" aria-hidden="true">{{ row.rank }}</span>
              <span class="featured-ledger__title">{{ row.title }}</span>
              <span class="featured-ledger__meta">{{ row.ref }}{% if row.views %} · {{ row.views }}{% endif %}</span>
            </a>
          </li>
        {% endfor %}
      </ol>
    </section>
  {% endif %}

  <section class="featured-register__section">
    {{ include('saho:saho-section-heading', {
      title: 'The register'|t,
      level: 'h2',
    }, with_context = false) }}

    <nav class="featured-register__chips" aria-label="{{ 'Filter the register'|t }}">
      {% for chip in register_sections %}
        <a class="featured-chip{{ chip.active ? ' is-active' : '' }}" href="{{ chip.href }}"{% if chip.active %} aria-current="true"{% endif %}>{{ chip.label }}</a>
      {% endfor %}
    </nav>

    <form class="featured-register__sort" method="get" data-featured-sort>
      {% if current_section != 'all' %}
        <input type="hidden" name="section" value="{{ current_section }}" />
      {% endif %}
      <label class="featured-register__sort-label" for="featured-sort-select">{{ 'Sort'|t }}</label>
      <select class="featured-register__sort-select" id="featured-sort-select" name="sort">
        <option value="changed" {{ current_sort == 'changed' ? 'selected' }}>{{ 'Recently updated'|t }}</option>
        <option value="title" {{ current_sort == 'title' ? 'selected' }}>{{ 'Title A-Z'|t }}</option>
        <option value="type" {{ current_sort == 'type' ? 'selected' }}>{{ 'Record type'|t }}</option>
      </select>
      <noscript><button type="submit" class="featured-register__sort-apply">{{ 'Apply'|t }}</button></noscript>
    </form>

    {% if register_items %}
      <div class="saho-cards-grid">
        {% for card in register_items %}
          {{ include('saho:saho-archive-card', card, with_context = false) }}
        {% endfor %}
      </div>
    {% else %}
      <p class="featured-register__empty">{{ 'Nothing is filed under this section yet.'|t }}</p>
    {% endif %}

    {% if pager %}
      <div class="featured-register__pager">
        {{ pager }}
      </div>
    {% endif %}
  </section>

</div>
