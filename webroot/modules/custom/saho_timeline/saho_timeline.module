<?php

/**
 * @file
 * SAHO Timeline module.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_query_alter().
 *
 * The /timelines landing sorts by period start parsed from the title
 * ("... timeline 1919-1989"): chronology is the register for timelines,
 * not node-changed recency. Titles with no parseable year sort last;
 * an explicit exposed-sort choice wins. MariaDB REGEXP_SUBSTR - remove
 * this alter to fall back to the view's configured sort.
 */
function saho_timeline_views_query_alter(ViewExecutable $view, QueryPluginBase $query) {
  if ($view->id() !== 'timelines' || $view->current_display !== 'page_1') {
    return;
  }
  if (!empty(\Drupal::request()->query->get('sort_by'))) {
    return;
  }
  if ($query instanceof Sql) {
    $query->orderby = [];
    $query->addOrderBy(NULL, "COALESCE(REGEXP_SUBSTR(node_field_data.title, '(1[0-9]{3}|20[0-9]{2})'), '9999')", 'ASC', 'timeline_period_start');
    $query->addOrderBy('node_field_data', 'title', 'ASC');
  }
}

/**
 * Implements hook_help().
 */
function saho_timeline_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.saho_timeline':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('The SAHO Timeline module provides timeline functionality for displaying historical events chronologically. It includes features for migrating timeline articles to event content types and displaying them in an interactive timeline format.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Interactive timeline display with filtering options') . '</li>';
      $output .= '<li>' . t('Migration tools for converting timeline articles to events') . '</li>';
      $output .= '<li>' . t('Chronological event browsing') . '</li>';
      $output .= '<li>' . t('Period-based grouping (decades, centuries)') . '</li>';
      $output .= '<li>' . t('Category filtering for events') . '</li>';
      $output .= '</ul>';
      return $output;
  }
}

/**
 * Implements hook_theme().
 */
function saho_timeline_theme() {
  return [
    'saho_timeline_app' => [
      'variables' => [
        'count' => 0,
        'range' => [0, 0],
        'eras' => [],
        'json_ld' => '',
      ],
      'template' => 'saho-timeline-app',
    ],
    'saho_timeline' => [
      'variables' => [
        'events' => [],
        'filters' => [],
        'timeline_type' => 'default',
        'attributes' => [],
      ],
      'template' => 'saho-timeline',
    ],
    'saho_timeline_interactive' => [
      'variables' => [
        'events' => [],
        'filters' => [],
        'attributes' => [],
      ],
      'template' => 'saho-timeline-interactive',
    ],
    'saho_timeline_event' => [
      'variables' => [
        'event' => NULL,
        'display_mode' => 'default',
        'attributes' => [],
      ],
      'template' => 'saho-timeline-event',
    ],
    'saho_timeline_filters' => [
      'variables' => [
        'filters' => [],
        'active_filters' => [],
        'attributes' => [],
      ],
      'template' => 'saho-timeline-filters',
    ],
  ];
}
