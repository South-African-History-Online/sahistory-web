<?php

/**
 * @file
 * Hook implementations for the SAHO Classroom module.
 */

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_pre_view().
 *
 * The CAPS-topic facet depends on grade (#466): with no grade selected the
 * topic chips are hidden, so a topic value left in the URL must not keep
 * filtering the results invisibly.
 */
function saho_classroom_views_pre_view(ViewExecutable $view, $display_id, array &$args): void {
  if ($view->id() !== 'classroom') {
    return;
  }
  $input = $view->getExposedInput();
  if (empty($input['grade']) && isset($input['caps_topic'])) {
    unset($input['caps_topic']);
    $view->setExposedInput($input);
  }
}

/**
 * Implements hook_form_alter().
 *
 * Turns the CAPS-topic exposed filter into a grade-dependent facet (#466):
 * teachers arrive knowing their grade, not our taxonomy. With no grade
 * selected the topic group is hidden entirely; with grades selected, only
 * the CAPS topics of those grades render (as chips - the widget is a BEF
 * links element, styled by the classroom-hub chip CSS). The caps_topic
 * vocabulary nests topics under one parent term per grade, so parentage
 * is matched to the selected classroom_grade labels; picking a phase term
 * means all of its grade children.
 */
function saho_classroom_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (($form['#id'] ?? '') !== 'views-exposed-form-classroom-page-1'
    || empty($form['caps_topic']['#options'])) {
    return;
  }

  $grade_input = $form_state->getUserInput()['grade'] ?? [];
  $grade_tids = array_filter(is_array($grade_input) ? $grade_input : [$grade_input], 'is_numeric');
  if (!$grade_tids) {
    $form['caps_topic']['#access'] = FALSE;
    return;
  }

  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');

  // Selected grade labels; a phase selection expands to its grade children.
  $grade_names = [];
  foreach ($term_storage->loadMultiple($grade_tids) as $grade_term) {
    $children = $term_storage->loadChildren($grade_term->id(), 'classroom_grade');
    $terms = $children ?: [$grade_term];
    foreach ($terms as $term) {
      $grade_names[mb_strtolower((string) $term->label())] = TRUE;
    }
  }

  // Keep only the CAPS topics whose parent term matches a selected grade;
  // the per-grade parent rows themselves are grouping, not topics.
  $topic_tids = array_filter(array_keys($form['caps_topic']['#options']), 'is_numeric');
  $topics = $term_storage->loadMultiple($topic_tids);
  foreach ($form['caps_topic']['#options'] as $tid => $label) {
    if (!is_numeric($tid)) {
      continue;
    }
    $topic = $topics[$tid] ?? NULL;
    $parent_id = $topic ? (int) ($topic->get('parent')->target_id ?? 0) : 0;
    if (!$topic || !$parent_id) {
      unset($form['caps_topic']['#options'][$tid]);
      continue;
    }
    $parent = $topics[$parent_id] ?? $term_storage->load($parent_id);
    if (!$parent || empty($grade_names[mb_strtolower((string) $parent->label())])) {
      unset($form['caps_topic']['#options'][$tid]);
      continue;
    }
    // Strip the hierarchy indent dashes the select-based options carry.
    $form['caps_topic']['#options'][$tid] = ltrim((string) $label, '- ');
  }

  // Nothing matched for the selected grades: hide, not an empty group.
  if (!array_filter(array_keys($form['caps_topic']['#options']), 'is_numeric')) {
    $form['caps_topic']['#access'] = FALSE;
  }
}

/**
 * Implements hook_preprocess_node().
 *
 * Attaches the resource-type badge styling to presentation nodes.
 */
function saho_classroom_preprocess_node(array &$variables): void {
  $node = $variables['node'] ?? NULL;
  if ($node instanceof EntityInterface && $node->bundle() === 'presentation') {
    $variables['#attached']['library'][] = 'saho_classroom/badge';
  }
}

/**
 * Implements hook_preprocess_views_view().
 *
 * Loads the badge styling on the classroom presentations browse.
 */
function saho_classroom_preprocess_views_view(array &$variables): void {
  $view = $variables['view'] ?? NULL;
  if ($view && $view->id() === 'classroom_presentations') {
    $variables['#attached']['library'][] = 'saho_classroom/badge';
  }
}

/**
 * Implements hook_node_view().
 *
 * Adds a prominent teacher quick-link to legacy classroom content. When a
 * presentation deck matches the topic (by comparing the article title with each
 * deck's caps_topic), it links straight to that deck; otherwise it links to the
 * presentations browse. The match is computed in code from the committed decks,
 * so it reproduces identically on every environment.
 */
function saho_classroom_node_view(array &$build, EntityInterface $node, $display, $view_mode): void {
  if ($view_mode !== 'full' || !$node instanceof NodeInterface || $node->bundle() === 'presentation') {
    return;
  }
  $is_classroom = FALSE;
  foreach (['field_classroom_categories', 'field_classroom'] as $field) {
    if ($node->hasField($field) && !$node->get($field)->isEmpty()) {
      $is_classroom = TRUE;
      break;
    }
  }
  if (!$is_classroom) {
    return;
  }

  $deck = _saho_classroom_match_deck($node);
  $url = $deck ? $deck->toUrl() : Url::fromUserInput('/classroom/presentations');
  $link_text = $deck ? t('Open the presentation') : t('Open presentations');
  $title = $deck
    ? t('Teach this topic with a ready-made, print-friendly presentation deck.')
    : t('Teach this in the classroom - interactive, print-ready presentations.');

  $build['saho_classroom_presentations_cta'] = [
    '#type' => 'container',
    '#weight' => -100,
    '#attributes' => ['class' => ['saho-classroom-cta']],
    '#attached' => ['library' => ['saho_classroom/badge']],
    // Recompute if the set of presentation decks changes.
    '#cache' => ['tags' => ['node_list']],
    'text' => [
      '#type' => 'html_tag',
      '#tag' => 'div',
      '#attributes' => ['class' => ['saho-classroom-cta__text']],
      'eyebrow' => [
        '#type' => 'html_tag',
        '#tag' => 'span',
        '#attributes' => ['class' => ['saho-classroom-cta__eyebrow']],
        '#value' => t('For teachers'),
      ],
      'title' => [
        '#type' => 'html_tag',
        '#tag' => 'span',
        '#attributes' => ['class' => ['saho-classroom-cta__title']],
        '#value' => $title,
      ],
    ],
    'link' => [
      '#type' => 'link',
      '#title' => $link_text,
      '#url' => $url,
      '#attributes' => ['class' => ['saho-classroom-cta__btn']],
    ],
  ];
}

/**
 * Finds the presentation deck whose topic best matches an article, if any.
 *
 * Deterministic token overlap between the article title and each published
 * deck's caps_topic term (falling back to the deck title). Pure code + a
 * runtime query - no stored mapping - so it reproduces on any environment.
 *
 * @param \Drupal\node\NodeInterface $article
 *   The legacy classroom article.
 *
 * @return \Drupal\node\NodeInterface|null
 *   The best-matching presentation node, or NULL when none is confident.
 */
function _saho_classroom_match_deck(NodeInterface $article): ?NodeInterface {
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $ids = $storage->getQuery()
    ->accessCheck(TRUE)
    ->condition('type', 'presentation')
    ->condition('status', 1)
    ->execute();
  if (!$ids) {
    return NULL;
  }
  $article_tokens = _saho_classroom_tokens($article->label());
  if (!$article_tokens) {
    return NULL;
  }

  $best = NULL;
  $best_score = 0.0;
  foreach ($storage->loadMultiple($ids) as $deck) {
    $topic = '';
    if ($deck->hasField('field_caps_topic') && !$deck->get('field_caps_topic')->isEmpty()) {
      $term = $deck->get('field_caps_topic')->entity;
      if ($term) {
        $topic = (string) $term->label();
      }
    }
    if ($topic === '') {
      $topic = (string) $deck->label();
    }
    $topic_tokens = _saho_classroom_tokens($topic);
    if (!$topic_tokens) {
      continue;
    }
    $hits = count(array_intersect_key($topic_tokens, $article_tokens));
    $score = $hits / count($topic_tokens);
    if ($score > $best_score) {
      $best_score = $score;
      $best = $deck;
    }
  }

  // Require a strong overlap so we never link to a loosely-related deck.
  return $best_score >= 0.6 ? $best : NULL;
}

/**
 * Tokenises a title into a set of significant lowercase words.
 */
function _saho_classroom_tokens(string $text): array {
  $text = strtolower($text);
  // Drop "Grade N" / "Term N" scaffolding that legacy titles carry.
  $text = preg_replace('/\bgrade\s*\d+\b|\bterm\s*\d+\b/', ' ', $text);
  $text = preg_replace('/[^a-z0-9\s]/', ' ', $text);
  $stop = [
    'the' => 1, 'and' => 1, 'for' => 1, 'from' => 1, 'with' => 1, 'into' => 1,
    'history' => 1, 'south' => 1, 'african' => 1, 'africa' => 1,
  ];
  $tokens = [];
  foreach (preg_split('/\s+/', trim($text)) as $t) {
    if (strlen($t) >= 3 && empty($stop[$t])) {
      $tokens[$t] = TRUE;
    }
  }
  return $tokens;
}
