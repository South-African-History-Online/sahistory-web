{#
/**
 * @file
 * Taxonomy term listing - 2027 "Open Record" term page (design-QA #457).
 *
 * The term head owns the page H1 (the global page title is suppressed for
 * entity.taxonomy_term.canonical in saho_preprocess_page_title()). Rows
 * render through views-view-unformatted--taxonomy-term.html.twig as the
 * unified card grid.
 *
 * Available variables (beyond the standard views-view set):
 * - term_vocab: The vocabulary label (saho_preprocess_views_view__taxonomy_term).
 * - term_description: Processed term description render array, or null.
 */
#}
<div{{ attributes.addClass('saho-page', 'saho-term-page', 'view-' ~ view.id|clean_class) }}>

  {# Term header: mono vocabulary kicker, Caslon term name, hairline. #}
  <header class="saho-term-head">
    {% if term_vocab %}
      <p class="saho-term-head__kicker">{{ term_vocab }} - index term</p>
    {% endif %}
    <h1 class="saho-term-head__title">{{ term_label ?: title }}</h1>
    {% if rows_total is defined and rows_total > 0 %}
      <p class="saho-term-head__count">{{ rows_total }} records</p>
    {% endif %}
    {% if term_description %}
      <div class="saho-term-head__desc">{{ term_description }}</div>
    {% endif %}
  </header>

  {% if header %}
    <div class="saho-term-intro">
      {{ header }}
    </div>
  {% endif %}

  {% if exposed %}
    <div class="saho-term-filters">
      {{ exposed }}
      {% if feed_icons %}
        <div class="saho-term-feeds">{{ feed_icons }}</div>
      {% endif %}
    </div>
  {% endif %}

  {% if rows %}
    {{ rows }}
  {% elseif empty %}
    <div class="saho-view-empty">
      {{ empty }}
    </div>
  {% endif %}

  {% if pager %}
    <div class="saho-term-pager">
      {{ pager }}
    </div>
  {% endif %}

  {% if more %}
    <div class="saho-term-more">
      {{ more }}
    </div>
  {% endif %}

  {% if attachment_after %}
    <div class="saho-term-attachment">
      {{ attachment_after }}
    </div>
  {% endif %}

</div>
