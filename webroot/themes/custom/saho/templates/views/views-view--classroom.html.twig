{#
/**
 * @file
 * Classroom / educator landing - 2027 "Open Record" shell (wireframe wf08).
 *
 * Rows are NOT printed via {{ rows }}: saho_preprocess_views_view__classroom()
 * shapes every result into classroom_cards (saho-archive-card SDC props).
 * The exposed BEF-links filters (grade, resource_type) render inside the
 * grade/phase selector bar and are styled as square tag chips.
 *
 * Available variables (beyond the standard views-view set):
 * - classroom_cards: One archive-card prop set per result.
 * - result_total: Total result count across all pages (formatted).
 *
 * The page title block provides the H1 on /classroom; headings start at h2.
 */
#}
<div{{ attributes.addClass('saho-page', 'saho-classroom-hub') }}>

  {# Header (wf08): Caslon title + educator intro on a 3px accent top edge.
     This header owns the page H1 - the global page title is suppressed for
     this route in saho_preprocess_page_title(). #}
  <header class="saho-classroom-hub__head">
    <h1 class="saho-classroom-hub__title">Classroom</h1>
    <p class="saho-classroom-hub__intro">Grade-aligned doors into the record: CAPS-aligned overviews, sources and lesson material for South African history classrooms.</p>
    <p class="saho-classroom-hub__count">{{ result_total }} resources</p>
  </header>

  {# Grade / phase selector (wf08): BEF-links exposed filters as tag chips. #}
  <nav class="saho-classroom-hub__grades" aria-label="Filter by grade">
    {{ exposed }}
  </nav>

  {# Curriculum-aligned collections: ArchiveCard grid. #}
  <section class="saho-classroom-hub__collections">
    {% include 'saho:saho-section-heading' with {
      title: 'Curriculum-aligned material',
      level: 'h3',
    } only %}

    {% if classroom_cards is not empty %}
      <div class="saho-card-grid saho-card-grid--columns-three">
        {% for card in classroom_cards %}
          {% include 'saho:saho-archive-card' with card only %}
        {% endfor %}
      </div>
    {% else %}
      <p class="saho-classroom-hub__empty">No classroom material matches this filter yet.</p>
      {% if empty %}
        <div class="saho-classroom-hub__empty-view">{{ empty }}</div>
      {% endif %}
    {% endif %}

    {% if pager %}
      <div class="saho-classroom-hub__pager">
        {{ pager }}
      </div>
    {% endif %}
  </section>

  {# Two-up bottom row (wf08): classroom guidance + lesson packs. #}
  <div class="saho-classroom-hub__extras">
    <article class="saho-classroom-hub__extra">
      <h3 class="saho-classroom-hub__extra-title">How to use the archive in class</h3>
      <p class="saho-classroom-hub__extra-copy">Every record here cites its sources - ask learners to follow the citations and weigh who wrote them, and why. Set two records on the same event side by side and compare the accounts. Provenance matters: where a document comes from is part of what it says.</p>
      <ul class="saho-classroom-hub__extra-links">
        <li><a href="/archives">Browse the archive</a></li>
      </ul>
    </article>
    <article class="saho-classroom-hub__extra">
      <h3 class="saho-classroom-hub__extra-title">Downloadable lesson packs</h3>
      <p class="saho-classroom-hub__extra-copy">CAPS curriculum documents and printable source packs, ready to take into the classroom.</p>
      <ul class="saho-classroom-hub__extra-links">
        <li><a href="/caps-documents">CAPS documents</a></li>
        <li><a href="/aids-resources">Teaching and learning aids</a></li>
      </ul>
    </article>
  </div>

</div>
