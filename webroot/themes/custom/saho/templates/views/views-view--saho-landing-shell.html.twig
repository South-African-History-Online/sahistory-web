{#
/**
 * @file
 * Shared section-landing shell - 2027 "Open Record" (wireframe wf02).
 *
 * Rows are NOT printed via {{ rows }}: saho_preprocess_views_view__biographies()
 * shapes every result into record_rows (saho-index-table SDC) and record_cards
 * (saho-archive-card SDC), rendered behind the shared table/cards toggle
 * (saho-view-toggle.js in the saho-index-table library). Same results contract
 * as views-view--saho-landing.html.twig, with two deviations:
 * - This header owns the page H1: block.block.saho_page_title excludes
 *   /biographies (negated request_path from the legacy landing template era),
 *   so unlike /index/% no global page title renders on this route.
 * - The exposed Biography Categories filter (BEF checkboxes) renders as a
 *   chip rail above the results (the classroom treatment), not a side rail.
 *
 * Available variables (beyond the standard views-view set):
 * - landing_type: Accent key for the content type.
 * - landing_label: Human label for the section.
 * - landing_count: Total record count across all pages (formatted).
 * - record_columns: Column definitions for the index-table SDC.
 * - record_rows: One row per result (ref/type/title/href/dates/src).
 * - record_cards: One archive-card prop set per result.
 * - results_layout: 'table' or 'grid' - the server-side default layout.
 */
#}
<div{{ attributes.addClass('saho-page', 'is-wide', 'saho-landing-page', 'saho-landing--' ~ landing_type) }}>

  {# Landing header: type chip, title, mono record count. This header owns
     the page H1 - the page title block is excluded on /biographies. #}
  <header class="saho-landing-head">
    {# No type chip here: on a landing it would repeat the H1 verbatim
       (the chip earns its keep on record pages, where type != title). #}
    <h1 class="saho-landing-head__title">{{ landing_label }}</h1>
    <p class="saho-landing-head__count">{{ landing_count }} records</p>
    {# Hidden URL-only filters made visible (term-register redirects):
       mono head line in the archive collection-head register. #}
    {% if filter_head %}
      <p class="saho-archive-collection">
        <span class="saho-archive-collection__label">{{ 'Filtered:'|t }}</span>
        {{ filter_head.labels|join(' · ') }}
        <a class="saho-archive-collection__clear" href="{{ filter_head.clear_url }}"
           aria-label="{{ 'Clear this filter'|t }}">&#215;</a>
      </p>
    {% endif %}
    {# Places carry coordinates, but the map is a results layout (the Map tab
       below), not a separate destination - no header link needed. #}
    {# Timelines carry dates: offer the interactive timeline as an alternate
       view ('event' is only ever the /timelines register in the shell map). #}
    {% if landing_type == 'event' %}
      <a class="saho-landing-head__maplink" href="/timeline">{{ 'View the interactive timeline'|t }} &rarr;</a>
    {% endif %}
  </header>

  {# Register tiles (R3 #481, generalised): thematic front doors that drive
     this landing's exposed filters in place - the records below become the
     register clicked. An active tile links back to the full landing.
     Built in _saho_landing_registers(); /africa keeps deep links because
     its regional pages are designed destinations of their own. #}
  {% if landing_registers %}
    <nav class="saho-africa-regions saho-landing-registers" aria-label="{{ 'Registers'|t }}">
      {% for register in landing_registers %}
        <a class="saho-africa-regions__card{{ register.active ? ' is-active' }}"
           href="{{ register.href }}"
           {%- if register.active %} aria-current="true"{% endif %}>
          <span class="saho-africa-regions__marker" aria-hidden="true"></span>
          <span class="saho-africa-regions__label">{{ register.label }}</span>
        </a>
      {% endfor %}
    </nav>
  {% endif %}

  {% if header %}
    <div class="saho-landing-intro">
      {{ header }}
    </div>
  {% endif %}

  {# Biography Categories (BEF checkboxes) as a square mono chip rail. #}
  <nav class="saho-landing__filters" aria-label="Filter {{ landing_label|lower }}">
    {{ exposed }}
  </nav>

  <div class="saho-search-layout saho-search-layout--single">
    <section class="saho-search-results" data-saho-results>

      {# Head row: the table/cards layout toggle (the header owns the count). #}
      <div class="saho-search-head">
        <div class="saho-search-toolbar">
          <div class="saho-view-toggle" data-saho-view-toggle role="tablist" aria-label="Result layout">
            <button type="button" role="tab" data-view="table"
                    class="saho-view-toggle__btn{{ results_layout == 'table' ? ' is-active' : '' }}"
                    aria-selected="{{ results_layout == 'table' ? 'true' : 'false' }}">Table</button>
            <button type="button" role="tab" data-view="grid"
                    class="saho-view-toggle__btn{{ results_layout == 'grid' ? ' is-active' : '' }}"
                    aria-selected="{{ results_layout == 'grid' ? 'true' : 'false' }}">Cards</button>
            {% if map_available|default(false) or map_embed %}
              {# The map pane only renders under ?layout=map (it is megabytes
                 of location markup); on other layouts the toggle JS turns
                 this tab into a navigation to that URL. #}
              <button type="button" role="tab" data-view="map"
                      class="saho-view-toggle__btn{{ results_layout == 'map' ? ' is-active' : '' }}"
                      aria-selected="{{ results_layout == 'map' ? 'true' : 'false' }}">Map</button>
            {% endif %}
          </div>
        </div>
      </div>

      {% if record_rows is not empty %}
        <div class="saho-results--table"{% if results_layout != 'table' %} hidden{% endif %}>
          {% include 'saho:saho-index-table' with {
            columns: record_columns,
            rows: record_rows,
            caption: landing_label,
          } only %}
        </div>
        <div class="saho-results--grid"{% if results_layout != 'grid' %} hidden{% endif %}>
          <div class="saho-card-grid saho-card-grid--columns-three">
            {% for card in record_cards %}
              {% include 'saho:saho-archive-card' with card only %}
            {% endfor %}
          </div>
        </div>
        {% if map_embed %}
          <div class="saho-results--map"{% if results_layout != 'map' %} hidden{% endif %}>
            {{ map_embed }}
          </div>
        {% endif %}
      {% else %}
        {% if empty %}
          <div class="saho-view-empty">
            {{ empty }}
          </div>
        {% else %}
          <p class="saho-search-empty">No records found.</p>
        {% endif %}
      {% endif %}

      {# The pager drives the paged layouts only - hidden while the (unpaged)
         map is the server-rendered layout; the toggle JS mirrors this. #}
      {% if pager %}
        <div class="saho-search-pager"{% if results_layout == 'map' %} hidden{% endif %}>
          {{ pager }}
        </div>
      {% endif %}

      {% if more %}
        <div class="saho-search-more">
          {{ more }}
        </div>
      {% endif %}

    </section>
  </div>

  {% if attachment_after %}
    <div class="saho-landing-attachment">
      {{ attachment_after }}
    </div>
  {% endif %}

</div>
