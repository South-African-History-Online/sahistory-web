{#
/**
 * @file
 * SAHO global search - 2027 "Open Record" search shell (wireframe wf05).
 *
 * Rows are NOT printed via {{ rows }}: saho_preprocess_views_view__saho_global_search()
 * shapes every result into record_rows (saho-index-table SDC) and record_cards
 * (saho-archive-card SDC), and this template renders both containers behind a
 * table/cards toggle (saho-view-toggle.js in the saho-index-table library).
 * The server-rendered default honours ?layout=grid.
 *
 * Available variables (beyond the standard views-view set):
 * - search_query: Active fulltext query string (set by saho_tools).
 * - spellcheck_suggestion: Solr "Did you mean" collation (set by saho_tools).
 * - record_columns: Column definitions for the index-table SDC.
 * - record_rows: One row per result (ref/type/title/href/dates/src).
 * - record_cards: One archive-card prop set per result.
 * - result_total: Total result count across all pages.
 * - results_layout: 'table' or 'grid' - the server-side default layout.
 *
 * The page title block provides the H1 on /search; headings here start at h2.
 */
#}
<div{{ attributes.addClass('saho-page', 'is-wide', 'saho-search-page') }}>

  {# Header zone: the big ledger search field, prefilled with the active query. #}
  <div class="saho-search-page__header">
    {% include 'saho:saho-search-field' with {
      size: 'lg',
      action: '/search',
      placeholder: 'Search people, events, places, dates…',
      value: search_query|default(''),
      input_id: 'saho-search-page-input',
    } only %}
  </div>

  {% if header %}
    <div class="saho-search-page__intro">
      {{ header }}
    </div>
  {% endif %}

  {# Refine rail + results. #}
  <div class="saho-search-layout">

    <aside class="saho-search-rail" aria-label="Refine search" data-saho-refine-source>
      <h2 class="saho-search-rail__title">Refine</h2>
      {{ exposed }}
      {% if feed_icons %}
        <div class="saho-search-rail__feeds">{{ feed_icons }}</div>
      {% endif %}
    </aside>

    <section class="saho-search-results" data-saho-results>

      {# Head row: mono record count + the table/cards layout toggle. #}
      <div class="saho-search-head">
        <p class="saho-search-count">{{ result_total }} records
          <a class="saho-search-advanced-link saho-search-advanced-link--inline" href="/search/advanced">Advanced search &rarr;</a>
        </p>
        <div class="saho-search-toolbar">
          <button type="button" class="saho-refine-trigger"
                  data-bs-toggle="offcanvas" data-bs-target="#sahoRefineDrawer"
                  aria-controls="sahoRefineDrawer">
            {{ 'Refine'|t }}{% if refine_count %} <span class="saho-refine-trigger__count">&middot; {{ refine_count }}</span>{% endif %}
          </button>
          <label class="saho-archive-sort">
            <span class="saho-archive-sort__label">Sort:</span>
            <select class="saho-archive-sort__select" data-saho-archive-sort>
              {% for value, label in search_sort.options %}
                <option value="{{ value }}"{{ value == search_sort.current ? ' selected' : '' }}>{{ label }}</option>
              {% endfor %}
            </select>
          </label>
          <div class="saho-view-toggle" data-saho-view-toggle role="tablist" aria-label="Result layout">
            <button type="button" role="tab" data-view="table"
                    class="saho-view-toggle__btn{{ results_layout == 'table' ? ' is-active' : '' }}"
                    aria-selected="{{ results_layout == 'table' ? 'true' : 'false' }}">Table</button>
            <button type="button" role="tab" data-view="grid"
                    class="saho-view-toggle__btn{{ results_layout == 'grid' ? ' is-active' : '' }}"
                    aria-selected="{{ results_layout == 'grid' ? 'true' : 'false' }}">Cards</button>
          </div>
        </div>
      </div>

      {% if record_rows is not empty %}
        {# saho-results--stack: on narrow phones rows stack (title first)
           instead of scrolling sideways - see saho-index-table.css. #}
        <div class="saho-results--table saho-results--stack"{% if results_layout == 'grid' %} hidden{% endif %}>
          {% include 'saho:saho-index-table' with {
            columns: record_columns,
            rows: record_rows,
            caption: 'Search results',
          } only %}
        </div>
        <div class="saho-results--grid"{% if results_layout == 'table' %} hidden{% endif %}>
          <div class="saho-card-grid saho-card-grid--columns-three">
            {% for card in record_cards %}
              {% include 'saho:saho-archive-card' with card only %}
            {% endfor %}
          </div>
        </div>
      {% else %}
        {% if empty %}
          <div class="saho-view-empty">
            {{ empty }}
          </div>
        {% elseif search_query %}
          <p class="saho-search-empty">No results found for &ldquo;{{ search_query }}&rdquo;.</p>
        {% endif %}

        {% if spellcheck_suggestion and search_query %}
          <p class="saho-spellcheck-suggestion">
            Did you mean:
            <a href="{{ path('view.saho_global_search.page_1', {}, {'query': {'search_api_fulltext': spellcheck_suggestion}}) }}" class="saho-spellcheck-link">
              {{ spellcheck_suggestion }}
            </a>?
          </p>
        {% endif %}
      {% endif %}

      {% if pager %}
        <div class="saho-search-pager">
          {{ pager }}
        </div>
      {% endif %}

      {% if more %}
        <div class="saho-search-more">
          {{ more }}
        </div>
      {% endif %}

    </section>
  </div>

  {% if attachment_after %}
    <div class="saho-search-attachment">
      {{ attachment_after }}
    </div>
  {% endif %}

  {# Mobile refine drawer: archive-refine-drawer.js moves the rail node in
     here below 40rem and back again on desktop - same contract as
     /archives (data-saho-refine-source/-body/-show). #}
  <div class="offcanvas offcanvas-end saho-refine-drawer" tabindex="-1"
       id="sahoRefineDrawer" aria-labelledby="sahoRefineDrawerTitle">
    <div class="offcanvas-header">
      <h2 class="saho-refine-drawer__title" id="sahoRefineDrawerTitle">{{ 'Refine'|t }}</h2>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'Close'|t }}"></button>
    </div>
    <div class="offcanvas-body saho-refine-drawer__body" data-saho-refine-body></div>
    <div class="saho-refine-drawer__footer">
      <button type="button" class="saho-refine-drawer__show" data-saho-refine-show>
        {{ 'Show @count records'|t({'@count': result_total}) }}
      </button>
      <a class="saho-refine-drawer__clear" href="{{ refine_clear_url }}">{{ 'Clear all'|t }}</a>
    </div>
  </div>

</div>
