{#
/**
 * @file
 * SAHO archive landing - the wf05 search shell applied to /archives.
 *
 * Rows are NOT printed via {{ rows }}: saho_preprocess_views_view__archive_pages__page_1()
 * shapes every result into record_rows (saho-index-table SDC) and record_cards
 * (saho-archive-card SDC). The query band at the top is a standalone GET form
 * (same pattern as /search); the exposed form in the rail carries the facets -
 * its own combine input, BEF sort widgets, items-per-page and Apply are hidden
 * in _archive-index.scss (BEF autosubmit applies facet changes, archive-sort.js
 * drives the one quiet sort control in the results head).
 *
 * Available variables (beyond the standard views-view set):
 * - search_query: Active ?combine= query string.
 * - record_columns: Column definitions for the index-table SDC.
 * - record_rows: One row per result (ref/title/href/dates/src).
 * - record_cards: One archive-card prop set per result.
 * - result_total: Total result count across all pages.
 * - results_layout: 'table' or 'grid' - the server-side default layout.
 * - archive_sort: { current: 'changed|DESC', options: {value: label} }.
 *
 * The page title block provides the H1 on /archives; headings here start at h2.
 */
#}
<div{{ attributes.addClass('saho-page', 'is-wide', 'saho-archive-index') }}>

  {# The archive's front door is the query - first interactive element. #}
  <div class="saho-archive-index__header">
    {% include 'saho:saho-search-field' with {
      size: 'lg',
      action: '/archives',
      input_name: 'combine',
      placeholder: 'Search the archive by title, author, ISBN…',
      value: search_query|default(''),
      input_id: 'saho-archive-query',
    } only %}
  </div>

  {% if header %}
    <div class="saho-archive-index__intro">
      {{ header }}
    </div>
  {% endif %}

  {# Facet rail + results. #}
  <div class="saho-search-layout">

    <aside class="saho-search-rail" aria-label="Refine the archive">
      <h2 class="saho-search-rail__title">Refine</h2>
      {{ exposed }}
    </aside>

    <section class="saho-search-results" data-saho-results>

      {% if collection_head %}
        <p class="saho-archive-collection">
          <span class="saho-archive-collection__label">Collection:</span>
          <a href="{{ collection_head.href }}">{{ collection_head.label }}</a>
          <a class="saho-archive-collection__clear" href="{{ collection_head.clear_url }}"
             aria-label="Clear the collection filter">&#215;</a>
        </p>
      {% endif %}

      {# Head row: mono record count + quiet sort control + layout toggle. #}
      <div class="saho-search-head">
        <p class="saho-search-count">{{ result_total }} records</p>
        <div class="saho-search-toolbar">
          <label class="saho-archive-sort">
            <span class="saho-archive-sort__label">Sort:</span>
            <select class="saho-archive-sort__select" data-saho-archive-sort>
              {% for value, label in archive_sort.options %}
                <option value="{{ value }}"{{ value == archive_sort.current ? ' selected' : '' }}>{{ label }}</option>
              {% endfor %}
            </select>
          </label>
          <div class="saho-view-toggle" data-saho-view-toggle role="tablist" aria-label="Result layout">
            <button type="button" role="tab" data-view="table"
                    class="saho-view-toggle__btn{{ results_layout == 'table' ? ' is-active' : '' }}"
                    aria-selected="{{ results_layout == 'table' ? 'true' : 'false' }}">Table</button>
            <button type="button" role="tab" data-view="grid"
                    class="saho-view-toggle__btn{{ results_layout == 'grid' ? ' is-active' : '' }}"
                    aria-selected="{{ results_layout == 'grid' ? 'true' : 'false' }}">Cards</button>
          </div>
        </div>
      </div>

      {% if record_rows is not empty %}
        <div class="saho-results--table saho-results--stack"{% if results_layout == 'grid' %} hidden{% endif %}>
          {% include 'saho:saho-index-table' with {
            columns: record_columns,
            rows: record_rows,
            caption: 'Archive records',
          } only %}
        </div>
        <div class="saho-results--grid"{% if results_layout == 'table' %} hidden{% endif %}>
          <div class="saho-card-grid saho-card-grid--columns-three">
            {% for card in record_cards %}
              {% include 'saho:saho-archive-card' with card only %}
            {% endfor %}
          </div>
        </div>
      {% elseif empty %}
        <div class="saho-view-empty">
          {{ empty }}
        </div>
      {% elseif search_query %}
        <p class="saho-search-empty">No records found for &ldquo;{{ search_query }}&rdquo;.</p>
      {% endif %}

      {% if pager %}
        <div class="saho-search-pager">
          {{ pager }}
        </div>
      {% endif %}

    </section>
  </div>

  {% if attachment_after %}
    <div class="saho-archive-index__attachment">
      {{ attachment_after }}
    </div>
  {% endif %}

</div>
