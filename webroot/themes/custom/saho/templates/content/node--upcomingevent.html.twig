{#
/**
 * @file
 * Custom SAHO node template for Upcoming Event content type.
 *
 * 2027 "Open Record" record family (S3): the record-header SDC owns the
 * page H1 (the global page title is suppressed for record bundles), the
 * rail carries the event details, image and cross-references.
 * Layout Builder is disabled - fields are output directly via Twig.
 */
#}

{% set sidebar_has_content = false %}

<article{{ attributes.addClass('saho-article-wrapper') }}>

  {# Record header: typed tab + display ref + live event status + key facts. #}
  {% if record is defined %}
    {{ include('saho:saho-record-header', {
      type: record.type,
      reference: record.reference,
      status: record.status,
      kicker: record.kicker,
      title: record.title,
      facts: record.facts,
    }, with_context = false) }}
  {% endif %}

  {# The record toolbar rides directly under the key-field strip (R3 #476). #}
  {% if record_toolbar is defined %}
    {{ include('saho:saho-record-toolbar', record_toolbar|merge({
      connections_count: record_related.tabs is defined ? record_related.tabs|reduce((c, t) => c + t.count, 0) : 0,
    }), with_context = false) }}
  {% endif %}

  <div class="saho-article-grid">

    {# LEFT: Main content column #}
    <div class="saho-main-content">

      {# Tools only (dates live in the record header + rail). #}
      <div class="saho-article-meta">
      </div>

      {# Main content with ID for TOC linking #}
      <div id="event-details" class="saho-article-body">
        {% if content.body %}
          {# Remove the label by accessing the content directly #}
          {{ content.body.0 }}
        {% endif %}
      </div>

      {# Render remaining fields not already shown manually #}
      {{ content|without(
        'body',
        'field_start_date',
        'field_end_date',
        'field_upcoming_venue',
        'field_type_of_event',
        'field_upcomingevent_image',
        'field_file_upload',
        'field_parent',
        'comment_node_upcomingevent',
        'sharing_buttons'
      ) }}

      {# Cite this entry (Harvard / APA / Oxford, from CitationService). #}
      {% if record_citation %}
        {{ include('saho:saho-citation', record_citation, with_context = false) }}
      {% endif %}

    </div>

    {# RIGHT: Sidebar (the Open Record rail - S3) #}
    {% if record_image.src is defined and record_image.src %}
      {% set sidebar_has_content = true %}
    {% endif %}
    {% if record_meta or record_related %}
      {% set sidebar_has_content = true %}
    {% endif %}
    {% if content.field_parent is defined and content.field_parent|render|trim %}
      {% set sidebar_has_content = true %}
    {% endif %}
    {% if content.field_file_upload is defined and content.field_file_upload|render|trim %}
      {% set sidebar_has_content = true %}
    {% endif %}
    {% if content.field_type_of_event is defined and content.field_type_of_event|render|trim %}
      {% set sidebar_has_content = true %}
    {% endif %}

    {% if sidebar_has_content %}
    <aside class="saho-article-sidebar">

      {# Event image: duotone image-credit figure (S3). #}
      {% if record_image.src is defined and record_image.src %}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}

      {# Event record: date, time, venue. #}
      {% if record_meta %}
        {{ include('saho:saho-metadata-block', record_meta, with_context = false) }}
      {% endif %}

      {# Cross-references: typed entity relations. #}
      {% if record_related %}
        {{ include('saho:saho-related-tabs', record_related, with_context = false) }}
      {% endif %}

      {# Display Event Type #}
      {% if content.field_type_of_event %}
        <section class="saho-meta-block saho-meta-block--event">
          <h4 class="saho-meta-block__title">Type of event</h4>
          <div class="saho-meta-block__val">{{ content.field_type_of_event }}</div>
        </section>
      {% endif %}

      {# Display file uploads if available #}
      {% if content.field_file_upload %}
        <section class="saho-meta-block saho-meta-block--event">
          <h4 class="saho-meta-block__title">Downloads</h4>
          <div class="saho-meta-block__val">{{ content.field_file_upload }}</div>
        </section>
      {% endif %}

      {# Display parent field if available #}
      {% if content.field_parent %}
        <section class="saho-meta-block saho-meta-block--event">
          <h4 class="saho-meta-block__title">Related</h4>
          <div class="saho-meta-block__val">{{ content.field_parent }}</div>
        </section>
      {% endif %}

    </aside>
    {% endif %}

  </div>

</article>
