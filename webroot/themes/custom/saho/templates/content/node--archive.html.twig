{#
/**
 * @file
 * Custom SAHO node template for Archive content type.
 *
 * Title is handled globally and not rendered here.
 * Layout Builder is disabled - fields are output directly via Twig.
 */
#}

{# Variable to track if sidebar has content #}
{% set sidebar_has_content = false %}

<article{{ attributes.addClass('saho-article-wrapper') }}>

  {# 2027 "Open Record" record header (typed tab + display ref + status + key fields). #}
  {% if record is defined %}
    {{ include('saho:saho-record-header', {
      type: record.type,
      reference: record.reference,
      status: record.status,
      kicker: record.kicker,
      title: record.title,
      facts: record.facts,
    }, with_context = false) }}
  {% endif %}

  {# The record toolbar rides directly under the key-field strip (R3 #476). #}
  {% if record_toolbar is defined %}
    {{ include('saho:saho-record-toolbar', record_toolbar|merge({
      connections_count: record_related.tabs is defined ? record_related.tabs|reduce((c, t) => c + t.count, 0) : 0,
    }), with_context = false) }}
  {% endif %}

  <div class="saho-article-grid">

    {# LEFT: Main content column #}
    <div class="saho-main-content">

      {# field_feature_banner does not exist on the archive bundle (config/sync:
         article/biography/place only), so the old banner branch was dead. The
         lead image is the Open Record duotone image-credit figure (S3). #}
      {% if record_image.src is defined and record_image.src %}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}


      {# Uploaded documents. PDFs get the inline preview + download; every other
         uploaded file (docx, audio, images, etc.) gets a download affordance so
         readers always have access to the document (R3). #}
      {% if node.field_file_upload.entity %}
        {% set pdf_files = node.field_file_upload|filter(item => item.entity and item.entity.filemime.value == 'application/pdf') %}
        {% set other_files = node.field_file_upload|filter(item => item.entity and item.entity.filemime.value != 'application/pdf') %}

        {% for item in pdf_files %}
          {% set file_uri = item.entity.uri.value %}
          <div class="saho-pdf-container">
            <h3>{{ 'Document Preview'|t }}</h3>
            {# An <iframe> renders the browser's built-in PDF viewer far more
               reliably inline than <object> (whose "unsupported" fallback fires
               even in capable browsers); the download button below is the
               always-available safety net. #}
            <div class="saho-pdf-viewer">
              <iframe class="saho-pdf-frame"
                      src="{{ file_url(file_uri) }}#view=FitH"
                      title="{{ 'Document preview: @title'|t({'@title': node.label}) }}"
                      width="100%"
                      height="820"
                      loading="lazy">
              </iframe>
            </div>
            <div class="saho-pdf-download mt-2">
              {% include 'saho:saho-button' with {
                text: 'Download PDF'|t,
                url: file_url(file_uri),
                variant: 'primary',
                size: 'medium',
                attributes: {
                  download: true
                }
              } %}
            </div>
          </div>
        {% endfor %}

        {% if other_files|length %}
          <div class="saho-page-attachments">
            <h3 class="saho-page-attachments__title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
              </svg>
              {{ 'Downloads'|t }}
            </h3>
            <ul class="saho-page-attachments__list">
              {% for item in other_files %}
                {% set ext = item.entity.filename.value|split('.')|last|lower %}
                <li class="saho-page-attachments__item saho-page-attachments__item--{{ ext }}">
                  <a href="{{ file_url(item.entity.uri.value) }}"
                     class="saho-page-attachments__link"
                     target="_blank"
                     rel="noopener noreferrer"
                     download>
                    <span class="saho-page-attachments__ext">{{ ext|upper }}</span>
                    {% if item.description %}
                      <span class="saho-page-attachments__description">{{ item.description }}</span>
                    {% else %}
                      <span class="saho-page-attachments__filename">{{ item.entity.filename.value }}</span>
                    {% endif %}
                    {% if item.entity.filesize.value %}
                      <span class="saho-page-attachments__size">
                        {% if item.entity.filesize.value > 1048576 %}
                          {{ (item.entity.filesize.value / 1048576)|round(1) }} MB
                        {% else %}
                          {{ (item.entity.filesize.value / 1024)|round(0) }} KB
                        {% endif %}
                      </span>
                    {% endif %}
                    <svg class="saho-page-attachments__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endif %}

      {# Summary / abstract (curator-written synopsis), above the body. #}
      {% if record_summary %}
        <section class="saho-record-summary saho-meta-block saho-meta-block--archive">
          <h4 class="saho-meta-block__title">{{ record_summary.heading|t }}</h4>
          <div class="saho-record-summary__body">{{ record_summary.body }}</div>
        </section>
      {% endif %}

      {% if content.body %}
        <div class="saho-article-body">
          {{ content.body }}
        </div>
      {% endif %}

      {% if content.field_highlight %}
        <div class="saho-highlight">
          {{ content.field_highlight }}
        </div>
      {% endif %}

      {# Render remaining fields not already shown manually #}
      {{ content|without(
        'body',
        'field_highlight',
        'field_further_reading',
        'field_archive_image',
        'field_node_image_caption',
        'field_ref_str',
        'field_african_country',
        'field_media_library_type',
        'field_archive_page_feature',
        'field_feature_parent',
        'field_home_page_feature',
        'field_image',
        'field_references_saho_source',
        'field_author',
        'field_contributor',
        'field_editors',
        'field_copyright',
        'field_description',
        'field_publication_date_archive',
        'field_archive_publication_date',
        'field_publication_place',
        'field_publication_title',
        'field_publishers',
        'field_subtitle',
        'field_synopsis',
        'field_source',
        'field_venue',
        'field_language',
        'field_isbn',
        'field_file_upload',
        'field_link_url',
        'field_link_title',
        'field_link_attributes',
        'field_navigation_links_placehold',
        'sharing_buttons',
        'comment'
      ) }}

      {# Provenance: "How we know this" from field_ref_str (S3). #}
      {% if record_provenance %}
        {{ include('saho:saho-provenance-block', record_provenance, with_context = false) }}
      {% endif %}

      {# Cite this entry (Harvard / APA / Oxford, from CitationService). #}
      {% if record_citation %}
        {{ include('saho:saho-citation', record_citation, with_context = false) }}
      {% endif %}

      {# The record foot (R3 #480/#477): one quiet supporter line, then
         reader contributions - after the record, never inside it. #}
      {# Open Record reading list: derived related records (siblings, shared
         topics, popular) - the record's onward-reading engine. #}
      {% if record_reading %}
        {{ include('saho:saho-reading-list', { title: 'Further reading'|t, items: record_reading }, with_context = false) }}
      {% endif %}

      <p class="saho-record-support">
        {{ 'SAHO is free because readers fund it.'|t }}
        <a href="/donate">{{ 'Donate'|t }} &rarr;</a>
      </p>
      {{ content.comment ?? '' }}

      {# Sequential flow within the collection: walk item to item without
         returning to the index. #}
      {% if record_collection_nav %}
        <nav class="saho-collection-nav" aria-label="Collection navigation">
          {% if record_collection_nav.prev %}
            <a class="saho-collection-nav__link" href="{{ record_collection_nav.prev.href }}"
               title="{{ record_collection_nav.prev.label }}">&#8592; {{ record_collection_nav.prev.ref }}</a>
          {% endif %}
          {% if record_collection_nav.prev and record_collection_nav.next %}
            <span class="saho-collection-nav__sep" aria-hidden="true">&#183;</span>
          {% endif %}
          {% if record_collection_nav.next %}
            <a class="saho-collection-nav__link" href="{{ record_collection_nav.next.href }}"
               title="{{ record_collection_nav.next.label }}">{{ record_collection_nav.next.ref }} &#8594;</a>
          {% endif %}
        </nav>
      {% endif %}

    </div>

    {# RIGHT: Sidebar (the Open Record rail - S3) #}
    {# No field_feature_banner on archive records, so the lead image always
       stays in the main column - there is no rail-image branch to gate here. #}
    {% if record_meta or record_meta_publication or record_related or record_further %}
      {% set sidebar_has_content = true %}
    {% endif %}

    {% if sidebar_has_content %}
    <aside class="saho-article-sidebar">

      {# Archive record: the structured publication fields. #}
      {% if record_meta %}
        {{ include('saho:saho-metadata-block', record_meta, with_context = false) }}
      {% endif %}

      {# Publication: the bibliographic record (publisher, ISBN, edition). #}
      {% if record_meta_publication %}
        {{ include('saho:saho-metadata-block', record_meta_publication, with_context = false) }}
      {% endif %}

      {# Cross-references: typed entity relations. #}
      {% if record_related %}
        {{ include('saho:saho-related-tabs', record_related, with_context = false) }}
      {% endif %}

      {# Further reading (kept crawlable). #}
      {% if record_further %}
        <section class="saho-meta-block saho-meta-block--archive">
          <h4 class="saho-meta-block__title">{{ 'Further reading'|t }}</h4>
          <div class="saho-meta-block__val">{{ record_further }}</div>
        </section>
      {% endif %}

      {# No Classification box: field_media_library_type already renders as
         the FORMAT row in Record details (record_meta), and
         field_archive_page_feature is an internal curation flag. #}

      {# Collection membership renders as the PART OF row in Record
         details (record_meta) - no legacy Related Content box. #}

      {# SAHO source references (archive-specific surface). #}
      {% if node.field_references_saho_source.value %}
        <div class="saho-references">
          <div class="saho-saho-sources">
            <h5>{{ 'SAHO Sources'|t }}</h5>
            {# Render through the field text format (.processed) so its filters
               strip scripts and event-handler/javascript: attributes; striptags
               alone kept dangerous attributes on allowed tags. #}
            {{ node.field_references_saho_source.0.processed|raw }}
          </div>
        </div>
      {% endif %}

      {# References now render as the main-column provenance-block (S3). #}

    </aside>
    {% endif %}

  </div>

</article>

