{#
/**
 * @file
 * Custom SAHO node template for Biography content type.
 *
 * Title is handled globally and not rendered here.
 * Layout Builder is disabled - fields are output directly via Twig.
 */
#}

{# Variable to track if sidebar has content #}
{% set sidebar_has_content = false %}

{# Related-cards footer renders .saho-button as static spans; ensure its CSS loads. #}
{{ attach_library('saho/saho-button') }}

{# Macro: enhanced suggested-reading cards (shared markup with article template). #}
{% macro suggested_reading_section(suggested_reading) %}
  <div class="saho-context-sections saho-context-bottom saho-suggested-reading-enhanced">
    <h3>Related Content & Topics</h3>

    {% for section_title, items in suggested_reading %}
      <div class="saho-related-content-section">
        <h4>{{ section_title }}</h4>
        <div class="saho-cards-grid">
          {% for item in items %}
            {% set entity = item.entity %}
            {% set image_url = null %}

{# Get image URL based on content type and available fields #}
            {% set bundle = entity.bundle %}

            {# Content-type specific image field priority #}
            {% if bundle == 'biography' %}
              {% if entity.field_bio_pic.entity %}
                {% set image_url = file_url(entity.field_bio_pic.entity.uri.value) %}
                {% set image_alt = entity.field_bio_pic.alt %}
              {% elseif entity.field_feature_banner.entity %}
                {% set image_url = file_url(entity.field_feature_banner.entity.uri.value) %}
                {% set image_alt = entity.field_feature_banner.alt %}
              {% endif %}

            {% elseif bundle == 'article' %}
              {% if entity.field_article_image.entity %}
                {% set image_url = file_url(entity.field_article_image.entity.uri.value) %}
                {% set image_alt = entity.field_article_image.alt %}
              {% elseif entity.field_feature_banner.entity %}
                {% set image_url = file_url(entity.field_feature_banner.entity.uri.value) %}
                {% set image_alt = entity.field_feature_banner.alt %}
              {% endif %}

            {% elseif bundle == 'archive' %}
              {% if entity.field_archive_image.entity %}
                {% set image_url = file_url(entity.field_archive_image.entity.uri.value) %}
                {% set image_alt = entity.field_archive_image.alt %}
              {% elseif entity.field_image.entity %}
                {% set image_url = file_url(entity.field_image.entity.uri.value) %}
                {% set image_alt = entity.field_image.alt %}
              {% endif %}

            {% elseif bundle == 'place' %}
              {% if entity.field_place_image.entity %}
                {% set image_url = file_url(entity.field_place_image.entity.uri.value) %}
                {% set image_alt = entity.field_place_image.alt %}
              {% elseif entity.field_feature_banner.entity %}
                {% set image_url = file_url(entity.field_feature_banner.entity.uri.value) %}
                {% set image_alt = entity.field_feature_banner.alt %}
              {% endif %}

            {% elseif bundle == 'event' %}
              {% if entity.field_event_image.entity %}
                {% set image_url = file_url(entity.field_event_image.entity.uri.value) %}
                {% set image_alt = entity.field_event_image.alt %}
              {% elseif entity.field_tdih_image.entity %}
                {% set image_url = file_url(entity.field_tdih_image.entity.uri.value) %}
                {% set image_alt = entity.field_tdih_image.alt %}
              {% endif %}

            {% else %}
              {# Fallback for other content types #}
              {% if entity.field_image.entity %}
                {% set image_url = file_url(entity.field_image.entity.uri.value) %}
                {% set image_alt = entity.field_image.alt %}
              {% elseif entity.field_article_image.entity %}
                {% set image_url = file_url(entity.field_article_image.entity.uri.value) %}
                {% set image_alt = entity.field_article_image.alt %}
              {% elseif entity.field_feature_banner.entity %}
                {% set image_url = file_url(entity.field_feature_banner.entity.uri.value) %}
                {% set image_alt = entity.field_feature_banner.alt %}
              {% endif %}
            {% endif %}

            <div class="saho-card">
              <a href="{{ path('entity.node.canonical', {'node': entity.id()}) }}" class="saho-card-link">
                {% if image_url %}
                <div class="saho-card-image">
                  <img src="{{ image_url }}" alt="{{ image_alt }}" loading="lazy" decoding="async">
                </div>
                {% endif %}
                <div class="saho-card-content">
                  <h5 class="saho-card-title">{{ entity.label }}</h5>
                  {% if entity.field_synopsis.value %}
                    <p class="saho-card-description">{{ entity.field_synopsis.value|striptags|truncate(120) }}</p>
                  {% elseif entity.body.value %}
                    <p class="saho-card-description">{{ entity.body.value|striptags|truncate(120) }}</p>
                  {% endif %}
                  <div class="saho-card-footer">
                    <span class="saho-button saho-button--primary saho-button--small saho-button--with-icon">
                      <span class="saho-button__text">Read More</span>
                      <svg class="saho-button__icon saho-button__icon--arrow-right" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>
{% endmacro %}

{% import _self as suggested %}

<article{{ attributes.addClass('saho-article-wrapper') }}>

  {# 2027 "Open Record" record header (typed tab + display ref + status + key fields). #}
  {% if record is defined %}
    {{ include('saho:saho-record-header', {
      type: record.type,
      reference: record.reference,
      status: record.status,
      kicker: record.kicker,
      title: record.title,
      facts: record.facts,
    }, with_context = false) }}
  {% endif %}

  {# The state's own banning / incarceration paperwork, rendered as evidence. #}
  {% if record.detention.banning is defined or record.detention.prison is defined %}
    {{ include('saho:saho-detention-record', {
      banning: record.detention.banning|default(null),
      prison: record.detention.prison|default(null),
    }, with_context = false) }}
  {% endif %}

  <div class="saho-article-grid">

    {# LEFT: Main content column #}
    <div class="saho-main-content">

      {% if node.field_feature_banner.entity %}
        <div class="saho-feature-banner">
          <img
            src="{{ file_url(node.field_feature_banner.entity.uri.value) }}"
            alt="{{ node.field_feature_banner.alt }}"
            class="saho-feature-banner-image"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          >
        </div>
      {% elseif record_image.src is defined and record_image.src %}
        {# Open Record portrait: duotone image-credit figure (S3). #}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% elseif biography_portrait_fallback_url %}
        <div class="saho-feature-banner">
          <img src="{{ biography_portrait_fallback_url }}" alt="{{ node.title.value }} portrait" class="saho-feature-banner-image" loading="eager" decoding="async" />
        </div>
      {% endif %}

      <div class="saho-article-meta">
        {% if node.getCreatedTime() %}
          <span>Published {{ node.getCreatedTime()|date("j F Y") }}</span>
        {% endif %}
        {% if node.getChangedTime() != node.getCreatedTime() %}
          <span>Updated {{ node.getChangedTime()|date("j F Y") }}</span>
        {% endif %}
        <div class="saho-tools-wrapper">
          {% if citation_button %}
            <div class="saho-citation-wrapper">
              {{ citation_button }}
            </div>
          {% endif %}
          {% if sharing_button %}
            <div class="saho-sharing-wrapper">
              {{ sharing_button }}
            </div>
          {% endif %}
        </div>
      </div>

      {# Personal information now lives in the rail metadata-block (S3). #}

      {% if content.body %}
        <div class="saho-article-body">
          {# Remove the label by accessing the content directly #}
          {{ content.body.0 }}
        </div>
      {% endif %}

      {% if content.field_highlight %}
        <div class="saho-highlight">
          {{ content.field_highlight }}
        </div>
      {% endif %}

      {# Render remaining fields not already shown manually #}
      {{ content|without(
        'body',
        'field_highlight',
        'field_further_reading',
        'field_bio_pic',
        'field_node_image_caption',
        'field_ref_str',
        'field_african_country',
        'field_archive_page_feature',
        'field_feature_parent',
        'field_parent',
        'field_feature_tag',
        'field_feature_banner',
        'field_home_page_feature',
        'field_home_page_feature_africa_s',
        'field_home_page_feature_biograph',
        'field_people_category',
        'field_people_level3_cat',
        'field_people_related_tab',
        'field_organizations_related_tab',
        'field_topics_related_tab',
        'field_timelines_related_tab',
        'field_gallery_tag',
        'field_synopsis',
        'field_title',
        'field_firstname',
        'field_middlename',
        'field_lastnamebio',
        'field_drupal_birth_date',
        'field_dob',
        'field_birth_location',
        'field_drupal_death_date',
        'field_dod',
        'field_death_location',
        'field_cod',
        'field_position',
        'field_affiliation',
        'field_position_held',
        'field_position_format',
        'field_member_of_organisation',
        'field_gender',
        'field_race',
        'field_article_author',
        'field_article_editors',
        'field_editors',
        'sharing_buttons'
      ) }}

      {# Provenance: "How we know this" from field_ref_str (S3). #}
      {% if record_provenance %}
        {{ include('saho:saho-provenance-block', record_provenance, with_context = false) }}
      {% endif %}

      {# Cite this entry (Harvard / APA / Oxford, from CitationService). #}
      {% if record_citation %}
        {{ include('saho:saho-citation', record_citation, with_context = false) }}
      {% endif %}

    </div>

    {# RIGHT: Sidebar (the Open Record rail - S3) #}
    {% if record_meta or record_related or record_further or accordion_views is not empty or (node.field_feature_banner.entity and record_image.src is defined and record_image.src) %}
      {% set sidebar_has_content = true %}
    {% endif %}

    {% if sidebar_has_content %}
    <aside class="saho-article-sidebar">

      {# Portrait moves to the rail when a feature banner leads the main column. #}
      {% if node.field_feature_banner.entity and record_image.src is defined and record_image.src %}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}

      {# Vital record: the structured biography fields. #}
      {% if record_meta %}
        {{ include('saho:saho-metadata-block', record_meta, with_context = false) }}
      {% endif %}

      {# Cross-references: typed entity relations. #}
      {% if record_related %}
        {{ include('saho:saho-related-tabs', record_related, with_context = false) }}
      {% endif %}

      {# Further reading (kept crawlable). #}
      {% if record_further %}
        <section class="saho-meta-block saho-meta-block--biography">
          <h4 class="saho-meta-block__title">Further reading</h4>
          <div class="saho-meta-block__val">{{ record_further }}</div>
        </section>
      {% endif %}

      {# Custom Accordion for feature_children views #}
      {% if accordion_views is not empty %}
        <div class="saho-accordion mb-5" id="sahoFeatureAccordion">
          {% for item in accordion_views %}
            <div class="saho-accordion-item">
              <h4 class="saho-accordion-header">
                <button class="saho-accordion-button {% if not loop.first %}collapsed{% endif %}"
                        type="button"
                        aria-expanded="{{ loop.first ? 'true' : 'false' }}"
                        aria-controls="collapse-{{ item.id }}"
                        data-target="#collapse-{{ item.id }}">
                  {{ item.title }}
                </button>
              </h4>
              <div id="collapse-{{ item.id }}"
                   class="saho-accordion-collapse {% if loop.first %}show{% endif %}"
                   aria-hidden="{{ loop.first ? 'false' : 'true' }}">
                <div class="saho-accordion-body">
                  {{ drupal_view(item.view, item.block, node.id()) }}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {# References now render as the main-column provenance-block (S3). #}

    </aside>
    {% endif %}

  </div>

</article>

{# Enhanced suggested reading - crawlable contextual cards (~6-12 related items). #}
{% if suggested_reading is defined and suggested_reading is not empty %}
  {{ suggested.suggested_reading_section(suggested_reading) }}
{% endif %}

{# Related Content section - Feature Parent Links displayed as cards #}
{% if grouped_feature_parents is not empty %}
  {% set accordion_categories = [] %}
  {% if accordion_views is not empty %}
    {% for item in accordion_views %}
      {% set accordion_categories = accordion_categories|merge([item.id]) %}
    {% endfor %}
  {% endif %}

  {# Only show categories that don't already appear in accordion views #}
  {% set has_feature_parents_to_display = false %}
  {% for category, items in grouped_feature_parents %}
    {% if category not in accordion_categories %}
      {% set has_feature_parents_to_display = true %}
    {% endif %}
  {% endfor %}

  {% if has_feature_parents_to_display %}
    <div class="saho-context-sections saho-context-bottom">
      <h3>Related Content</h3>

      {% for category, items in grouped_feature_parents %}
        {% if category not in accordion_categories %}
          <div class="saho-related-content-section">
            <h4>{{ category|capitalize }}</h4>
            <div class="saho-cards-grid">
              {% for referenced_node in items %}
                {% set bundle = referenced_node.bundle %}
                {% set image_url = null %}
                {% set image_alt = '' %}

                {# Get image based on content type #}
                {% if bundle == 'biography' %}
                  {% if referenced_node.field_bio_pic.entity %}
                    {% set image_url = file_url(referenced_node.field_bio_pic.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_bio_pic.alt %}
                  {% elseif referenced_node.field_feature_banner.entity %}
                    {% set image_url = file_url(referenced_node.field_feature_banner.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_feature_banner.alt %}
                  {% endif %}
                {% elseif bundle == 'article' %}
                  {% if referenced_node.field_article_image.entity %}
                    {% set image_url = file_url(referenced_node.field_article_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_article_image.alt %}
                  {% elseif referenced_node.field_feature_banner.entity %}
                    {% set image_url = file_url(referenced_node.field_feature_banner.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_feature_banner.alt %}
                  {% endif %}
                {% elseif bundle == 'archive' %}
                  {% if referenced_node.field_archive_image.entity %}
                    {% set image_url = file_url(referenced_node.field_archive_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_archive_image.alt %}
                  {% elseif referenced_node.field_image.entity %}
                    {% set image_url = file_url(referenced_node.field_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_image.alt %}
                  {% endif %}
                {% elseif bundle == 'place' %}
                  {% if referenced_node.field_place_image.entity %}
                    {% set image_url = file_url(referenced_node.field_place_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_place_image.alt %}
                  {% elseif referenced_node.field_feature_banner.entity %}
                    {% set image_url = file_url(referenced_node.field_feature_banner.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_feature_banner.alt %}
                  {% endif %}
                {% elseif bundle == 'event' %}
                  {% if referenced_node.field_event_image.entity %}
                    {% set image_url = file_url(referenced_node.field_event_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_event_image.alt %}
                  {% elseif referenced_node.field_tdih_image.entity %}
                    {% set image_url = file_url(referenced_node.field_tdih_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_tdih_image.alt %}
                  {% endif %}
                {% else %}
                  {# Fallback for other content types #}
                  {% if referenced_node.field_image.entity %}
                    {% set image_url = file_url(referenced_node.field_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_image.alt %}
                  {% elseif referenced_node.field_article_image.entity %}
                    {% set image_url = file_url(referenced_node.field_article_image.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_article_image.alt %}
                  {% elseif referenced_node.field_feature_banner.entity %}
                    {% set image_url = file_url(referenced_node.field_feature_banner.entity.uri.value) %}
                    {% set image_alt = referenced_node.field_feature_banner.alt %}
                  {% endif %}
                {% endif %}

                <div class="saho-card">
                  <a href="{{ path('entity.node.canonical', {'node': referenced_node.id}) }}" class="saho-card-link">
                    {% if image_url %}
                      <div class="saho-card-image">
                        <img src="{{ image_url }}" alt="{{ image_alt }}" loading="lazy">
                      </div>
                    {% endif %}
                    <div class="saho-card-content">
                      <h5 class="saho-card-title">{{ referenced_node.label }}</h5>
                      {% if referenced_node.field_synopsis.value %}
                        <p class="saho-card-description">{{ referenced_node.field_synopsis.value|striptags|truncate(120) }}</p>
                      {% elseif referenced_node.body.value %}
                        <p class="saho-card-description">{{ referenced_node.body.value|striptags|truncate(120) }}</p>
                      {% endif %}
                      <div class="saho-card-footer">
                        <span class="saho-button saho-button--card-action saho-button--small">
                          <span class="saho-button__text">Read More</span>
                          <svg class="saho-button__icon saho-button__icon--arrow-right" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
                          </svg>
                        </span>
                      </div>
                    </div>
                  </a>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
{% endif %}

{# The Context & Related Information accordion is retired: entity relations
   render in the rail related-tabs; further reading is a rail block (S3). #}
