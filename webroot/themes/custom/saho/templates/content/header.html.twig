{#
/**
 * @file
 * SAHO Header — single fixed bar (60px, zero CLS).
 *
 * ≥1200px: logo — nav items — actions  (one row)
 * <1200px: logo — actions — hamburger  (nav in offcanvas)
 *
 * Body offset: saho-header-wrapper padding-top: 60px — static CSS, no JS.
 *
 * @see saho_preprocess_header()
 */
#}
<header class="saho-header-wrapper" role="banner">

  {# ── PRIMARY BAR: fixed 60px, single row ── #}
  <div class="saho-primary-bar">

    <a href="{{ path('<front>') }}" class="saho-logo" aria-label="South African History Online — Homepage">
      <img src="/themes/custom/saho/logo.svg" alt="SAHO" width="44" height="44">
      <span class="saho-logo-wordmark" aria-hidden="true">
        <span class="saho-logo-wordmark__line1">South African</span>
        <span class="saho-logo-wordmark__line2">History Online</span>
      </span>
    </a>

    {# Desktop inline nav — visible ≥1200px, hidden below (hamburger takes over) #}
    <nav class="saho-primary-nav" role="navigation" aria-label="Main navigation">
      {{ drupal_menu('main') }}
    </nav>

    <div class="saho-primary-actions">

      {# Search — opens modal at ALL viewport sizes #}
      <button class="saho-icon-btn"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#mobileSearchModal"
              aria-label="Search South African History Online">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
        </svg>
      </button>

      {# Tools dropdown — icon only in primary bar #}
      <div class="dropdown">
        <button class="saho-icon-btn dropdown-toggle"
                type="button"
                id="toolsDropdown"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="Tools — cite, share, print">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
          </svg>
        </button>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="toolsDropdown">
          <li>
            <button type="button" class="dropdown-item d-flex align-items-center" data-citation-trigger="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M12 12a1 1 0 0 0 1-1V8.558a1 1 0 0 0-1-1h-1.388c0-.351.021-.703.062-1.054.062-.372.166-.703.31-.992.145-.29.331-.517.559-.683.227-.186.516-.279.868-.279V3c-.579 0-1.085.124-1.52.372a3.322 3.322 0 0 0-1.085.992 4.92 4.92 0 0 0-.62 1.458A7.712 7.712 0 0 0 9 7.558V11a1 1 0 0 0 1 1h2Zm-6 0a1 1 0 0 0 1-1V8.558a1 1 0 0 0-1-1H4.612c0-.351.021-.703.062-1.054.062-.372.166-.703.31-.992.145-.29.331-.517.559-.683.227-.186.516-.279.868-.279V3c-.579 0-1.085.124-1.52.372a3.322 3.322 0 0 0-1.085.992 4.92 4.92 0 0 0-.62 1.458A7.712 7.712 0 0 0 3 7.558V11a1 1 0 0 0 1 1h2Z"/>
              </svg>
              Cite This Page
            </button>
          </li>
          <li>
            <button type="button" class="dropdown-item d-flex align-items-center" data-sharing-trigger="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.499 2.499 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5zm-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
              </svg>
              Share
            </button>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center" href="javascript:window.print()">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/>
                <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2H5zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4V3zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2H5zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1z"/>
              </svg>
              Print
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center" href="/saho-timeline">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8.515 1.019A7 7 0 0 0 8 1V0a8 8 0 0 1 .589.022l-.074.997zm2.004.45a7.003 7.003 0 0 0-.985-.299l.219-.976c.383.086.76.2 1.126.342l-.36.933zm1.37.71a7.01 7.01 0 0 0-.439-.27l.493-.87a8.025 8.025 0 0 1 .979.654l-.615.789a6.996 6.996 0 0 0-.418-.302zm1.834 1.79a6.99 6.99 0 0 0-.653-.796l.724-.69c.27.285.52.59.747.91l-.818.576zm.744 1.352a7.08 7.08 0 0 0-.214-.468l.893-.45a7.976 7.976 0 0 1 .45 1.088l-.95.313a7.023 7.023 0 0 0-.179-.483zm.53 2.507a6.991 6.991 0 0 0-.1-1.025l.985-.17c.067.386.106.778.116 1.17l-1 .025zm-.131 1.538c.033-.17.06-.339.081-.51l.993.123a7.957 7.957 0 0 1-.23 1.155l-.964-.267c.046-.165.086-.332.12-.501zm-.952 2.379c.184-.29.346-.594.486-.908l.914.405c-.16.36-.345.706-.555 1.038l-.845-.535zm-.964 1.205c.122-.122.239-.248.35-.378l.758.653a8.073 8.073 0 0 1-.401.432l-.707-.707z"/>
                <path d="M8 1a7 7 0 1 0 4.95 11.95l.707.707A8.001 8.001 0 1 1 8 0v1z"/>
                <path d="M7.5 3a.5.5 0 0 1 .5.5v5.21l3.248 1.856a.5.5 0 0 1-.496.868l-3.5-2A.5.5 0 0 1 7 9V3.5a.5.5 0 0 1 .5-.5z"/>
              </svg>
              Timeline Explorer
            </a>
          </li>
        </ul>
      </div>

      {# Donate button #}
      <a href="/donate" class="saho-donate-btn" aria-label="Donate to South African History Online">
        <span class="saho-donate-icon" aria-hidden="true">♥</span>
        <span class="saho-donate-label">Donate</span>
      </a>

      {# Hamburger — always mobile; desktop only when nav bar has scrolled away #}
      <button class="saho-hamburger-btn"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#sahoMobileMenu"
              aria-label="Open navigation menu">
        <span class="saho-hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

    </div>
  </div>


</header>

{# ── SEARCH MODAL (all viewport sizes) ── #}
<div class="modal fade saho-search-modal" id="mobileSearchModal" tabindex="-1" aria-labelledby="mobileSearchLabel" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title" id="mobileSearchLabel">Search SAHO</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-0">
        <form action="/search" method="get" role="search">
          <div class="input-group input-group-lg">
            <input type="search"
                   name="search_api_fulltext"
                   placeholder="Search South African history..."
                   class="form-control"
                   aria-label="Search"
                   autofocus>
            <button type="submit" class="btn btn-primary">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
              </svg>
              Search
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

{# ── MOBILE MENU OFFCANVAS ── #}
<div class="offcanvas offcanvas-start saho-mobile-menu"
     tabindex="-1"
     id="sahoMobileMenu"
     aria-labelledby="sahoMobileMenuLabel">

  <div class="offcanvas-header">
    <div class="d-flex align-items-center">
      <img src="/themes/custom/saho/logo.svg" alt="SAHO" class="saho-mobile-logo me-2" width="40" height="40">
      <h5 id="sahoMobileMenuLabel" class="mb-0">Menu</h5>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>

  <div class="offcanvas-body">
    {# Mobile Search #}
    <form action="/search" method="get" class="saho-mobile-search mb-4" role="search">
      <div class="input-group">
        <input type="search" name="search_api_fulltext" placeholder="Search history..." class="form-control" aria-label="Search">
        <button type="submit" class="btn btn-outline-secondary text-gold">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
          </svg>
        </button>
      </div>
    </form>

    {# Mobile Navigation — same drupal_menu() → menu--main.html.twig → saho:nav. #}
    {# CSS in .saho-mobile-nav context makes it vertical with tap-friendly links. #}
    <nav class="saho-mobile-nav" role="navigation" aria-label="Mobile navigation">
      {{ drupal_menu('main') }}
    </nav>

  </div>
</div>

{# Modals are created by saho_tools module - removed duplicate definitions #}
