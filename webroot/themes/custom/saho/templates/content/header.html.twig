{#
/**
 * @file
 * SAHO Header - Open Record 2027 sticky bar.
 *
 * ≥1024px: wordmark - nav items - actions  (one row, sticky)
 * <1024px: wordmark - actions - hamburger  (nav in offcanvas)
 *
 * In-flow sticky header - no body offset needed, zero CLS.
 *
 * @see saho_preprocess_header()
 */
#}
{{ attach_library('saho/saho-search-field') }}
{# Skip link: first focusable element on every page (this header is included by
   all page templates). Bypasses the header/nav for keyboard and screen-reader
   users (WCAG 2.4.1). Visible only on focus; targets #main-content. #}
<a href="#main-content" class="visually-hidden-focusable saho-skip-link">{{ 'Skip to main content'|t }}</a>
<header class="saho-header-wrapper" role="banner">

  {# ── PRIMARY BAR: container-wide row on the sticky paper surface ── #}
  <div class="saho-primary-bar">

    <a href="{{ path('<front>') }}" class="saho-logo" aria-label="South African History Online - Homepage">
      <img src="/themes/custom/saho/logo.svg" alt="SAHO" width="44" height="44">
      <span class="saho-logo-wordmark" aria-hidden="true">
        <span class="saho-logo-wordmark__line1">South African</span>
        <span class="saho-logo-wordmark__line2">History Online</span>
        <span class="saho-logo-wordmark__tagline">The open record &middot; est. 1998</span>
      </span>
    </a>

    {# Desktop inline nav - visible ≥1024px, hidden below (hamburger takes over) #}
    <nav class="saho-primary-nav" role="navigation" aria-label="Main navigation">
      {{ drupal_menu('saho_primary') }}
    </nav>

    <div class="saho-primary-actions">

      {# Search - Open Record accent square, opens modal at ALL viewport sizes #}
      <button class="saho-search-glyph"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#mobileSearchModal"
              aria-label="Search South African History Online">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
          <circle cx="8.5" cy="8.5" r="6"></circle>
          <line x1="13" y1="13" x2="17.5" y2="17.5"></line>
        </svg>
      </button>

      {# Tools dropdown - icon only in primary bar #}
      <div class="dropdown">
        <button class="saho-icon-btn dropdown-toggle"
                type="button"
                id="toolsDropdown"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="Tools - cite, share, print">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
          </svg>
        </button>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="toolsDropdown">
          <li>
            <button type="button" class="dropdown-item d-flex align-items-center" data-sharing-trigger="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.499 2.499 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5zm-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
              </svg>
              Share
            </button>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center" href="javascript:window.print()">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/>
                <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2H5zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4V3zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2H5zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1z"/>
              </svg>
              Print
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center" href="/timeline">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" class="me-2" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M8.515 1.019A7 7 0 0 0 8 1V0a8 8 0 0 1 .589.022l-.074.997zm2.004.45a7.003 7.003 0 0 0-.985-.299l.219-.976c.383.086.76.2 1.126.342l-.36.933zm1.37.71a7.01 7.01 0 0 0-.439-.27l.493-.87a8.025 8.025 0 0 1 .979.654l-.615.789a6.996 6.996 0 0 0-.418-.302zm1.834 1.79a6.99 6.99 0 0 0-.653-.796l.724-.69c.27.285.52.59.747.91l-.818.576zm.744 1.352a7.08 7.08 0 0 0-.214-.468l.893-.45a7.976 7.976 0 0 1 .45 1.088l-.95.313a7.023 7.023 0 0 0-.179-.483zm.53 2.507a6.991 6.991 0 0 0-.1-1.025l.985-.17c.067.386.106.778.116 1.17l-1 .025zm-.131 1.538c.033-.17.06-.339.081-.51l.993.123a7.957 7.957 0 0 1-.23 1.155l-.964-.267c.046-.165.086-.332.12-.501zm-.952 2.379c.184-.29.346-.594.486-.908l.914.405c-.16.36-.345.706-.555 1.038l-.845-.535zm-.964 1.205c.122-.122.239-.248.35-.378l.758.653a8.073 8.073 0 0 1-.401.432l-.707-.707z"/>
                <path d="M8 1a7 7 0 1 0 4.95 11.95l.707.707A8.001 8.001 0 1 1 8 0v1z"/>
                <path d="M7.5 3a.5.5 0 0 1 .5.5v5.21l3.248 1.856a.5.5 0 0 1-.496.868l-3.5-2A.5.5 0 0 1 7 9V3.5a.5.5 0 0 1 .5-.5z"/>
              </svg>
              Timeline Explorer
            </a>
          </li>
        </ul>
      </div>

      {# Donate button #}
      <a href="/donate"
         class="saho-donate-btn"
         aria-label="Donate to South African History Online">
        <span class="saho-donate-icon" aria-hidden="true">♥</span>
        <span class="saho-donate-label">Donate</span>
      </a>

      {# Hamburger - always mobile; desktop only when nav bar has scrolled away #}
      <button class="saho-hamburger-btn"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#sahoMobileMenu"
              aria-label="Open navigation menu">
        <span class="saho-hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

    </div>
  </div>


</header>

{# ── SEARCH MODAL - Research Discovery Centre ── #}
<div class="modal fade saho-search-modal" id="mobileSearchModal" tabindex="-1" aria-labelledby="mobileSearchLabel" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen">
    <div class="modal-content">

      {# ── Hero zone ── #}
      <div class="saho-search-hero">

        <button type="button"
                class="saho-search-close"
                data-bs-dismiss="modal"
                aria-label="Close search">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
          </svg>
        </button>

        <p class="saho-search-eyebrow">South African History Online</p>
        <h2 class="saho-search-headline" id="mobileSearchLabel">Know your <em>history</em></h2>

        {# Open Record search field SDC - posts name="search_api_fulltext" by default.
           The wrapper id keeps search-enhancements.js recent-history capture working
           (submit events bubble up from the inner form). #}
        {% include 'saho:saho-search-field' with {
          attributes: create_attribute({ 'id': 'sahoSearchModalForm' }),
          size: 'lg',
          placeholder: 'Search articles, biographies, events…',
          input_id: 'saho-search-modal-input',
        } %}

        {# Live suggestions listbox (R3 #478), driven by search-suggest.js. #}
        <div class="saho-search-suggest" id="sahoSearchSuggest" role="listbox"
             aria-label="Search suggestions" hidden></div>

        {# Progressive disclosure to the full query builder (R3 #476). #}
        <p class="saho-search-advanced-link">
          <a href="/search/advanced">Advanced search &rarr;</a>
        </p>

        {# One count vocabulary (R3 #478): live index counts, exact numbers -
           archival institutions state exact holdings. #}
        {% if overlay_stats %}
        <div class="saho-search-stats" aria-hidden="true">
          {% for stat in overlay_stats %}
          <div class="saho-search-stat">
            <strong>{{ stat.value }}</strong>
            <span>{{ stat.label }}</span>
          </div>
          {% endfor %}
        </div>
        {% endif %}

      </div>{# /.saho-search-hero #}

      {# ── Discovery zone ── #}
      <div class="saho-search-discovery">

        {# Trending topics - curated fallback, JS replaces with real data #}
        <div class="saho-search-section saho-search-popular">
          <p class="saho-search-section-label">Trending topics</p>
          <div class="saho-search-chips" id="sahoPopularChips">
            <a href="/search?search_api_fulltext=Apartheid" class="saho-search-chip">Apartheid</a>
            <a href="/search?search_api_fulltext=Nelson+Mandela" class="saho-search-chip">Nelson Mandela</a>
            <a href="/search?search_api_fulltext=Freedom+Charter" class="saho-search-chip">Freedom Charter</a>
            <a href="/search?search_api_fulltext=Sharpeville" class="saho-search-chip">Sharpeville</a>
            <a href="/search?search_api_fulltext=Steve+Biko" class="saho-search-chip">Steve Biko</a>
            <a href="/search?search_api_fulltext=Anglo-Boer+War" class="saho-search-chip">Anglo-Boer War</a>
            <a href="/search?search_api_fulltext=Mandela" class="saho-search-chip">Mandela</a>
            <a href="/search?search_api_fulltext=Zulu" class="saho-search-chip">Zulu</a>
          </div>
        </div>

        {# Browse by era #}
        <div class="saho-search-section saho-search-eras">
          <p class="saho-search-section-label">Browse by era</p>
          <div class="saho-search-chips">
            <a href="/search?search_api_fulltext=pre-colonial" class="saho-search-chip--era">Pre-colonial</a>
            <a href="/search?search_api_fulltext=colonial" class="saho-search-chip--era">Colonial era</a>
            <a href="/search?search_api_fulltext=apartheid" class="saho-search-chip--era">Apartheid era</a>
            <a href="/search?search_api_fulltext=liberation+struggle" class="saho-search-chip--era">Liberation struggle</a>
            <a href="/search?search_api_fulltext=post-apartheid+1994" class="saho-search-chip--era">Post-1994</a>
            <a href="/search?search_api_fulltext=world+war+south+africa" class="saho-search-chip--era">World Wars</a>
          </div>
        </div>

        {# The archive is alive (R3 #478): the three newest records. #}
        {% if overlay_recent %}
        <div class="saho-search-section saho-search-latest">
          <p class="saho-search-section-label">Recently added to the record</p>
          <ul class="saho-search-latest__list">
            {% for row in overlay_recent %}
            <li class="saho-search-latest__row">
              <a href="{{ row.href }}">
                <span class="saho-search-latest__marker saho-type--{{ row.type }}" aria-hidden="true"></span>
                <span class="saho-search-latest__title">{{ row.title }}</span>
                <span class="saho-search-latest__added">Added {{ row.added }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        {# Explore by type #}
        <div class="saho-search-section saho-search-types">
          <p class="saho-search-section-label">Explore by type</p>
          <div class="saho-search-chips">
            <a href="/politics-society" class="saho-search-chip--type">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/></svg>
              Politics &amp; Society
            </a>
            <a href="/biographies" class="saho-search-chip--type">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/></svg>
              Biographies
            </a>
            <a href="/timeline" class="saho-search-chip--type">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71zm4 4.5a4 4 0 1 1-8 0 4 4 0 0 1 8 0M3.051 3.051A7 7 0 1 0 12.95 12.95 7 7 0 0 0 3.05 3.05z"/></svg>
              Timeline
            </a>
            <a href="/archives" class="saho-search-chip--type">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M0 2a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 1 12.5V5a1 1 0 0 1-1-1zm2 3v7.5A1.5 1.5 0 0 0 3.5 14h9a1.5 1.5 0 0 0 1.5-1.5V5zm13-3H1v2h14zM5 7.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5"/></svg>
              Archives
            </a>
            <a href="/classroom" class="saho-search-chip--type">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M8.211 2.047a.5.5 0 0 0-.422 0l-7.5 3.5a.5.5 0 0 0 .025.917l7.5 3a.5.5 0 0 0 .372 0L14 7.14V13a1 1 0 0 0-1 1v2h3v-2a1 1 0 0 0-1-1V6.739l.686-.275a.5.5 0 0 0 .025-.917zM8 8.46 1.758 5.965 8 3.052l6.242 2.913z"/><path d="M4.176 9.032a.5.5 0 0 0-.656.327l-.5 1.7a.5.5 0 0 0 .294.605l4.5 1.8a.5.5 0 0 0 .372 0l4.5-1.8a.5.5 0 0 0 .294-.605l-.5-1.7a.5.5 0 0 0-.656-.327L8 10.466z"/></svg>
              Classroom
            </a>
          </div>
        </div>

        {# Recent searches - populated from localStorage via JS #}
        <div class="saho-search-section saho-search-recent" id="sahoSearchRecent" hidden>
          <p class="saho-search-section-label">Recent searches</p>
          <div class="saho-search-chips" id="sahoSearchRecentChips"></div>
        </div>

      </div>{# /.saho-search-discovery #}

    </div>
  </div>
</div>

{# ── MOBILE MENU OFFCANVAS ── #}
<div class="offcanvas offcanvas-start saho-mobile-menu"
     tabindex="-1"
     id="sahoMobileMenu"
     aria-labelledby="sahoMobileMenuLabel">

  {# Hero header - dark gradient, logo + search in one zone #}
  <div class="offcanvas-header saho-mobile-menu-hero">

    <div class="saho-mobile-menu-toprow">
      <div class="d-flex align-items-center gap-2">
        <img src="/themes/custom/saho/logo.svg" alt="SAHO" class="saho-mobile-logo" width="36" height="36">
        <span class="saho-mobile-menu-label" id="sahoMobileMenuLabel">Menu</span>
      </div>
      <button type="button" class="saho-mobile-menu-close" data-bs-dismiss="offcanvas" aria-label="Close menu">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
        </svg>
      </button>
    </div>

    {# Open Record search field SDC - md size for the offcanvas hero #}
    {% include 'saho:saho-search-field' with {
      size: 'md',
      placeholder: 'Search the record…',
      input_id: 'saho-search-offcanvas-input',
    } %}

  </div>

  <div class="offcanvas-body">
    {# Mobile Navigation - same drupal_menu() → saho:nav as desktop. #}
    <nav class="saho-mobile-nav" role="navigation" aria-label="Mobile navigation">
      {{ drupal_menu('saho_primary') }}
    </nav>

    {# Secondary destinations (R3 #478): ruled mono group; Donate is the
       one solid row, pinned at the sheet foot. #}
    <nav class="saho-mobile-secondary" aria-label="More">
      <a class="saho-mobile-secondary__link" href="/featured">{{ 'Featured'|t }}</a>
      <a class="saho-mobile-secondary__link" href="/about-us">{{ 'About'|t }}</a>
      <a class="saho-mobile-secondary__link" href="/form/contribute">{{ 'Contribute'|t }}</a>
    </nav>
    <a class="saho-mobile-donate" href="{{ shop_donate_url ?? '/donate' }}">&hearts; {{ 'Donate'|t }}</a>
  </div>

</div>

{# Modals are created by saho_tools module - removed duplicate definitions #}
