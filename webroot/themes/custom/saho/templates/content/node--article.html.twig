{#
/**
 * @file
 * Custom SAHO node template.
 *
 * Title is handled globally and not rendered here.
 * Layout Builder is disabled - fields are output directly via Twig.
 */
#}

{# Variable to track if sidebar has content #}
{% set sidebar_has_content = false %}

{# Related-cards footer renders .saho-button as static spans; ensure its CSS loads. #}
{{ attach_library('saho/saho-button') }}

<article{{ attributes.addClass('saho-article-wrapper', chronology is defined and chronology ? 'saho-has-chronology' : '') }}>

  {# 2027 "Open Record" record header (typed tab + display ref + status + key fields). #}
  {% if record is defined %}
    {% set record_lead_mobile = (record_image.orientation is defined and record_image.orientation in ['portrait', 'square'] and not (node.hasField('field_feature_banner') and node.field_feature_banner.entity.uri.value)) ? record_image : {} %}
    {{ include('saho:saho-record-header', {
      type: record.type,
      reference: record.reference,
      status: record.status,
      kicker: record.kicker,
      title: record.title,
      facts: record.facts,
      image: record_lead_mobile,
    }, with_context = false) }}
  {% endif %}

  {# The record toolbar rides directly under the key-field strip (R3 #476). #}
  {% if record_toolbar is defined %}
    {{ include('saho:saho-record-toolbar', record_toolbar|merge({
      connections_count: record_related.tabs is defined ? record_related.tabs|reduce((c, t) => c + t.count, 0) : 0,
    }), with_context = false) }}
  {% endif %}

  <div class="saho-article-grid">

    {# LEFT: Main content column #}
    <div class="saho-main-content">

      {% if hero_banner_image %}
        {# Feature banner image (eager loading for LCP) #}
        <div class="saho-feature-banner">
          {{ hero_banner_image }}
        </div>
      {% elseif record_image.src is defined and record_image.src and not is_collection_head %}
        {# Open Record lead image: duotone image-credit figure (S3). #}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}


      {# Summary / abstract (curator-written synopsis), above the body. #}
      {% if record_summary %}
        <section class="saho-record-summary saho-meta-block saho-meta-block--article">
          <h2 class="saho-meta-block__title">{{ record_summary.heading|t }}</h2>
          <div class="saho-record-summary__body">{{ record_summary.body }}</div>
        </section>
      {% endif %}

      {% if content.body %}
        <div class="saho-article-body">
          {# Article contents page field integrated within body text like biography metadata #}
          {% if content.field_article_contents_page is defined and content.field_article_contents_page|render|trim %}
            <div class="saho-article-index">
              <h2>{{ 'Contents'|t }}</h2>
              <div class="saho-index-content">
                {{ content.field_article_contents_page }}
              </div>
            </div>
          {% endif %}

          {# Teacher quick-link to the interactive classroom presentations. #}
          {{ content.saho_classroom_presentations_cta }}

          {# Main body content: timeline-genre articles set their dated
             entries in the chronology register (saho_preprocess_node__article
             builds it; unparsed bodies fall through untouched). #}
          {% if chronology %}
            {{ include('saho:saho-chronology', chronology, with_context = false) }}
            {# Bridge to the interactive timeline app (R3 #477). #}
            <p class="saho-chron-bridge">
              <a href="/timeline">{{ 'Explore the full timeline'|t }} &rarr;</a>
            </p>
          {% else %}
            {{ content.body.0 }}
          {% endif %}
        </div>
      {% endif %}

      {% if content.field_tags is defined and content.field_tags|render|trim %}
        <div class="saho-tags">
          <h2>{{ 'Tags'|t }}</h2>
          <ul class="saho-tags-list">
            {% for item in node.field_tags %}
              <li>
                <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': item.target_id}) }}">
                  {{ item.entity.label }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {% if content.field_highlight %}
        <div class="saho-highlight">
          {{ content.field_highlight }}
        </div>
      {% endif %}

      {# Render remaining fields not already shown manually #}
      {{ content|without(
        'body',
        'saho_classroom_presentations_cta',
        'field_highlight',
        'field_further_reading',
        'field_article_image',
        'field_node_image_caption',
        'field_ref_str',
        'field_african_country',
        'field_article_type',
        'field_synopsis',
        'field_tags',
        'field_topics_related_tab',
        'field_people_related_tab',
        'field_archive_page_feature',
        'field_feature_parent',
        'field_parent',
        'field_feature_tag',
        'field_politics_society_categorie',
        'field_timeline_categories_type',
        'field_feature_banner',
        'field_africa_category',
        'field_image',
        'field_featured',
        'field_gallery_tag',
        'field_timelines_related_tab',
        'field_article_contents_page',
        'field_organizations_related_tab',
        'field_article_author',
        'field_article_editors',
        'sharing_buttons',
        'comment_node_article',
        'comment'
      ) }}

      {# Provenance: "How we know this" from field_ref_str (S3). #}
      {% if record_provenance %}
        {{ include('saho:saho-provenance-block', record_provenance, with_context = false) }}
      {% endif %}

      {# Cite this entry (Harvard / APA / Oxford, from CitationService). #}
      {% if record_citation %}
        {{ include('saho:saho-citation', record_citation, with_context = false) }}
      {% endif %}

      {# The record foot (R3 #480/#477): one quiet supporter line, then
         reader contributions - after the record, never inside it. #}
      {# Open Record reading list: derived related records (siblings, shared
         topics, popular) - the record's onward-reading engine. #}
      {% if record_reading %}
        {{ include('saho:saho-reading-list', { title: 'Further reading'|t, items: record_reading }, with_context = false) }}
      {% endif %}

      <p class="saho-record-support">
        {{ 'SAHO is free because readers fund it.'|t }}
        <a href="/donate">{{ 'Donate'|t }} &rarr;</a>
      </p>
      {{ content.comment_node_article ?? '' }}
      {{ content.comment ?? '' }}

    </div>

    {# RIGHT: Sidebar (the Open Record rail - S3) #}
    {# Gate the rail image on the banner's file URI (not .entity, which is
       truthy on an empty reference field) so a banner-less article does not
       render its lead image in both the main column and the rail. #}
    {% set rail_image = record_image.src is defined and record_image.src and (node.field_feature_banner.entity.uri.value or is_collection_head) %}
    {% if record_meta or record_related or record_further or rail_image or chronology_decades %}
      {% set sidebar_has_content = true %}
    {% endif %}

    {% if sidebar_has_content %}
    <aside class="saho-article-sidebar">

      {# Lead image moves to the rail when a feature banner leads the main column. #}
      {% if rail_image %}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}

      {# Record details: the structured article fields. #}
      {% if record_meta %}
        {{ include('saho:saho-metadata-block', record_meta, with_context = false) }}
      {% endif %}

      {# Cross-references: typed entity relations. #}
      {% if record_related %}
        {{ include('saho:saho-related-tabs', record_related, with_context = false) }}
      {% endif %}

      {# Further reading (kept crawlable). #}
      {% if record_further %}
        <section class="saho-meta-block saho-meta-block--article">
          <h2 class="saho-meta-block__title">{{ 'Further reading'|t }}</h2>
          <div class="saho-meta-block__val">{{ record_further }}</div>
        </section>
      {% endif %}

      {# References now render as the main-column provenance-block (S3). #}

      {# Sticky decade index, last in the rail so sticking never overlaps
         rail siblings: orientation for long chronologies. #}
      {% if chronology_decades %}
        <nav class="saho-chron-index" data-saho-chron-index aria-label="{{ 'Decade index'|t }}">
          <h2 class="saho-chron-index__title">{{ 'Decades'|t }}</h2>
          <ul class="saho-chron-index__list">
            {% for d in chronology_decades %}
              <li class="saho-chron-index__item">
                <a class="saho-chron-index__link" href="#{{ d.anchor }}" data-decade="{{ d.label }}">{{ d.label }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}

    </aside>
    {% endif %}

  </div>

</article>

{# The Context & Related Information accordion is retired: entity relations
   render in the rail related-tabs; further reading is a rail block (S3). #}
