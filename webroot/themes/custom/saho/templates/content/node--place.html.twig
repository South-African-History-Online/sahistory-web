{#
/**
 * @file
 * Custom SAHO node template for Place content type.
 *
 * Title is handled globally and not rendered here.
 * Layout Builder is disabled - fields are output directly via Twig.
 */
#}

{# Variable to track if sidebar has content #}
{% set sidebar_has_content = false %}

{# Related-cards footer renders .saho-button as static spans; ensure its CSS loads. #}
{{ attach_library('saho/saho-button') }}

<article{{ attributes.addClass('saho-article-wrapper') }}>

  {# 2027 "Open Record" record header (typed tab + display ref + status + key fields). #}
  {% if record is defined %}
    {{ include('saho:saho-record-header', {
      type: record.type,
      reference: record.reference,
      status: record.status,
      kicker: record.kicker,
      title: record.title,
      facts: record.facts,
    }, with_context = false) }}
  {% endif %}

  {# The record toolbar rides directly under the key-field strip (R3 #476). #}
  {% if record_toolbar is defined %}
    {{ include('saho:saho-record-toolbar', record_toolbar|merge({
      connections_count: record_related.tabs is defined ? record_related.tabs|reduce((c, t) => c + t.count, 0) : 0,
    }), with_context = false) }}
  {% endif %}

  <div class="saho-article-grid">

    {# LEFT: Main content column #}
    <div class="saho-main-content">

      {# .entity alone is truthy on an EMPTY reference field (Twig ArrayAccess
         trap); gate on the file URI so places without a banner fall through to
         the record image instead of emitting an empty-src eager <img>. #}
      {% if node.field_feature_banner.entity.uri.value %}
        <div class="saho-feature-banner">
          <img
            src="{{ file_url(node.field_feature_banner.entity.uri.value) }}"
            alt="{{ node.field_feature_banner.alt }}"
            class="saho-feature-banner-image"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          >
        </div>
      {% elseif record_image.src is defined and record_image.src %}
        {# Open Record lead image: duotone image-credit figure (S3). #}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}

      <div class="saho-article-meta">
        {% if node.getCreatedTime() %}
          <span>{{ 'Published @date'|t({'@date': node.getCreatedTime()|date("j F Y")}) }}</span>
        {% endif %}
        {% if node.getChangedTime() != node.getCreatedTime() %}
          <span>{{ 'Updated @date'|t({'@date': node.getChangedTime()|date("j F Y")}) }}</span>
        {% endif %}
      </div>

      {% if content.body %}
        <div class="saho-article-body">
          {# Remove the label by accessing the content directly #}
          {{ content.body.0 }}
        </div>
      {% endif %}

      {# Geolocation information if available #}
      {% if content.field_geolocation|render|trim %}
        <div class="saho-place-location mb-4">
          <h3 class="mb-3">{{ 'Location Map'|t }}</h3>
          <div class="saho-map-responsive">
            {{ content.field_geolocation }}
          </div>
        </div>
      {% endif %}

      {% if content.field_highlight %}
        <div class="saho-highlight">
          {{ content.field_highlight }}
        </div>
      {% endif %}

      {# Render remaining fields not already shown manually #}
      {{ content|without(
        'body',
        'field_highlight',
        'field_further_reading',
        'field_place_image',
        'field_node_image_caption',
        'field_ref_str',
        'field_african_country',
        'field_feature_banner',
        'field_feature_parent',
        'field_feature_tag',
        'field_home_page_feature',
        'field_home_page_feature_africa_s',
        'field_home_page_feature_place_se',
        'field_place_category',
        'field_place_type',
        'field_places_level3',
        'field_country',
        'field_parent_loc',
        'field_parent',
        'field_geolocation',
        'field_geofield',
        'field_people_related_tab',
        'field_organizations_related_tab',
        'field_topics_related_tab',
        'field_timelines_related_tab',
        'field_synopsis',
        'field_article_author',
        'field_article_editors',
        'sharing_buttons',
        'comment_node_place'
      ) }}

      {# Provenance: "How we know this" from field_ref_str (S3). #}
      {% if record_provenance %}
        {{ include('saho:saho-provenance-block', record_provenance, with_context = false) }}
      {% endif %}

      {# Cite this entry (Harvard / APA / Oxford, from CitationService). #}
      {% if record_citation %}
        {{ include('saho:saho-citation', record_citation, with_context = false) }}
      {% endif %}

      {# The record foot (R3 #480/#477): one quiet supporter line, then
         reader contributions - after the record, never inside it. #}
      {# Open Record reading list: derived related records (siblings, shared
         topics, popular) - the record's onward-reading engine. #}
      {% if record_reading %}
        {{ include('saho:saho-reading-list', { title: 'Further reading'|t, items: record_reading }, with_context = false) }}
      {% endif %}

      <p class="saho-record-support">
        {{ 'SAHO is free because readers fund it.'|t }}
        <a href="/donate">{{ 'Donate'|t }} &rarr;</a>
      </p>
      {{ content.comment_node_place ?? '' }}

    </div>

    {# RIGHT: Sidebar (the Open Record rail - S3) #}
    {% if record_meta or record_related or record_further or (node.field_feature_banner.entity.uri.value and record_image.src is defined and record_image.src) %}
      {% set sidebar_has_content = true %}
    {% endif %}

    {% if sidebar_has_content %}
    <aside class="saho-article-sidebar">

      {# Place image moves to the rail when a feature banner leads the main column. #}
      {% if node.field_feature_banner.entity.uri.value and record_image.src is defined and record_image.src %}
        {{ include('saho:saho-image-credit', record_image, with_context = false) }}
      {% endif %}

      {# Vital record: the structured place fields. #}
      {% if record_meta %}
        {{ include('saho:saho-metadata-block', record_meta, with_context = false) }}
      {% endif %}

      {# Cross-references: typed entity relations. #}
      {% if record_related %}
        {{ include('saho:saho-related-tabs', record_related, with_context = false) }}
      {% endif %}

      {# Further reading (kept crawlable). #}
      {% if record_further %}
        <section class="saho-meta-block saho-meta-block--place">
          <h4 class="saho-meta-block__title">{{ 'Further reading'|t }}</h4>
          <div class="saho-meta-block__val">{{ record_further }}</div>
        </section>
      {% endif %}

      {# References now render as the main-column provenance-block (S3). #}

    </aside>
    {% endif %}

  </div>

</article>

