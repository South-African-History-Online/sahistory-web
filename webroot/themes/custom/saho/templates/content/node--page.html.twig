{#
/**
 * @file
 * SAHO Basic Page template.
 *
 * Two-column layout: body content left, sticky sidebar right.
 * Sidebar contains: file downloads, page info (dates).
 * Hero banner from field_image when present.
 *
 * Available variables:
 * - node: The node entity.
 * - content: Rendered content fields.
 * - attributes: HTML attributes for the article wrapper.
 * - citation_button: Rendered citation button (saho_tools).
 * - sharing_button: Rendered share button (saho_tools).
 */
#}

{# ─── Pre-flight checks ──────────────────────────────────────────────────── #}
{% set has_hero    = node.field_image.entity is not empty %}
{% set has_files   = node.field_file_upload is not empty %}
{% set has_comments = content.comment_node_page is defined and content.comment_node_page|render|trim %}

<article{{ attributes.addClass('saho-article-wrapper', 'saho-page-wrapper') }}>

  {# ─── Hero Banner ─────────────────────────────────────────────────────── #}
  {% if has_hero %}
    <div class="saho-page-hero">
      <img
        src="{{ file_url(node.field_image.entity.uri.value) }}"
        alt="{{ node.field_image.alt|default(node.label) }}"
        class="saho-page-hero__image"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      >
      {% if node.field_image.title %}
        <p class="saho-page-hero__caption">{{ node.field_image.title }}</p>
      {% endif %}
    </div>
  {% endif %}

  {# ─── Content Grid ────────────────────────────────────────────────────── #}
  <div class="saho-article-grid saho-page-grid">

    {# ─── Main Content ─────────────────────────────────────────────────── #}
    <div class="saho-main-content">

      {# Meta row: dates + tools #}
      <div class="saho-article-meta">
        <div class="saho-article-meta__dates">
          {% if node.getCreatedTime() %}
            <span>{{ 'Published'|t }} {{ node.getCreatedTime()|date("j F Y") }}</span>
          {% endif %}
          {% if node.getChangedTime() != node.getCreatedTime() %}
            <span>{{ 'Updated'|t }} {{ node.getChangedTime()|date("j F Y") }}</span>
          {% endif %}
        </div>
        <div class="saho-tools-wrapper">
          {% if citation_button %}
            <div class="saho-citation-wrapper">{{ citation_button }}</div>
          {% endif %}
          {% if sharing_button %}
            <div class="saho-sharing-wrapper">{{ sharing_button }}</div>
          {% endif %}
        </div>
      </div>

      {# Body - .saho-page-body enables TOC/heading/section CSS rules #}
      {% if content.body %}
        <div class="saho-article-body saho-page-body">
          {{ content.body.0 }}
        </div>
      {% endif %}

      {# Comments - only when actual comments exist (not just the empty form) #}
      {% if node.comment_node_page is defined and node.comment_node_page.comment_count.value > 0 %}
        <div class="saho-comments-section">
          {{ content.comment_node_page }}
        </div>
      {% endif %}

    </div>{# /.saho-main-content #}

    {# ─── Sidebar ──────────────────────────────────────────────────────── #}
    <aside class="saho-article-sidebar saho-page-sidebar" aria-label="{{ 'Page information'|t }}">

      {# File attachments ──────────────────────────────────────────────── #}
      {% if has_files %}
        <div class="saho-page-attachments">
          <h3 class="saho-page-attachments__title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
            </svg>
            {{ 'Downloads'|t }}
          </h3>
          <ul class="saho-page-attachments__list">
            {% for item in node.field_file_upload %}
              {% if item.entity %}
                {% set ext = item.entity.filename.value|split('.')|last|lower %}
                <li class="saho-page-attachments__item saho-page-attachments__item--{{ ext }}">
                  <a href="{{ file_url(item.entity.uri.value) }}"
                     class="saho-page-attachments__link"
                     target="_blank"
                     rel="noopener noreferrer">
                    <span class="saho-page-attachments__ext">{{ ext|upper }}</span>
                    {% if item.description %}
                      <span class="saho-page-attachments__description">{{ item.description }}</span>
                    {% else %}
                      <span class="saho-page-attachments__filename">{{ item.entity.filename.value }}</span>
                    {% endif %}
                    {% if item.entity.filesize.value %}
                      <span class="saho-page-attachments__size">
                        {% if item.entity.filesize.value > 1048576 %}
                          {{ (item.entity.filesize.value / 1048576)|round(1) }} MB
                        {% else %}
                          {{ (item.entity.filesize.value / 1024)|round(0) }} KB
                        {% endif %}
                      </span>
                    {% endif %}
                    <svg class="saho-page-attachments__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                  </a>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      {% endif %}

    </aside>{# /.saho-page-sidebar #}

  </div>{# /.saho-article-grid #}

</article>
