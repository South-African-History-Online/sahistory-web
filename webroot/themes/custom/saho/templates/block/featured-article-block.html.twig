{#
/**
 * @file
 * Featured topics band (Open Record register, #453).
 *
 * One staff-pick article as a duotone figure with a square kind label and
 * the title as the link, closed by a single mono band action to /featured.
 * No filler standfirst - the voice states facts or says nothing.
 */
#}
<div class="block-section">
  <div class="block-section-header">
    <div class="block-title-wrapper">
      <h2>{{ 'Featured topics'|t }}</h2>
    </div>
    <div class="block-meta">{{ 'Staff picks'|t }}</div>
  </div>

  {% if article_item %}
    <div class="block-content">
      {% if article_item.image %}
        <div class="block-image-wrapper">
          {# Featured topics block sits in the home page LCP region - eager load. #}
          <img src="{{ article_item.image }}" alt="{{ article_item.title|striptags }}" class="block-image" fetchpriority="high" decoding="async" />
          <div class="block-label">{{ 'Article'|t }}</div>
        </div>
      {% endif %}

      <h3>
        <a href="{{ article_item.url }}">{{ article_item.title }}</a>
      </h3>
    </div>
  {% else %}
    <div class="block-content">
      <p class="block-main-text">{{ 'No featured article found.'|t }}</p>
    </div>
  {% endif %}

  <div class="block-buttons">
    <a href="/featured" class="block-more-link">{{ 'More features'|t }} <span aria-hidden="true">&rarr;</span></a>
  </div>
</div>
