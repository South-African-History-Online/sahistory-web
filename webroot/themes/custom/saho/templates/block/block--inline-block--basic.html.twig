{#
/**
 * @file
 * Template for the Basic inline block type.
 *
 * Wraps the body content in a saho-prose container for consistent typography.
 * Used for rich-text content, embedded media, and arbitrary HTML.
 *
 * Available variables:
 * - content: The block content, including content.body.
 * - label: The configured label of the block.
 * - attributes: HTML attributes for the wrapper.
 */
#}

{% if content.body %}
  <div class="saho-prose-block">
    {% if label %}
      <h2 class="saho-prose-block__title">{{ label }}</h2>
    {% endif %}
    <div class="saho-prose-block__body">
      {{ content.body }}
    </div>
  </div>
{% endif %}
