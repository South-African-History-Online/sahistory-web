{#
/**
 * @file
 * SAHO main menu — clean output, no Bootstrap navbar/collapse wrapper.
 *
 * Used in two contexts:
 *  - .saho-nav-bar   (desktop, horizontal)
 *  - .saho-mobile-nav (offcanvas, vertical)
 *
 * CSS differentiates layout by parent container class.
 * The saho-main-menu utility class is passed to saho:nav so CSS can target it.
 */
#}
{% include 'saho:nav' with {
  nav_utility_classes: ['saho-main-menu']
} %}
