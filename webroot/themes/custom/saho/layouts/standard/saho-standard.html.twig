{#
/**
 * @file
 * SAHO — Standard column layout. One aligned reading column.
 */
#}
<div{{ attributes.addClass('layout', 'layout--saho', 'layout--saho-standard') }}>
  {% if content.content %}
    <div {{ region_attributes.content.addClass('layout-builder__region', 'region--content') }}>
      {{ content.content }}
    </div>
  {% endif %}
</div>
