{#
/**
 * @file
 * SAHO — Index grid. A responsive, always-aligned grid of records/cards.
 * Add the modifier class `is-auto`, `is-dense` or `is-wide` via the layout
 * settings to change density. Single column on mobile.
 *
 * The grid region carries `display: contents` via SCSS (.region--grid) so its
 * children become the grid items directly.
 */
#}
<div{{ attributes.addClass('layout', 'layout--saho', 'layout--saho-index') }}>
  <div {{ region_attributes.grid.addClass('layout-builder__region', 'region--grid') }}>
    {{ content.grid }}
  </div>
</div>
