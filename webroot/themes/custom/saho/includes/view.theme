 * Implements hook_preprocess_views_view() for the saho_landing view (page_1).
 */
function saho_preprocess_views_view__saho_landing__page_1(array &$variables) {
  // The theme registry only runs base-hook + exact-suggestion preprocess when
  // a more specific template exists, so the page display needs this wrapper.
  saho_preprocess_views_view__saho_landing($variables);
}

/**
 * Builds the Open Record content-type landing shell (wireframe wf02).
 *
 * Same results contract as the /search shell: index-table columns/rows and
 * archive-card props for every result behind a table/cards toggle, plus the
 * landing header variables (type accent, plural label, record count) derived
 * from the node-type contextual argument on /index/%.
 */
function saho_preprocess_views_view__saho_landing(array &$variables) {
  /** @var \Drupal\saho_refs\DisplayRefService $refs */
  $refs = \Drupal::service('saho_refs.display_ref');
  $date_formatter = \Drupal::service('date.formatter');

  // Bundles renamed for display accents.
  $type_map = ['upcomingevent' => 'event', 'book' => 'archive'];
  // Types the archive-card SDC accepts; anything else falls back to article.
  $card_types = ['article', 'biography', 'place', 'archive', 'event', 'topic'];

  // Landing header vars from the node-type contextual argument.
  $arg = (string) ($variables['view']->args[0] ?? '');
  $landing_type = $arg === '' ? 'article' : ($type_map[$arg] ?? $arg);
  // Explicit archive vocabulary for the record bundles; bundle labels are
  // unreliable here (event's label is "This day in history").
  $label_map = [
    'biography' => 'Biographies',
    'article' => 'Articles',
    'event' => 'Events',
    'place' => 'Places',
    'archive' => 'Archive',
    'topic' => 'Topics',
    'upcomingevent' => 'Events',
    'book' => 'Archive',
  ];
  $landing_label = 'Records';
  if ($arg !== '') {
    if (isset($label_map[$arg])) {
      $landing_label = $label_map[$arg];
    }
    else {
      $node_type = \Drupal::entityTypeManager()->getStorage('node_type')->load($arg);
      $landing_label = $node_type ? (string) $node_type->label() : ucfirst($arg);
    }
  }
  $variables['landing_type'] = $landing_type;
  $variables['landing_label'] = $landing_label;
  $variables['landing_count'] = number_format((int) ($variables['view']->total_rows ?? count($variables['view']->result)));

  $variables['record_columns'] = [
    ['key' => 'ref', 'label' => 'Ref', 'mono' => TRUE, 'sortable' => TRUE, 'width' => '110px'],
    ['key' => 'type', 'label' => 'Type', 'sortable' => TRUE, 'width' => '130px'],
    ['key' => 'title', 'label' => 'Record', 'sortable' => TRUE],
    ['key' => 'dates', 'label' => 'Dates', 'mono' => TRUE, 'muted' => TRUE, 'sortable' => TRUE, 'width' => '140px'],
    ['key' => 'src', 'label' => 'Src', 'mono' => TRUE, 'muted' => TRUE, 'align' => 'center', 'width' => '70px'],
  ];

  $record_rows = [];
  $record_cards = [];
  foreach ($variables['view']->result as $row) {
    $node = $row->_entity ?? NULL;
    if (!$node instanceof NodeInterface || !$node->isPublished()) {
      continue;
    }
    $bundle = $node->bundle();
    $type = $type_map[$bundle] ?? $bundle;

    // Dates: biography lifespans are verbatim free-text strings (never
    // date-formatted); everything else shows the created date.
    if ($bundle === 'biography') {
      $span = [];
      foreach (['field_dob', 'field_dod'] as $date_field) {
        if ($node->hasField($date_field) && !$node->get($date_field)->isEmpty()) {
          $value = trim((string) $node->get($date_field)->value);
          if ($value !== '') {
            $span[] = $value;
          }
        }
      }
      $dates = implode('-', $span);
    }
    else {
      $dates = $date_formatter->format($node->getCreatedTime(), 'custom', 'j M Y');
    }

    // Src column: a mono check mark when the record cites a source.
    $has_source = $node->hasField('field_ref_str')
      && !$node->get('field_ref_str')->isEmpty()
      && trim((string) $node->get('field_ref_str')->value) !== '';

    $ref = $refs->getRef($node);
    $href = $node->toUrl()->toString();

    $record_rows[] = [
      'ref' => $ref,
      'type' => $type,
      'title' => $node->label(),
      'href' => $href,
      'dates' => $dates,
      'src' => $has_source ? "\u{2713}" : '-',
    ];

    // Excerpt: trimmed plain-text body (plain node rows have no Solr excerpt).
    $excerpt = '';
    if ($node->hasField('body') && !$node->get('body')->isEmpty()) {
      $excerpt = trim(strip_tags((string) $node->get('body')->value));
    }
    $excerpt = Unicode::truncate(html_entity_decode($excerpt, ENT_QUOTES), 160, TRUE, TRUE);

    $image = _saho_search_result_image($node);
    $record_cards[] = [
      'type' => in_array($type, $card_types, TRUE) ? $type : 'article',
      'title' => $node->label(),
      'href' => $href,
      'excerpt' => $excerpt,
      'dates' => $dates,
      'meta' => $ref,
      'image' => $image['url'] ?? '',
      'image_alt' => $image['alt'],
      'duotone' => TRUE,
    ];
  }

  $variables['record_rows'] = $record_rows;
  $variables['record_cards'] = $record_cards;
  $variables['result_total'] = $variables['landing_count'];
  $variables['results_layout'] = \Drupal::request()->query->get('layout') === 'grid' ? 'grid' : 'table';

  $variables['#attached']['library'][] = 'saho/saho-index-table';
  $variables['#attached']['library'][] = 'saho/saho-archive-card';
  $variables['#cache']['contexts'][] = 'url.query_args:layout';
}

/**
 * Implements hook_preprocess_views_view() for the classroom view (page_1).
 */
function saho_preprocess_views_view__classroom__page_1(array &$variables) {
  // The theme registry only runs base-hook + exact-suggestion preprocess when
  // a more specific template exists, so the page display needs this wrapper.
  saho_preprocess_views_view__classroom($variables);
}

/**
 * Builds the Open Record classroom / educator landing (wireframe wf08).
 *
 * Shapes every result row into archive-card SDC props (classroom_cards):
 * classroom resource bundles borrow the article accent, the meta line shows
 * the resource-type term when set (bundle label otherwise), and images run
 * through the shared per-bundle image resolver with the archival duotone.
 */
function saho_preprocess_views_view__classroom(array &$variables) {
  $date_formatter = \Drupal::service('date.formatter');
  $node_type_storage = \Drupal::entityTypeManager()->getStorage('node_type');

  // Bundles renamed for display accents.
  $type_map = ['upcomingevent' => 'event', 'book' => 'archive'];
  // Types the archive-card SDC accepts; classroom resource bundles
  // (presentation, worksheet, activity, quiz, classroom_clip) and anything
  // else outside the enum fall back to the article accent for now.
  $card_types = ['article', 'biography', 'place', 'archive', 'event', 'topic'];

  $classroom_cards = [];
  $bundle_labels = [];
  foreach ($variables['view']->result as $row) {
    $node = _saho_search_result_node($row);
    if (!$node || !$node->isPublished()) {
      continue;
    }
    $bundle = $node->bundle();
    $type = $type_map[$bundle] ?? $bundle;

    // Meta line: the resource-type term label when the field is populated,
    // the bundle label otherwise.
    $meta = '';
    if ($node->hasField('field_classroom_resource_type') && !$node->get('field_classroom_resource_type')->isEmpty()) {
      $term = $node->get('field_classroom_resource_type')->entity;
      if ($term) {
        $meta = (string) $term->label();
      }
    }
    if ($meta === '') {
      if (!isset($bundle_labels[$bundle])) {
        $node_type = $node_type_storage->load($bundle);
        $bundle_labels[$bundle] = $node_type ? (string) $node_type->label() : ucfirst($bundle);
      }
      $meta = $bundle_labels[$bundle];
    }

    // Excerpt: trimmed plain-text body.
    $excerpt = '';
    if ($node->hasField('body') && !$node->get('body')->isEmpty()) {
      $excerpt = trim(strip_tags((string) $node->get('body')->value));
    }
    $excerpt = Unicode::truncate(html_entity_decode($excerpt, ENT_QUOTES), 140, TRUE, TRUE);

    $image = _saho_search_result_image($node);
    $classroom_cards[] = [
      'type' => in_array($type, $card_types, TRUE) ? $type : 'article',
      'title' => $node->label(),
      'href' => $node->toUrl()->toString(),
      'excerpt' => $excerpt,
      'dates' => $date_formatter->format($node->getCreatedTime(), 'custom', 'j M Y'),
      'meta' => $meta,
      'image' => $image['url'] ?? '',
      'image_alt' => $image['alt'],
      'duotone' => TRUE,
    ];
  }

  $variables['classroom_cards'] = $classroom_cards;
  $variables['result_total'] = number_format((int) ($variables['view']->total_rows ?? count($variables['view']->result)));

  $variables['#attached']['library'][] = 'saho/saho-archive-card';
  $variables['#attached']['library'][] = 'saho/saho-card-grid';
  $variables['#attached']['library'][] = 'saho/saho-tag';
  $variables['#attached']['library'][] = 'saho/saho-section-heading';
}

/**
 * Implements hook_preprocess_views_view() for the topic spine page display.
 */
function saho_preprocess_views_view__saho_classroom_topic__page_1(array &$variables) {
  // The theme registry only runs base-hook + exact-suggestion preprocess when
  // a more specific template exists, so the page display needs this wrapper.
  saho_preprocess_views_view__saho_classroom_topic($variables);
}

/**
 * Builds the Classroom 2.0 topic spine page (issue #444).
 *
 * One /classroom/topic/% page per caps_topic term: results are shaped into
 * archive-card SDC props and grouped by resource type (the node's
 * field_classroom_resource_type term label, bundle label otherwise) in a
 * fixed pedagogical order - overview first, assessment material last.
 */
function saho_preprocess_views_view__saho_classroom_topic(array &$variables) {
  $date_formatter = \Drupal::service('date.formatter');
  $node_type_storage = \Drupal::entityTypeManager()->getStorage('node_type');

  // Resolve the topic term from the view's contextual argument.
  $variables['topic_label'] = '';
  $variables['topic_grade'] = '';
  $tid = $variables['view']->args[0] ?? NULL;
  if ($tid) {
    $topic = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
    if ($topic) {
      $variables['topic_label'] = (string) $topic->label();
      // caps_topic parents are grade terms (e.g. "Grade 10").
      $grade = $topic->get('parent')->entity;
      if ($grade) {
        $variables['topic_grade'] = (string) $grade->label();
      }
    }
  }

  // Fixed spine order for resource-type groups; unknown labels sort last.
  $group_weights = array_flip([
    'Topic overview',
    'Presentation',
    'Clip',
    'Worksheet',
    'Activity',
    'Quiz',
    'Glossary',
    'Source-based questions',
    'Essay questions',
    'Exam paper',
    'Lesson pack',
  ]);

  // Bundles renamed for display accents.
  $type_map = ['upcomingevent' => 'event', 'book' => 'archive'];
  // Types the archive-card SDC accepts; anything else falls back to article.
  $card_types = ['article', 'biography', 'place', 'archive', 'event', 'topic'];

  $spine_groups = [];
  $bundle_labels = [];
  foreach ($variables['view']->result as $row) {
    $node = _saho_search_result_node($row);
    if (!$node || !$node->isPublished()) {
      continue;
    }
    $bundle = $node->bundle();
    $type = $type_map[$bundle] ?? $bundle;

    // Group label: the resource-type term label when the field is populated,
    // the bundle label otherwise (e.g. Presentation for the new types).
    $group = '';
    if ($node->hasField('field_classroom_resource_type') && !$node->get('field_classroom_resource_type')->isEmpty()) {
      $term = $node->get('field_classroom_resource_type')->entity;
      if ($term) {
        $group = (string) $term->label();
      }
    }
    if ($group === '') {
      if (!isset($bundle_labels[$bundle])) {
        $node_type = $node_type_storage->load($bundle);
        $bundle_labels[$bundle] = $node_type ? (string) $node_type->label() : ucfirst($bundle);
      }
      $group = $bundle_labels[$bundle];
    }

    // Excerpt: trimmed plain-text body.
    $excerpt = '';
    if ($node->hasField('body') && !$node->get('body')->isEmpty()) {
      $excerpt = trim(strip_tags((string) $node->get('body')->value));
    }
    $excerpt = Unicode::truncate(html_entity_decode($excerpt, ENT_QUOTES), 140, TRUE, TRUE);

    $image = _saho_search_result_image($node);
    $spine_groups[$group][] = [
      'type' => in_array($type, $card_types, TRUE) ? $type : 'article',
      'title' => $node->label(),
      'href' => $node->toUrl()->toString(),
      'excerpt' => $excerpt,
      'dates' => $date_formatter->format($node->getCreatedTime(), 'custom', 'j M Y'),
      'meta' => $group,
      'image' => $image['url'] ?? '',
      'image_alt' => $image['alt'],
      'duotone' => TRUE,
    ];
  }

  uksort($spine_groups, function (string $a, string $b) use ($group_weights): int {
    $weight_a = $group_weights[$a] ?? count($group_weights);
    $weight_b = $group_weights[$b] ?? count($group_weights);
    return $weight_a <=> $weight_b ?: strcasecmp($a, $b);
  });

  $variables['spine_groups'] = $spine_groups;
  $variables['result_total'] = number_format((int) ($variables['view']->total_rows ?? count($variables['view']->result)));

  $variables['#attached']['library'][] = 'saho/saho-archive-card';
  $variables['#attached']['library'][] = 'saho/saho-card-grid';
  $variables['#attached']['library'][] = 'saho/saho-section-heading';
}
