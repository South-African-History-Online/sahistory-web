<?php

/**
 * @file
 * Theme and preprocess functions for views.
 */

use Drupal\Component\Utility\Unicode;
use Drupal\file\Entity\File;
use Drupal\image\Entity\ImageStyle;
use Drupal\media\Entity\Media;
use Drupal\node\NodeInterface;

/**
 * Resolves the node behind a search result row, if any.
 *
 * @param object $row
 *   A views result row from a Search API index.
 *
 * @return \Drupal\node\NodeInterface|null
 *   The node, or NULL when the row does not wrap a node.
 */
function _saho_search_result_node($row): ?NodeInterface {
  $node = NULL;
  if (isset($row->_entity)) {
    $node = $row->_entity;
  }
  elseif (isset($row->_item) && $row->_item->getOriginalObject()) {
    $node = $row->_item->getOriginalObject()->getValue();
  }
  return $node instanceof NodeInterface ? $node : NULL;
}

/**
 * Resolves the display image for a search result node.
 *
 * Shared by the "Open Record" search shell (archive cards) and the legacy
 * per-row fields preprocess: walks a per-bundle image-field map and returns
 * the first usable image as a styled derivative URL.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The result node.
 *
 * @return array
 *   Array with 'url' (string|NULL when no image was found) and 'alt' (string).
 */
function _saho_search_result_image(NodeInterface $node): array {
  // Image field mappings per content type (in priority order).
  $image_field_map = [
    'article' => ['field_article_image', 'field_image', 'field_main_image'],
    'biography' => ['field_bio_pic'],
    'archive' => ['field_archive_image', 'field_image'],
    'place' => ['field_place_image'],
    'event' => ['field_event_image', 'field_tdih_image'],
    'upcomingevent' => ['field_event_image'],
  ];

  $fields_to_check = $image_field_map[$node->bundle()] ?? ['field_image'];

  foreach ($fields_to_check as $field_name) {
    if (!$node->hasField($field_name)) {
      continue;
    }

    $field = $node->get($field_name);
    if ($field->isEmpty()) {
      continue;
    }

    $field_type = $field->getFieldDefinition()->getType();

    // Handle media reference fields.
    if ($field_type === 'entity_reference' && $field->getSetting('target_type') === 'media') {
      $media_id = $field->target_id;
      if ($media_id) {
        $media = Media::load($media_id);
        if ($media && $media->hasField('field_media_image')) {
          $media_image = $media->get('field_media_image');
          if (!$media_image->isEmpty()) {
            $file = File::load($media_image->target_id);
            if ($file) {
              return [
                'url' => _saho_get_styled_image_url($file->getFileUri(), 'saho_medium'),
                'alt' => $media_image->alt ?? $node->label(),
              ];
            }
          }
        }
      }
    }
    // Handle regular image fields.
    elseif ($field_type === 'image') {
      $file_id = $field->target_id;
      if ($file_id) {
        $file = File::load($file_id);
        if ($file) {
          return [
            'url' => _saho_get_styled_image_url($file->getFileUri(), 'saho_medium'),
            'alt' => $field->alt ?? $node->label(),
          ];
        }
      }
    }
  }

  return ['url' => NULL, 'alt' => ''];
}

/**
 * Implements hook_preprocess_views_view() for the saho_global_search view.
 *
 * Builds the 2027 "Open Record" search shell (wireframe wf05): index-table
 * columns/rows and archive-card props for every result, the total count and
 * the server-side default layout honoring ?layout=. Rows render from these
 * variables in the page template via SDCs - the per-row fields template is
 * an empty stub.
 */
function saho_preprocess_views_view__saho_global_search__page_1(array &$variables) {
  // The theme registry only runs base-hook + exact-suggestion preprocess when
  // a more specific template exists, so the page display needs this wrapper.
  saho_preprocess_views_view__saho_global_search($variables);
}

/**
 * Builds the Open Record search shell variables (shared by all displays).
 */
function saho_preprocess_views_view__saho_global_search(array &$variables) {
  /** @var \Drupal\saho_refs\DisplayRefService $refs */
  $refs = \Drupal::service('saho_refs.display_ref');
  $date_formatter = \Drupal::service('date.formatter');

  // Bundles renamed for display; commerce products are skipped entirely.
  $type_map = ['upcomingevent' => 'event', 'book' => 'archive'];
  // Types the archive-card SDC accepts; anything else falls back to article.
  $card_types = ['article', 'biography', 'place', 'archive', 'event', 'topic'];

  $variables['record_columns'] = [
    ['key' => 'ref', 'label' => 'Ref', 'mono' => TRUE, 'sortable' => TRUE, 'width' => '110px'],
    ['key' => 'type', 'label' => 'Type', 'sortable' => TRUE, 'width' => '130px'],
    ['key' => 'title', 'label' => 'Record', 'sortable' => TRUE],
    ['key' => 'dates', 'label' => 'Dates', 'mono' => TRUE, 'muted' => TRUE, 'sortable' => TRUE, 'width' => '140px'],
    ['key' => 'src', 'label' => 'Src', 'mono' => TRUE, 'muted' => TRUE, 'align' => 'center', 'width' => '70px'],
  ];

  $record_rows = [];
  $record_cards = [];
  foreach ($variables['view']->result as $row) {
    $node = _saho_search_result_node($row);
    if (!$node || !$node->isPublished()) {
      continue;
    }
    $bundle = $node->bundle();
    if ($bundle === 'product') {
      continue;
    }
    $type = $type_map[$bundle] ?? $bundle;

    // Dates: biography lifespans are verbatim free-text strings (never
    // date-formatted); everything else shows the created date.
    if ($bundle === 'biography') {
      $span = [];
      foreach (['field_dob', 'field_dod'] as $date_field) {
        if ($node->hasField($date_field) && !$node->get($date_field)->isEmpty()) {
          $value = trim((string) $node->get($date_field)->value);
          if ($value !== '') {
            $span[] = $value;
          }
        }
      }
      $dates = implode('-', $span);
    }
    else {
      $dates = $date_formatter->format($node->getCreatedTime(), 'custom', 'j M Y');
    }

    // Src column: a mono check mark when the record cites a source.
    $has_source = $node->hasField('field_ref_str')
      && !$node->get('field_ref_str')->isEmpty()
      && trim((string) $node->get('field_ref_str')->value) !== '';

    $ref = $refs->getRef($node);
    $href = $node->toUrl()->toString();

    $record_rows[] = [
      'ref' => $ref,
      'type' => $type,
      'title' => $node->label(),
      'href' => $href,
      'dates' => $dates,
      'src' => $has_source ? "\u{2713}" : '-',
    ];

    // Excerpt: Solr highlight when available, else trimmed plain-text body.
    $excerpt = trim(strip_tags((string) ($row->search_api_excerpt ?? '')));
    if ($excerpt === '' && $node->hasField('body') && !$node->get('body')->isEmpty()) {
      $excerpt = trim(strip_tags((string) $node->get('body')->value));
    }
    $excerpt = Unicode::truncate(html_entity_decode($excerpt, ENT_QUOTES), 160, TRUE, TRUE);

    $image = _saho_search_result_image($node);
    $record_cards[] = [
      'type' => in_array($type, $card_types, TRUE) ? $type : 'article',
      'title' => $node->label(),
      'href' => $href,
      'excerpt' => $excerpt,
      'dates' => $dates,
      'meta' => $ref,
      'image' => $image['url'] ?? '',
      'image_alt' => $image['alt'],
      'duotone' => TRUE,
    ];
  }

  $variables['record_rows'] = $record_rows;
  $variables['record_cards'] = $record_cards;
  $variables['result_total'] = number_format((int) ($variables['view']->total_rows ?? count($variables['view']->result)));
  $variables['results_layout'] = \Drupal::request()->query->get('layout') === 'grid' ? 'grid' : 'table';

  $variables['#attached']['library'][] = 'saho/saho-index-table';
  $variables['#attached']['library'][] = 'saho/saho-archive-card';
  $variables['#attached']['library'][] = 'saho/saho-search-field';
  $variables['#cache']['contexts'][] = 'url.query_args:layout';
}

/**
 * Implements hook_preprocess_views_view_fields() for saho_global_search view.
 *
 * Legacy per-row variables (image/alt/url). The row template is an empty
 * stub under the "Open Record" search shell, but the variables stay wired
 * for any display that still prints rows.
 */
function saho_preprocess_views_view_fields__saho_global_search(&$variables) {
  $node = _saho_search_result_node($variables['row']);

  // Default placeholder image.
  $placeholder = '/' . \Drupal::service('extension.list.theme')->getPath('saho') . '/images/placeholder-card.svg';
  $variables['search_result_image'] = $placeholder;
  $variables['search_result_image_alt'] = '';

  if (!$node) {
    return;
  }

  $image = _saho_search_result_image($node);
  if ($image['url']) {
    $variables['search_result_image'] = $image['url'];
    $variables['search_result_image_alt'] = $image['alt'];
  }

  // Add the node URL for the "Read more" link.
  $variables['search_result_url'] = $node->toUrl()->toString();
}

/**
 * Implements hook_preprocess_views_view() for featured_content view.
 *
 * Provides dynamic category counts and stats for the featured content page.
 */
function saho_preprocess_views_view__featured_content(&$variables) {
  $database = \Drupal::database();

  // Calculate featured content statistics.
  $stats = [];

  // Total featured stories (home page feature OR staff picks).
  try {
    $featured_query = $database->select('node__field_home_page_feature', 'hp');
    $featured_query->join('node_field_data', 'n', 'hp.entity_id = n.nid');
    $featured_query->condition('hp.field_home_page_feature_value', 1);
    $featured_query->condition('hp.deleted', 0);
    $featured_query->condition('n.status', 1);
    $stats['featured_stories'] = (int) $featured_query->countQuery()->execute()->fetchField();
  }
  catch (\Exception $e) {
    $stats['featured_stories'] = 0;
  }

  // Staff picks (Editor's Choices).
  try {
    $staff_query = $database->select('node__field_staff_picks', 'sp');
    $staff_query->join('node_field_data', 'n', 'sp.entity_id = n.nid');
    $staff_query->condition('sp.field_staff_picks_value', 1);
    $staff_query->condition('sp.deleted', 0);
    $staff_query->condition('n.status', 1);
    $stats['staff_picks'] = (int) $staff_query->countQuery()->execute()->fetchField();
  }
  catch (\Exception $e) {
    $stats['staff_picks'] = 0;
  }

  // Recent updates (last 30 days).
  try {
    $recent_date = strtotime('-30 days');
    $recent_query = $database->select('node_field_data', 'n');
    $recent_query->condition('n.status', 1);
    $recent_query->condition('n.changed', $recent_date, '>');
    $recent_query->condition('n.type', ['article', 'biography', 'archive', 'place', 'event'], 'IN');
    $stats['recent_updates'] = (int) $recent_query->countQuery()->execute()->fetchField();
  }
  catch (\Exception $e) {
    $stats['recent_updates'] = 0;
  }

  // Category counts for sidebar.
  $categories = [];

  // Africa Section.
  try {
    $africa_query = $database->select('node__field_africa_category', 'ac');
    $africa_query->join('node_field_data', 'n', 'ac.entity_id = n.nid');
    $africa_query->condition('ac.deleted', 0);
    $africa_query->condition('n.status', 1);
    $categories['africa_section'] = (int) $africa_query->countQuery()->execute()->fetchField();
  }
  catch (\Exception $e) {
    $categories['africa_section'] = 0;
  }

  // Politics & Society.
  try {
    $politics_query = $database->select('node__field_politics_society_categorie', 'ps');
    $politics_query->join('node_field_data', 'n', 'ps.entity_id = n.nid');
    $politics_query->condition('ps.deleted', 0);
    $politics_query->condition('n.status', 1);
    $categories['politics_society'] = (int) $politics_query->countQuery()->execute()->fetchField();
  }
  catch (\Exception $e) {
    $categories['politics_society'] = 0;
  }

  // Timeline Features (events with featured flag).
  try {
    $timeline_query = $database->select('node_field_data', 'n');
    $timeline_query->leftJoin('node__field_home_page_feature', 'hp', 'hp.entity_id = n.nid AND hp.deleted = 0');
    $timeline_query->condition('n.type', 'event');
    $timeline_query->condition('n.status', 1);
    $timeline_query->condition('hp.field_home_page_feature_value', 1);
    $categories['timelines'] = (int) $timeline_query->countQuery()->execute()->fetchField();
  }
  catch (\Exception $e) {
    $categories['timelines'] = 0;
  }

  // Most Read - use statistics if available.
  try {
    if (\Drupal::moduleHandler()->moduleExists('statistics')) {
      $most_read_query = $database->select('node_counter', 'nc');
      $most_read_query->join('node_field_data', 'n', 'nc.nid = n.nid');
      $most_read_query->condition('nc.totalcount', 100, '>');
      $most_read_query->condition('n.status', 1);
      $categories['most_read'] = (int) $most_read_query->countQuery()->execute()->fetchField();
    }
    else {
      $categories['most_read'] = 0;
    }
  }
  catch (\Exception $e) {
    $categories['most_read'] = 0;
  }

  // Pass to template.
  $variables['featured_stats'] = $stats;
  $variables['featured_categories'] = $categories;
}

/**
 * Helper function to get styled image URL.
 *
 * Creates the derivative if it doesn't exist to ensure images display.
 */
function _saho_get_styled_image_url($uri, $style_name = 'large') {
  $file_url_generator = \Drupal::service('file_url_generator');
  $file_system = \Drupal::service('file_system');

  $style = ImageStyle::load($style_name);
  if ($style) {
    // Check if the derivative exists, create it if not.
    $derivative_uri = $style->buildUri($uri);
    $derivative_path = $file_system->realpath($derivative_uri);

    if (!$derivative_path || !file_exists($derivative_path)) {
      // Ensure the source file exists before attempting to create derivative.
      $source_path = $file_system->realpath($uri);
      if ($source_path && file_exists($source_path)) {
        $style->createDerivative($uri, $derivative_uri);
      }
      else {
        // Source file doesn't exist, return NULL to use placeholder.
        return NULL;
      }
    }
    $url = $style->buildUrl($uri);
    // Convert to relative URL for consistency across environments.
    return $file_url_generator->transformRelative($url);
  }
  // Fallback to original file URL.
  $url = $file_url_generator->generateAbsoluteString($uri);
  return $file_url_generator->transformRelative($url);
}

