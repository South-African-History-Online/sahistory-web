{#
/**
 * @file
 * SAHO Hero Banner - wf07 editorial-feature hero (#461).
 *
 * Standard mode anatomy, top to bottom: duotone image, then a flat ink band
 * carrying (bottom-left) mono kicker, masthead, standfirst, CTA row (solid +
 * optional ghost) and (bottom-right) the mono image credit. No overlay, no
 * centering, no text-shadow; the content-type accent paints the top rule.
 *
 * Graphic mode is unchanged in spirit: the whole banner is one clickable
 * promotional image with no text rendering.
 *
 * See saho-hero-banner.component.yml for the prop contract.
 */
#}
{# Don't render anything if the background image is missing (file not found). #}
{% if background_image %}

{% set is_graphic_mode = display_mode|default('standard') == 'graphic' %}
{% set heading_tag = heading_level|default('h2') %}
{% set classes = [
  'saho-hero-banner',
  'saho-hero-banner--accent-' ~ accent|default('archive'),
  is_graphic_mode ? 'saho-hero-banner--graphic',
] %}

<div{{ attributes.addClass(classes) }}>
  {% if is_graphic_mode %}
    {# Graphic mode: the entire banner is the link; the image is the message. #}
    {% if button_url %}
      <a href="{{ button_url }}"
         class="saho-hero-banner__link"
         {% if button_target %}target="{{ button_target }}"{% endif %}
         {% if button_rel %}rel="{{ button_rel }}"{% endif %}
         data-original-url="{{ button_url }}">
    {% endif %}
    <picture class="saho-hero-banner__picture">
      {% if background_image_mobile %}
        <source media="(max-width: 768px)" srcset="{{ background_image_mobile }}">
      {% endif %}
      <img
        src="{{ background_image }}"
        alt="{{ title|default('') }}"
        class="saho-hero-banner__image"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        {% if image_width and image_height %}width="{{ image_width }}" height="{{ image_height }}"{% endif %}
      >
    </picture>
    {% if button_url %}
      </a>
    {% endif %}
  {% else %}
    {# LCP optimization: real <picture> element, duotone per the image system. #}
    <picture class="saho-hero-banner__picture">
      {% if background_image_mobile %}
        <source media="(max-width: 768px)" srcset="{{ background_image_mobile }}">
      {% endif %}
      <img
        src="{{ background_image }}"
        alt=""
        class="saho-hero-banner__image saho-duotone"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        {% if image_width and image_height %}width="{{ image_width }}" height="{{ image_height }}"{% endif %}
      >
    </picture>

    <div class="saho-hero-banner__band">
      <div class="saho-hero-banner__inner">
        {% if kicker %}
          <p class="saho-hero-banner__kicker">{{ kicker }}</p>
        {% endif %}

        <{{ heading_tag }} class="saho-hero-banner__title">{{ title }}</{{ heading_tag }}>

        {% if subtitle %}
          <p class="saho-hero-banner__standfirst">{{ subtitle }}</p>
        {% endif %}

        {% if body %}
          <div class="saho-hero-banner__body text-formatted">
            {{ body }}
          </div>
        {% endif %}

        {% if button_text and button_url %}
          <div class="saho-hero-banner__cta">
            <a class="saho-hero-banner__btn saho-hero-banner__btn--solid"
               href="{{ button_url }}"
               {% if button_target and button_target != '_self' %}target="{{ button_target }}"{% endif %}
               {% if button_rel %}rel="{{ button_rel }}"{% endif %}>{{ button_text }}</a>
            {% if button2_text and button2_url %}
              <a class="saho-hero-banner__btn saho-hero-banner__btn--ghost" href="{{ button2_url }}">{{ button2_text }}</a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if credit %}
        <p class="saho-hero-banner__credit">{{ credit }}</p>
      {% endif %}
    </div>
  {% endif %}
</div>
{% endif %}
