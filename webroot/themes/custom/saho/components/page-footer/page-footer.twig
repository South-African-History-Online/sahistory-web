{#
/**
 * @file
 * Footer for SAHO with Marion Institute partnership and donation pathways.
 * White background, grey text, subtle divider lines.
 */
#}
{# Attach the donate library so the Snapscan QR overlay and supporter
   memory behaviours below are wired up. #}
{{ attach_library('saho_donate/donate-page') }}
{% apply spaceless %}
<footer class="saho-footer">

  {# Support SAHO banner - 4 donation pathways + Marion Institute partnership #}
  <div class="footer-support-banner">
    <div class="container py-4">
      <p class="footer-support-tagline">Keep South African history free and accessible</p>
      <div class="footer-support-actions">
        <a href="https://www.marioninstitute.org/south-african-history-online-donation-page/"
           class="footer-cta-primary"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Donate to SAHO via Marion Institute (opens in new tab)">
          <span class="footer-cta-icon" aria-hidden="true">♥</span>
          <span>Donate</span>
        </a>
        <a href="https://shop.sahistory.org.za/champion"
           class="footer-cta-secondary"
           aria-label="Become a SAHO Champion supporter">
          <span class="footer-cta-icon" aria-hidden="true">★</span>
          <span>Become a Champion</span>
        </a>
        <a href="https://www.paypal.com/donate?hosted_button_id=CZPNF5PNPW8SL"
           class="footer-cta-paypal"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="{{ 'Donate via PayPal (opens in new tab)'|t }}">
          <span class="footer-cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" focusable="false">
              <path d="M14.06 3.713c.12-1.071-.093-1.832-.702-2.526C12.628.356 11.312 0 9.626 0H4.734a.7.7 0 0 0-.691.59L2.005 13.509a.42.42 0 0 0 .415.486h2.756l-.202 1.28a.628.628 0 0 0 .62.726H8.14c.429 0 .793-.31.862-.731l.025-.13.48-3.043.03-.164.001-.007a.351.351 0 0 1 .348-.297h.38c1.266 0 2.425-.256 3.345-.91.379-.27.712-.603.993-1.005a4.942 4.942 0 0 0 .88-2.195c.242-1.246.13-2.356-.57-3.079a2.274 2.274 0 0 0-.57-.395z"/>
            </svg>
          </span>
          <span>{{ 'PayPal'|t }}</span>
        </a>
        <button type="button"
                class="footer-cta-tertiary"
                data-donate-qr-modal="saho-footer-snapscan-overlay"
                aria-label="{{ 'Show Snapscan QR code to donate'|t }}">
          <span class="footer-cta-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" focusable="false">
              <path d="M3 11h8V3H3v8zm2-6h4v4H5V5zM3 21h8v-8H3v8zm2-6h4v4H5v-4zM13 3v8h8V3h-8zm6 6h-4V5h4v4zM13 13h2v2h-2v-2zm2 2h2v2h-2v-2zm2-2h2v2h-2v-2zm-2 4h2v2h-2v-2zm2 2h2v2h-2v-2zm-4-4h2v2h-2v-2zm0 4h2v2h-2v-2z"/>
            </svg>
          </span>
          <span>{{ 'Snapscan'|t }}</span>
        </button>
      </div>

      {# Inline overlay shown when the Snapscan button is clicked. Reuses
         the donate-snapscan-overlay markup + CSS so the experience matches
         the donate page. #}
      <div id="saho-footer-snapscan-overlay"
           class="donate-snapscan-overlay"
           role="dialog"
           aria-modal="true"
           aria-label="{{ 'Snapscan QR code'|t }}"
           hidden>
        <div class="donate-snapscan-overlay__backdrop" data-donate-qr-close></div>
        <div class="donate-snapscan-overlay__box">
          <button type="button"
                  class="donate-snapscan-overlay__close"
                  data-donate-qr-close
                  aria-label="{{ 'Close'|t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/></svg>
          </button>
          <h2 class="donate-snapscan-overlay__title">{{ 'Scan to donate'|t }}</h2>
          <img
            src="/modules/custom/saho_donate/images/snapscan-qr.gif"
            alt="{{ 'Snapscan QR code - scan with the Snapscan app to donate to SAHO'|t }}"
            class="donate-snapscan-overlay__qr"
          />
          <p class="donate-snapscan-overlay__note">{{ 'Open the Snapscan app and scan this code.'|t }}</p>
        </div>
      </div>

      <div class="footer-partner-badge">
        <img
          src="/themes/custom/saho/images/marion-institute.png"
          alt="SAHO is fiscally sponsored by the Marion Institute - marioninstitute.org"
          class="footer-partner-logo"
        />
      </div>
    </div>
  </div>

  {# Main link columns #}
  <div class="footer-top container py-4">
    <div class="row g-4 align-items-start">

      {# Column 1: SAHO Logo #}
      <div class="col-12 col-md-3 footer-col text-center">
        <img
          src="/themes/custom/saho/logo.svg"
          alt="SAHO Logo"
          class="footer-logo-img"
        />
      </div>

      {# Column 2: About #}
      <div class="col-12 col-md-3 footer-col text-center">
        <ul class="list-unstyled footer-links mb-0">
          <li><a href="/about-us">About us</a></li>
          <li><a href="/saho-timeline">SAHO Timeline</a></li>
          <li><a href="/about-us#saho-board-members">SAHO Board Members</a></li>
          <li><a href="/funders">Funders</a></li>
        </ul>
      </div>

      {# Column 3: Connect #}
      <div class="col-12 col-md-3 footer-col text-center">
        <ul class="list-unstyled footer-links mb-0">
          <li><a href="/contact-us">Contact us</a></li>
          <li><a href="/form/contribute">Contribute</a></li>
          <li><a href="/partners">Partners</a></li>
          <li><a href="/policy">Copyright &amp; Disclaimer</a></li>
        </ul>
      </div>

      {# Column 4: Social icons #}
      <div class="col-12 col-md-3 footer-col text-center">
        <strong class="footer-heading d-block mb-2">Follow us</strong>
          <ul class="list-unstyled d-flex flex-row footer-social-links mb-0 justify-content-center">
            <li class="me-3">
              <a href="https://facebook.com/sahistoryonline" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Facebook.svg" alt="Facebook" />
              </a>
            </li>
            <li class="me-3">
              <a href="https://instagram.com/sa_history_online" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Instagram.svg" alt="Instagram" />
              </a>
            </li>
            <li class="me-3">
              <a href="https://youtube.com/@sahistoryonline1" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Youtube.svg" alt="YouTube" />
              </a>
            </li>
            <li class="me-3">
              <a href="https://github.com/South-African-History-Online/sahistory-web/issues/new" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Github.svg" alt="GitHub" />
              </a>
            </li>
          </ul>
      </div>
    </div>
  </div>

  {# Thin divider #}
  <hr class="footer-divider" />

  {# Bottom row #}
  <div class="footer-bottom container py-3 text-center">
    <p class="footer-address mb-1">349 Albert Road, Woodstock</p>
    <p class="mb-1">
      &copy; {{ "now"|date("Y") }} South African History Online
    </p>
    <p class="footer-npo mb-0">
      NPO Registration: 037-117-NPO
    </p>
  </div>
</footer>
{% endapply %}
