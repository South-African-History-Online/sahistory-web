{#
/**
 * @file
 * SAHO site footer - Open Record 2027.
 *
 * Dark ink footer with the 2-tone accent rule, a brand column carrying the
 * mission blurb + single /donate CTA + social links, three nav columns
 * (Browse / Programmes / About SAHO) and a mono legal bottom bar.
 */
#}
{% apply spaceless %}
<footer class="saho-footer">

  {# Hard 2-tone accent rule (oxblood 62% / ochre 38%) #}
  <div class="saho-footer__accent" aria-hidden="true"></div>

  {# Main grid: brand column + three nav columns #}
  <div class="saho-footer__inner">

    {# Brand column #}
    <div class="saho-footer__brand">
      <p class="saho-footer__wordmark">South African History Online</p>
      <p class="saho-footer__mission">
        The largest independent, non-partisan history archive in South Africa.
        Anti-paywall by principle - knowledge here is free, sourced and accessible.
      </p>
      <a href="/donate" class="saho-footer__donate" aria-label="Donate to SAHO">Donate</a>
      <ul class="saho-footer__social" aria-label="SAHO on social media">
        <li>
          <a href="https://facebook.com/sahistoryonline" class="saho-footer__social-link" target="_blank" rel="noopener noreferrer">
            <img src="/themes/custom/saho/components/page-footer/icons/Facebook.svg" alt="Facebook" />
          </a>
        </li>
        <li>
          <a href="https://instagram.com/sa_history_online" class="saho-footer__social-link" target="_blank" rel="noopener noreferrer">
            <img src="/themes/custom/saho/components/page-footer/icons/Instagram.svg" alt="Instagram" />
          </a>
        </li>
        <li>
          <a href="https://youtube.com/@sahistoryonline1" class="saho-footer__social-link" target="_blank" rel="noopener noreferrer">
            <img src="/themes/custom/saho/components/page-footer/icons/Youtube.svg" alt="YouTube" />
          </a>
        </li>
        <li>
          <a href="https://github.com/South-African-History-Online/sahistory-web/issues/new" class="saho-footer__social-link" target="_blank" rel="noopener noreferrer">
            <img src="/themes/custom/saho/components/page-footer/icons/Github.svg" alt="GitHub" />
          </a>
        </li>
      </ul>
    </div>

    {# Browse #}
    <nav class="saho-footer__col" aria-label="Browse">
      <h2 class="saho-footer__col-title">Browse</h2>
      <ul class="saho-footer__links">
        <li><a href="/biographies">Biographies</a></li>
        <li><a href="/politics-society">Topics</a></li>
        <li><a href="/places">Places</a></li>
        <li><a href="/timelines">Timeline</a></li>
        <li><a href="/archives">Archive</a></li>
      </ul>
    </nav>

    {# Programmes #}
    <nav class="saho-footer__col" aria-label="Programmes">
      <h2 class="saho-footer__col-title">Programmes</h2>
      <ul class="saho-footer__links">
        <li><a href="/classroom">Classroom</a></li>
        <li><a href="/form/contribute">Contribute</a></li>
        <li><a href="/timeline">SAHO Timeline</a></li>
      </ul>
    </nav>

    {# About SAHO #}
    <nav class="saho-footer__col" aria-label="About SAHO">
      <h2 class="saho-footer__col-title">About SAHO</h2>
      <ul class="saho-footer__links">
        <li><a href="/about-us">About us</a></li>
        <li><a href="/about-us#saho-board-members">SAHO Board Members</a></li>
        <li><a href="/partners">Partners</a></li>
        <li><a href="/funders">Funders</a></li>
        <li><a href="/contact-us">Contact us</a></li>
        <li><a href="/policy">Copyright &amp; Disclaimer</a></li>
      </ul>
      <p class="saho-footer__org">
        349 Albert Road, Woodstock<br />
        NPO Registration: 037-117-NPO
      </p>
    </nav>
  </div>

  {# Legal bottom bar #}
  <div class="saho-footer__legal">
    <span class="saho-footer__legal-item">
      &copy; 2000-{{ "now"|date("Y") }} South African History Online &middot; Content licensed CC BY-NC-SA 4.0
    </span>
    <span class="saho-footer__legal-item">
      Accessibility: WCAG 2.2 AA
    </span>
    {# Built for the open web (R3 #476): the machine-readable record. #}
    <span class="saho-footer__legal-item saho-footer__open-data">
      Open data &middot; <a href="/llm.txt">llm.txt</a> &middot; <a href="/llm.txt">Citations API</a> &middot; <a href="/llm.txt">Schema.org</a>
    </span>
  </div>
</footer>
{% endapply %}
