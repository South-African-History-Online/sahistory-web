{#
/**
 * @file
 * Footer for SAHO with Marion Institute partnership and donation pathways.
 * White background, grey text, subtle divider lines.
 */
#}
{% apply spaceless %}
<footer class="saho-footer">

  {# Support SAHO banner - 3 donation pathways + Marion Institute partnership #}
  <div class="footer-support-banner">
    <div class="container py-4">
      <p class="footer-support-tagline">Keep South African history free and accessible</p>
      <div class="footer-support-actions">
        <a href="https://www.marioninstitute.org/south-african-history-online-donation-page/"
           class="footer-cta-primary"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Donate to SAHO via Marion Institute (opens in new tab)">
          <span class="footer-cta-icon" aria-hidden="true">♥</span>
          <span>Donate</span>
        </a>
        <a href="https://shop.sahistory.org.za/champion"
           class="footer-cta-secondary"
           aria-label="Become a SAHO Champion supporter">
          <span class="footer-cta-icon" aria-hidden="true">★</span>
          <span>Become a Champion</span>
        </a>
        <a href="https://pos.snapscan.io/qr/SAHO"
           class="footer-cta-tertiary"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="{{ 'Donate via Snapscan (opens in new tab)'|t }}">Snapscan</a>
      </div>
      <div class="footer-partner-badge">
        <img
          src="/themes/custom/saho/images/marion-institute.png"
          alt="We are a fiscal sponsorship of the Marion Institute - marioninstitute.org"
          class="footer-partner-logo"
        />
      </div>
    </div>
  </div>

  {# Main link columns #}
  <div class="footer-top container py-4">
    <div class="row g-4 align-items-start">

      {# Column 1: SAHO Logo #}
      <div class="col-12 col-md-3 footer-col text-center">
        <img
          src="/themes/custom/saho/logo.svg"
          alt="SAHO Logo"
          class="footer-logo-img"
        />
      </div>

      {# Column 2: About #}
      <div class="col-12 col-md-3 footer-col text-center">
        <ul class="list-unstyled footer-links mb-0">
          <li><a href="/about-us">About us</a></li>
          <li><a href="/saho-timeline">SAHO Timeline</a></li>
          <li><a href="/about-us#saho-board-members">SAHO Board Members</a></li>
          <li><a href="/funders">Funders</a></li>
        </ul>
      </div>

      {# Column 3: Connect #}
      <div class="col-12 col-md-3 footer-col text-center">
        <ul class="list-unstyled footer-links mb-0">
          <li><a href="/contact-us">Contact us</a></li>
          <li><a href="/form/contribute">Contribute</a></li>
          <li><a href="/partners">Partners</a></li>
          <li><a href="/policy">Copyright &amp; Disclaimer</a></li>
        </ul>
      </div>

      {# Column 4: Social icons #}
      <div class="col-12 col-md-3 footer-col text-center">
        <strong class="footer-heading d-block mb-2">Follow us</strong>
          <ul class="list-unstyled d-flex flex-row footer-social-links mb-0 justify-content-center">
            <li class="me-3">
              <a href="https://facebook.com/sahistoryonline" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Facebook.svg" alt="Facebook" />
              </a>
            </li>
            <li class="me-3">
              <a href="https://instagram.com/sa_history_online" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Instagram.svg" alt="Instagram" />
              </a>
            </li>
            <li class="me-3">
              <a href="https://youtube.com/@sahistoryonline1" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Youtube.svg" alt="YouTube" />
              </a>
            </li>
            <li class="me-3">
              <a href="https://github.com/South-African-History-Online/sahistory-web/issues/new" class="footer-social-link" target="_blank" rel="noopener noreferrer">
                <img src="/themes/custom/saho/components/page-footer/icons/Github.svg" alt="GitHub" />
              </a>
            </li>
          </ul>
      </div>
    </div>
  </div>

  {# Thin divider #}
  <hr class="footer-divider" />

  {# Bottom row #}
  <div class="footer-bottom container py-3 text-center">
    <p class="footer-address mb-1">349 Albert Road, Woodstock</p>
    <p class="mb-1">
      &copy; {{ "now"|date("Y") }} South African History Online
    </p>
    <p class="footer-npo mb-0">
      NPO Registration: 037-117-NPO
    </p>
  </div>
</footer>
{% endapply %}
