{#
/**
 * @file
 * Template for the main page.
 */
#}
{% set page_attributes = attributes ?: create_attribute() %}
{% set
  page_classes = [
    'page',
  ]|merge(page_utility_classes ?: [])
%}

<div {{ page_attributes.addClass(page_classes) }}>
	{% block page_navigation %}
		{# The legacy navbar region blocks are all disabled; skip the empty bar
		   entirely unless a region actually has content (S2 chrome owns the
		   header now). #}
		{% if page.navbar_branding|render|trim or page.navbar_left|render|trim or page.navbar_right|render|trim %}
			{% include 'saho:page-navigation' %}
		{% endif %}
	{% endblock %}

  {% block page_content %}
    {% include 'saho:page-content' with {
      page_main_utility_classes: ['py-5'],
      page_header_container_utility_classes: ['mb-3'],
      page_content_container_utility_classes: ['saho-page'],
      breadcrumb: breadcrumb,
    }%}
  {% endblock %}

</div>
