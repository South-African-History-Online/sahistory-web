{#
/**
 * @file SAHO Browse index SDC. props: title, items[] of {label, type, href, count}.
 * Every square is a real <a href> (SEO); count is optional and hidden when null.
 */
#}
<section{{ attributes.addClass('saho-browse-index') }}>
  {% if title %}
    <h2 class="saho-browse-index__title">{{ title }}</h2>
  {% endif %}
  <div class="saho-browse-index__grid">
    {% for item in items %}
      <a class="saho-browse-index__item saho-browse-index__item--{{ item.type }}" href="{{ item.href }}">
        <span class="saho-browse-index__label">{{ item.label }}</span>
        {% if item.count %}
          <span class="saho-browse-index__count">{{ item.count }}</span>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>
