{#
/**
 * @file
 * Shared tier grid partial — used on the front page and the champion page.
 *
 * Variables:
 * - show_link: boolean, show "Full membership benefits" link (default true).
 *              Set to false on the champion page where we are already there.
 */
#}
{% set show_link = show_link ?? true %}

<div class="tier-grid">

  <div class="tier-item">
    <p class="tier-item__label">{{ 'Monthly'|t }}</p>
    <div class="tier-item__price">
      <span class="tier-item__currency">R</span>
      <span class="tier-item__amount">200</span>
      <span class="tier-item__period">/{{ 'month'|t }}</span>
    </div>
    <p class="tier-item__note">{{ 'Cancel anytime'|t }}</p>
    <a href="/product/saho-champion-monthly-support-0" class="tier-item__cta">{{ 'Support monthly'|t }}</a>
  </div>

  <div class="tier-item tier-item--featured">
    <p class="tier-item__label">{{ 'Annual'|t }}</p>
    <div class="tier-item__price">
      <span class="tier-item__currency">R</span>
      <span class="tier-item__amount">2 000</span>
      <span class="tier-item__period">/{{ 'year'|t }}</span>
    </div>
    <p class="tier-item__note">{{ 'Equivalent to R167 per month'|t }}</p>
    <a href="/product/saho-champion-annual-support-0" class="tier-item__cta">{{ 'Support annually'|t }}</a>
  </div>

  <div class="tier-item">
    <p class="tier-item__label">{{ 'Patron Circle'|t }}</p>
    <div class="tier-item__price">
      <span class="tier-item__currency">R</span>
      <span class="tier-item__amount">5 000</span>
      <span class="tier-item__period">/{{ 'year'|t }}</span>
    </div>
    <p class="tier-item__note">{{ 'Tax certificate via Marion Institute'|t }}</p>
    <a href="/product/saho-champion-patron-support" class="tier-item__cta">{{ 'Become a Patron'|t }}</a>
  </div>

</div>

{% if show_link %}
  <div class="support-tiers-preview__link">
    <a href="/champion" class="support-text-link">
      {{ 'Full membership benefits and details'|t }}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/></svg>
    </a>
  </div>
{% endif %}
