{#
/**
 * @file
 * Publications catalog page template for SAHO Shop.
 *
 * Provides a styled hero header above the publications view output.
 *
 * @see template_preprocess_page()
 */
#}
{% do attach_library('saho_shop/page.catalog') %}

<div{{ attributes.addClass('publications-page') }}>
  {% block skip_link %}
    <a href="#main-content" class="visually-hidden-focusable">
      {{ 'Skip to main content'|t }}
    </a>
  {% endblock %}

  {% block top_bar %}
    {% if page.top_bar %}{{ page.top_bar }}{% endif %}
  {% endblock %}

  {% block header %}
    {% if page.header %}
      <header role="banner">{{ page.header }}</header>
    {% endif %}
  {% endblock %}

  {% block navigation %}
    {% if page.navigation %}
      <nav role="navigation" aria-label="{{ 'Main navigation'|t }}">
        {{ page.navigation }}
      </nav>
    {% endif %}
  {% endblock %}

  {% block messages %}
    {% if page_top %}{{ page_top }}{% endif %}
  {% endblock %}

  <main id="main-content" role="main">

    {# ==========================================
       PUBLICATIONS HERO
    ========================================== #}
    <section class="publications-hero" aria-labelledby="publications-hero-heading">
      <div class="publications-hero__backdrop" aria-hidden="true">
        <svg class="publications-hero__books" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 200" preserveAspectRatio="xMidYMid slice">
          <!-- Decorative stacked book spines -->
          <rect x="60"  y="40"  width="28" height="140" rx="3" fill="rgba(153,0,0,0.35)"/>
          <rect x="90"  y="20"  width="24" height="160" rx="3" fill="rgba(184,138,46,0.25)"/>
          <rect x="116" y="55"  width="32" height="125" rx="3" fill="rgba(255,255,255,0.08)"/>
          <rect x="150" y="35"  width="20" height="145" rx="3" fill="rgba(153,0,0,0.2)"/>
          <rect x="172" y="60"  width="28" height="120" rx="3" fill="rgba(184,138,46,0.15)"/>

          <rect x="600" y="50"  width="26" height="130" rx="3" fill="rgba(153,0,0,0.3)"/>
          <rect x="628" y="30"  width="22" height="150" rx="3" fill="rgba(255,255,255,0.07)"/>
          <rect x="652" y="45"  width="30" height="135" rx="3" fill="rgba(184,138,46,0.2)"/>
          <rect x="684" y="65"  width="24" height="115" rx="3" fill="rgba(153,0,0,0.18)"/>
          <rect x="710" y="40"  width="28" height="140" rx="3" fill="rgba(255,255,255,0.06)"/>
        </svg>
      </div>
      <div class="container publications-hero__inner">
        <div class="publications-hero__text">
          <div class="publications-hero__eyebrow" aria-hidden="true">
            <span class="publications-hero__rule"></span>
            <span>{{ 'SAHO Shop'|t }}</span>
            <span class="publications-hero__rule"></span>
          </div>
          <h1 id="publications-hero-heading" class="publications-hero__title">
            {{ 'Publications'|t }}
          </h1>
          <p class="publications-hero__subtitle">
            {{ 'Books, essays, and primary sources - curated by South African History Online.'|t }}
          </p>
        </div>
        <div class="publications-hero__badge" aria-label="{{ 'SAHO Champions receive a 20% discount'|t }}">
          <span class="publications-hero__badge-star" aria-hidden="true">★</span>
          <span class="publications-hero__badge-text">{{ 'Champion discount up to 20% off'|t }}</span>
          <a href="/champion" class="publications-hero__badge-link">{{ 'Learn more'|t }}</a>
        </div>
      </div>
    </section>

    {# ==========================================
       CATALOG CONTENT (View output)
    ========================================== #}
    <section class="publications-catalog" aria-label="{{ 'Publications catalog'|t }}">
      <div class="container">
        {% if page.content %}
          {{ page.content }}
        {% endif %}
      </div>
    </section>

  </main>

  {% block footer %}
    {% include '@saho_shop/page/_footer-shared.html.twig' %}
  {% endblock %}

  {% block page_bottom %}
    {% if page_bottom %}{{ page_bottom }}{% endif %}
  {% endblock %}
</div>
