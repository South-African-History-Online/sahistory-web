{#
/**
 * @file SAHO Archive card SDC.
 * props: type, title, href, excerpt, dates, meta, image, image_alt, duotone
 */
#}
{% set type = type|default('article') %}
<a{{ attributes.addClass(['saho-card', 'saho-card--' ~ type]) }} href="{{ href|default('#') }}">
  {% if image %}
    <div class="saho-card__media">
      <img class="saho-card__img{{ duotone ? ' saho-duotone' : '' }}" src="{{ image }}" alt="{{ image_alt|default('') }}" loading="lazy" />
      <span class="saho-card__badge">
        {% include 'saho:badge' with { type: type, on_image: true } only %}
      </span>
    </div>
  {% endif %}
  <div class="saho-card__body">
    {% if not image %}
      <div class="saho-card__badge-inline">{% include 'saho:badge' with { type: type } only %}</div>
    {% endif %}
    {% if dates %}<p class="saho-card__dates saho-meta">{{ dates }}</p>{% endif %}
    <h3 class="saho-card__title">{{ title }}</h3>
    {% if excerpt %}<p class="saho-card__excerpt">{{ excerpt }}</p>{% endif %}
    {% if meta %}<p class="saho-card__meta saho-meta">{{ meta }}</p>{% endif %}
  </div>
</a>
