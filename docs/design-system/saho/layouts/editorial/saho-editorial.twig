{#
/**
 * @file
 * SAHO — Editorial feature. Asymmetric lead + aside for the people's-history
 * register (features, campaigns, commemorations). Stacks on mobile.
 */
#}
<div{{ attributes.addClass('layout', 'layout--saho', 'layout--saho-editorial') }}>
  <div {{ region_attributes.lead.addClass('layout-builder__region', 'region--lead') }}>
    {{ content.lead }}
  </div>
  {% if content.aside %}
    <div {{ region_attributes.aside.addClass('layout-builder__region', 'region--aside') }}>
      {{ content.aside }}
    </div>
  {% endif %}
</div>
