{#
/**
 * @file
 * SAHO — Record + rail. Main record body with a sticky right rail for
 * provenance, chronology and cross-references. Stacks on mobile.
 */
#}
<div{{ attributes.addClass('layout', 'layout--saho', 'layout--saho-record') }}>
  <div {{ region_attributes.main.addClass('layout-builder__region', 'region--main') }}>
    {{ content.main }}
  </div>
  {% if content.rail %}
    <aside {{ region_attributes.rail.addClass('layout-builder__region', 'region--rail') }}>
      {{ content.rail }}
    </aside>
  {% endif %}
</div>
