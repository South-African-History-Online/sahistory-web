{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/navigation/**",
              "components/provenance/**",
              "components/record/**",
              "ui_kits/sahistory/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Libre Caslon Text|Libre Caslon Display|Archivo|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Libre Caslon Text, Libre Caslon Display, Archivo, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArchiveCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|href|excerpt|image|meta|dates|reference|duotone|style|key|ref|className|style|children)$/]",
        "message": "<ArchiveCard> doesn't accept that prop. Declared props: type, title, href, excerpt, image, meta, dates, reference, duotone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArchiveCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:article|biography|place|archive|event|topic)$/]",
        "message": "<ArchiveCard> type must be one of 'article' | 'biography' | 'place' | 'archive' | 'event' | 'topic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|children|onImage|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: type, children, onImage, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:article|biography|place|archive|event|topic)$/]",
        "message": "<Badge> type must be one of 'article' | 'biography' | 'place' | 'archive' | 'event' | 'topic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|as|href|iconBefore|iconAfter|fullWidth|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, as, href, iconBefore, iconAfter, fullWidth, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|quiet|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'quiet' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Citation'] > JSXAttribute > JSXIdentifier[name!=/^(?:formats|defaultFormat|style|key|ref|className|style|children)$/]",
        "message": "<Citation> doesn't accept that prop. Declared props: formats, defaultFormat, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentWarning'] > JSXAttribute > JSXIdentifier[name!=/^(?:reason|children|revealLabel|defaultRevealed|style|key|ref|className|style|children)$/]",
        "message": "<ContentWarning> doesn't accept that prop. Declared props: reason, children, revealLabel, defaultRevealed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImageCredit'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|credit|source|caption|duotone|ratio|style|key|ref|className|style|children)$/]",
        "message": "<ImageCredit> doesn't accept that prop. Declared props: src, alt, credit, source, caption, duotone, ratio, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IndexColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|width|sortable|mono|muted|render|key|ref|className|style|children)$/]",
        "message": "<IndexColumn> doesn't accept that prop. Declared props: key, label, align, width, sortable, mono, muted, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='IndexColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<IndexColumn> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetadataItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|href|key|ref|className|style|children)$/]",
        "message": "<MetadataItem> doesn't accept that prop. Declared props: label, value, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProvenanceSource'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|title|detail|href|key|ref|className|style|children)$/]",
        "message": "<ProvenanceSource> doesn't accept that prop. Declared props: author, title, detail, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecordFact'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<RecordFact> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='RelatedItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|note|href|key|ref|className|style|children)$/]",
        "message": "<RelatedItem> doesn't accept that prop. Declared props: label, type, note, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='RelatedItem'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:article|biography|place|archive|event|topic)$/]",
        "message": "<RelatedItem> type must be one of 'article' | 'biography' | 'place' | 'archive' | 'event' | 'topic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|size|scopes|defaultScope|buttonLabel|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: placeholder, size, scopes, defaultScope, buttonLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<SearchField> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|active|count|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, href, active, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:year|title|detail|theme|href|key|ref|className|style|children)$/]",
        "message": "<TimelineEvent> doesn't accept that prop. Declared props: year, title, detail, theme, href."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
